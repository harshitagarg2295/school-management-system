<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Teacher Dashboard</title>

  <!-- External Styles & Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

  <style>
    :root {
      --primary: #2196f3;
      --primary-gradient: linear-gradient(135deg, #1976d2, #42a5f5);
      --light-bg: #f4f7fb;
      --text-dark: #2c3e50;
      --border: #e0e0e0;
      --text-muted: #7f8c8d;
      --card-bg: #ffffff;
      --radius: 16px;
      --shadow: 0 4px 24px rgba(0, 0, 0, 0.06);
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      background: var(--light-bg);
      color: var(--text-dark);
    }

    .teacher-dash {
      display: flex;
      min-height: 100vh;
    }

    /* Outer Wrapper for Content + Calendar */
    .dashboard-content-wrapper {
      display: flex;
      flex: 1;
      gap: 24px;
      padding: 24px;
      align-items: flex-start;
    }

    /* Main Center Profile Container */
    .profile-container {
      font-family: 'Poppins', sans-serif;

      flex: 1;
      min-width: 0; /* Prevents flex items from breaking layout */
    }

    /* Top Hero Profile Banner Card */
    .hero-card {
      background: var(--primary-gradient);
      border-radius: var(--radius);
      padding: 30px;
      display: flex;
      align-items: center;
      gap: 26px;
      margin-bottom: 24px;
      color: white;
      box-shadow: var(--shadow);
    }

    .hero-avatar {
      width: 110px;
      height: 110px;
      border-radius: 50%;
      object-fit: cover;
      border: 4px solid rgba(255, 255, 255, 0.6);
      box-shadow: 0 4px 14px rgba(0, 0, 0, 0.15);
      flex-shrink: 0;
    }

    .hero-info h2 {
      font-size: 26px;
      font-weight: 700;
      margin-bottom: 4px;
      letter-spacing: -0.5px;
    }

    .hero-info p {
      font-size: 15px;
      opacity: 0.9;
      margin-bottom: 12px;
    }

    .hero-badges {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }

    .badge {
      background: rgba(255, 255, 255, 0.2);
      border: 1px solid rgba(255, 255, 255, 0.35);
      border-radius: 999px;
      padding: 5px 14px;
      font-size: 12px;
      font-weight: 500;
      display: inline-flex;
      align-items: center;
      gap: 6px;
    }

    /* Section Cards holding data items */
    .section-card {
      background: var(--card-bg);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      padding: 24px;
      margin-bottom: 24px;
      border: 1px solid rgba(0, 0, 0, 0.02);
    }

    .section-title {
      font-size: 14px;
      font-weight: 700;
      color: var(--text-dark);
      border-left: 4px solid var(--primary);
      padding-left: 12px;
      margin-bottom: 20px;
      text-transform: uppercase;
      letter-spacing: 0.8px;
      display: flex;
      align-items: center;
      gap: 6px;
    }

    /* Clean Information Grid */
    .info-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }

    .info-item {
      background: #f8fafc;
      border: 1px solid #edf2f7;
      border-radius: 12px;
      padding: 14px 16px;
      display: flex;
      align-items: center;
      gap: 14px;
      transition: all 0.25s ease;
    }

    .info-item:hover {
      border-color: var(--primary);
      background: #e3f2fd;
      transform: translateY(-2px);
    }

    .info-icon {
      width: 40px;
      height: 40px;
      border-radius: 10px;
      background: white;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--primary);
      font-size: 16px;
      flex-shrink: 0;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
    }

    .info-text label {
      font-size: 11px;
      color: var(--text-muted);
      font-weight: 600;
      display: block;
      margin-bottom: 2px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .info-text span {
      font-size: 15px;
      font-weight: 600;
      color: var(--text-dark);
      word-break: break-word;
    }

    /* Layout Utilities */
    .full-width {
      grid-column: span 2;
    }

    /* Glowing dynamic Warning box style if not assigned a class */
    .select-warning {
      background-color: #fffbeb !important;
      border: 1px solid #fde047 !important;
      animation: softWarn 2.5s infinite ease-in-out;
    }
    .select-warning .info-icon {
      color: #d97706 !important;
    }
    .select-warning label {
      color: #b45309 !important;
    }
    .badge-warning {
      background: rgba(251, 191, 36, 0.3) !important;
      border-color: rgba(251, 191, 36, 0.5) !important;
    }

    @keyframes softWarn {
      0%, 100% { box-shadow: var(--shadow); }
      50% { box-shadow: 0 0 16px rgba(234, 179, 8, 0.15); border-color: #eab308 !important; }
    }

    /* --- RESPONSIVE ADJUSTMENTS (Saves Gaps on Small Screens) --- */
    @media (max-width: 1150px) {
      .dashboard-content-wrapper {
        flex-direction: column;
        align-items: stretch;
        padding: 20px;
      }
      
      /* Forces attendance component full width beneath main content */
      .dashboard-content-wrapper > :last-child {
        width: 100% !important;
      }
    }

    @media (max-width: 768px) {
      .dashboard-content-wrapper {
        padding: 12px; /* Margins completely optimized for mobile screen */
        gap: 16px;
      }

      .hero-card {
        flex-direction: column;
        text-align: center;
        padding: 24px 16px;
        gap: 16px;
      }

      .hero-info h2 {
        font-size: 22px;
      }

      .hero-badges {
        justify-content: center;
      }

      .info-grid {
        grid-template-columns: 1fr; /* Stack layout seamlessly on phones */
        gap: 12px;
      }

      .full-width {
        grid-column: span 1;
      }

      .section-card {
        padding: 18px 16px;
        border-radius: 14px;
      }
    }
  </style>
</head>

<body>

  <div class="teacher-dash">

    <!-- Sidebar Inclusion -->
    <%- include("partials/TeacherPageSidebar") %>

    <!-- Content Engine -->
    <div class="dashboard-content-wrapper">
      
      <div class="profile-container">

        <!-- Top Profile Banner -->
        <div class="hero-card">
          <img
            src="<%= teacher?.photo ? (teacher.photo.startsWith('http') ? teacher.photo : '/uploads/teachers/' + teacher.photo) : '/default.png' %>"
            class="hero-avatar" alt="Profile Picture">

          <div class="hero-info">
            <h2><%= teacher.name %></h2>
            <p><%= teacher.subject || 'Faculty Member' %></p>

            <div class="hero-badges">
              <span class="badge">
                <i class="fa-solid fa-id-card"></i>
                <%= teacher.empId || 'N/A' %>
              </span>

              <span class="badge">
                <i class="fa-solid fa-book"></i>
                <%= teacher.subject || 'N/A' %>
              </span>

              <span class="badge <%= teacher.classTeacher !== 'yes' ? 'badge-warning' : '' %>">
                <i class="fa-solid fa-user-check"></i>
                <%= teacher.classTeacher === "yes" ? "Class Teacher" : "Subject Teacher" %>
              </span>
            </div>
          </div>
        </div>

        <!-- Professional Details -->
        <div class="section-card">
          <div class="section-title">
            <i class="fa-solid fa-briefcase"></i> Academic & Professional Details
          </div>

          <div class="info-grid">
            <div class="info-item">
              <div class="info-icon"><i class="fa-solid fa-chalkboard"></i></div>
              <div class="info-text">
                <label>Classes Handled</label>
                <span><%= teacher.class || 'N/A' %></span>
              </div>
            </div>

            <div class="info-item">
              <div class="info-icon"><i class="fa-solid fa-book-open"></i></div>
              <div class="info-text">
                <label>Primary Subject</label>
                <span><%= teacher.subject || 'N/A' %></span>
              </div>
            </div>

            <div class="info-item">
              <div class="info-icon"><i class="fa-solid fa-indian-rupee-sign"></i></div>
              <div class="info-text">
                <label>Salary</label>
                <span><%= teacher.salary || 'N/A' %></span>
              </div>
            </div>

            <!-- Conditional styling triggers if warning state detected -->
            <div class="info-item <%= teacher.classTeacher !== 'yes' ? 'select-warning' : '' %>">
              <div class="info-icon"><i class="fa-solid fa-building"></i></div>
              <div class="info-text">
                <label>Assigned Class Room</label>
                <span><%= teacher.assignedClass || 'None Assigned' %></span>
              </div>
            </div>
          </div>
        </div>

        <!-- Personal Information Section -->
        <div class="section-card">
          <div class="section-title">
            <i class="fa-solid fa-address-card"></i> Personal Information
          </div>

          <div class="info-grid">
            <div class="info-item">
              <div class="info-icon"><i class="fa-solid fa-phone"></i></div>
              <div class="info-text">
                <label>Phone Number</label>
                <span><%= teacher.phone || 'N/A' %></span>
              </div>
            </div>

            <div class="info-item">
              <div class="info-icon"><i class="fa-solid fa-user-shield"></i></div>
              <div class="info-text">
                <label>Class Teacher Status</label>
                <span><%= teacher.classTeacher === "yes" ? "Yes (Assigned)" : "No" %></span>
              </div>
            </div>

            <div class="info-item full-width">
              <div class="info-icon"><i class="fa-solid fa-location-dot"></i></div>
              <div class="info-text">
                <label>Residential Address</label>
                <span><%= teacher.address || 'N/A' %></span>
              </div>
            </div>
          </div>
        </div>

      </div>

      <!-- Right Column Attendance Integration Component -->
      <%- include("partials/attendanceCalendar", { size: "small" , type: "attendance-teacher" , attendance: attendance }) %>

    </div>
  </div>

  <script src="/backButton.js"></script>
</body>

</html>