<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Upload Study Material</title>
</head>
<style>
  .teacher-dash {
    display: flex;
}

body {
    font-family: "Segoe UI", Arial, sans-serif;
    background: #f5f7fa;
    margin: 0;
}

/* ----- Upload Card ----- */
.upload-card {
    flex: 1;
    max-width: 900px;
    margin: 40px auto;
    padding: 35px 45px;
    background: #ffffff;
    border-radius: 16px;
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.08);
    box-sizing: border-box;
}

/* Dropdown */
.select_class {
    padding: 10px 14px;
    border-radius: 10px;
    border: 1px solid #ccc;
    background-color: #f2f3f5;
    font-size: 14px;
    width: 100%;
    cursor: pointer;
}

/* Heading */
.upload-card h2 {
    text-align: center;
    color: #2c3e50;
    margin-bottom: 25px;
    font-size: 26px;
}

/* Form layout */
.upload-card form {
    display: flex;
    flex-direction: column;
    gap: 20px;
}

.upload-card input[type="text"],
.upload-card textarea {
    padding: 15px;
    border: 1px solid #dcdcdc;
    border-radius: 10px;
    font-size: 1em;
    width: 100%;
    background: #fafafa;
    transition: 0.3s;
}

.upload-card input[type="text"]:focus,
.upload-card textarea:focus {
    border-color: #3498db;
    box-shadow: 0 0 0 3px rgba(52, 152, 219, 0.2);
    background: #fff;
    outline: none;
}

.upload-card textarea {
    min-height: 150px;
    resize: vertical;
}

/* Upload button */
#uploadBtn {
    padding: 15px;
    background: #eef7ff;
    color: #3498db;
    border: 2px dashed #3498db;
    border-radius: 10px;
    cursor: pointer;
    text-align: center;
    font-weight: 600;
    transition: 0.3s;
}

#uploadBtn:hover {
    background: #e3f2ff;
    border-color: #2980b9;
}

/* Submit button */
.upload-card button[type="submit"] {
    padding: 15px;
    background-color: #2ecc71;
    color: white;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    font-size: 1.1em;
    font-weight: bold;
    transition: 0.2s;
}

.upload-card button[type="submit"]:hover {
    background-color: #27ae60;
}

/* --------------------- RESPONSIVE ---------------------- */

@media (max-width: 992px) {
    .upload-card {
        margin: 30px 40px;
        padding: 30px;
    }
}

@media (max-width: 768px) {
    .upload-card {
        margin: 20px;
        padding: 25px;
    }

    .select_class {
        font-size: 13px;
        padding: 9px 12px;
    }

    #uploadBtn {
        padding: 15px;
        font-size: 0.95em;
    }

    .upload-card button[type="submit"] {
        width: 100%;
    }
}

@media (max-width: 480px) {
    .upload-card {
        margin: 15px;
        padding: 20px;
    }

    .upload-card h2 {
        font-size: 22px;
    }

    .upload-card textarea {
        font-size: 14px;
    }

    .select_class {
        width: 100%;
    }
}

</style>

<body>
    <div class="teacher-dash">
        <%- include("partials/TeacherPageSidebar") %>

            <div class="upload-card">
                <h2>Upload Study Material</h2>

                <% if (status==='success' ) { %>
                    <p style="color: green; text-align: center; font-weight: bold;">✅ Material uploaded successfully!
                    </p>
                    <% } else if (errorMessage) { %>
                        <p style="color: red; text-align: center; font-weight: bold;">⚠️ <%= errorMessage %>
                        </p>
                        <% } %>

                            <form id="uploadForm" action="/teachers/upload-material" method="POST"
                                enctype="multipart/form-data">

                                <div class="class-select">
                                    <select id="classSelect" name="className" class="select_class">
                                        <option value="">Select Class</option>
                                        <% classList.forEach(c=> { %>
                                            <option value="<%= c %>" <%=c===selectedClass ? "selected" : "" %>>
                                                <%= c %>
                                            </option>
                                            <% }) %>
                                    </select>
                                </div>


                                <input type="text" name="title" placeholder="Subject name  Chapter No : Title"
                                    value="<%= locals.title || '' %>" required>

                                <input type="file" id="fileInput" name="material" style="display:none" multiple>

                                <button type="button" id="uploadBtn">📁 Add Photos / Files</button>

                                <textarea name="description" id="description" placeholder="Enter Description"
                                    required><%= locals.description || '' %></textarea>

                                <button type="submit">Upload</button>
                            </form>
            </div>
    </div>

</body>
<script>
    const fileInput = document.getElementById('fileInput');
    const uploadBtn = document.getElementById('uploadBtn');
    const uploadForm = document.getElementById('uploadForm');
    const classSelect = document.getElementById('classSelect');

    uploadBtn.addEventListener('click', () => fileInput.click()); // ✅ opens phone/PC file picker

    // ✅ Client-side validation for Class selection
    uploadForm.addEventListener('submit', function (e) {
        if (classSelect.value === "") {
            alert("⚠️ Please select a Class before uploading!");
            e.preventDefault();
        }
    });

</script>

</html>