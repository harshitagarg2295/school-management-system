<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Syllabus</title>

  <style>
    body {
      font-family: "Segoe UI", Arial, sans-serif;
      background: #f4f7fb;
      margin: 0;
      color: #2c3e50;
    }

    .teacher-dash {
      display: flex;
    }

    /* ------------------- MAIN SYLLABUS CARD ------------------- */
    .syllabus-card {
      max-width: 900px;
      width: 100%;
      margin: 40px 150px;
      padding: 40px 50px;
      background: #ffffff;
      border-radius: 16px;
      box-shadow: 0 6px 20px rgba(0, 0, 0, 0.08);
      box-sizing: border-box;
      transition: 0.3s;
    }

    /* ------------------- HEADING ------------------- */
    .syllabus-card h2 {
      text-align: center;
      color: #2c3e50;
      margin-bottom: 30px;
      font-size: 26px;
      font-weight: 600;
      border-bottom: 3px solid #2196f3;
      display: inline-block;
      padding-bottom: 6px;
    }

    /* ------------------- DROPDOWNS ------------------- */
    .dropdowns {
      display: flex;
      justify-content: center;
      flex-wrap: wrap;
      gap: 20px;
      margin-bottom: 30px;
    }

    select {
      padding: 10px 16px;
      border: 1px solid #ccc;
      border-radius: 10px;
      font-size: 15px;
      min-width: 180px;
      background: #f9fbfe;
    }

    select:focus {
      border-color: #2196f3;
      outline: none;
      box-shadow: 0 0 6px rgba(33, 150, 243, 0.3);
    }

    /* ------------------- GRID ------------------- */
    .syllabus-grid {
      margin-top: 40px;
      width: 100%;
      display: grid;
      grid-template-columns: minmax(140px, 200px) 1fr;
      gap: 15px 25px;
      align-items: start;
    }

    .subject-cell {
      background: #eef4fb;
      padding: 12px 16px;
      border-radius: 10px;
      border: 1px solid #e0e6ed;
      font-weight: 600;
      text-align: center;
    }

    .syllabus-grid textarea {
      width: 100%;
      min-height: 50px;
      padding: 10px 14px;
      border: 1px solid #d0d7de;
      border-radius: 10px;
      resize: vertical;
    }

    .syllabus-grid textarea:focus {
      border-color: #2196f3;
      background: #fff;
      box-shadow: 0 0 6px rgba(33, 150, 243, 0.25);
    }

    /* ------------------- MESSAGE ------------------- */
    .selection-message {
      grid-column: 1 / -1;
      text-align: center;
      padding: 40px;
      font-size: 17px;
      color: #555;
      background: #f9fbfe;
      border: 1px dashed #b8d7fa;
      border-radius: 12px;
    }

    /* ------------------- SAVE BUTTON ------------------- */
    .btn {
      text-align: center;
      margin-top: 40px;
    }

    .btn button {
      background: #2196f3;
      color: #fff;
      border: none;
      padding: 12px 35px;
      border-radius: 10px;
      font-size: 16px;
      font-weight: 600;
      cursor: pointer;
      box-shadow: 0 4px 10px rgba(33, 150, 243, 0.25);
    }

    .btn button:hover {
      background: #1976d2;
    }

    /* ------------------- RESPONSIVE FIXES ------------------- */
    @media (max-width: 1100px) {
      .syllabus-card {
        width: calc(100% - 200px);
        /* auto adjust */
        margin: 30px 100px;
        /* reduce margin */
      }
    }

    @media (max-width: 900px) {
      .syllabus-card {
        width: calc(100% - 100px);
        margin: 25px 50px;
        padding: 30px 35px;
      }

      .syllabus-grid {
        grid-template-columns: 1fr 1fr;
      }
    }

    @media (max-width: 768px) {
      .syllabus-card {
        width: calc(100% - 40px);
        margin: 20px;
        padding: 25px;
      }

      .syllabus-grid {
        grid-template-columns: 1fr;
      }

      .btn button {
        width: 100%;
      }
    }

    @media (max-width: 480px) {
      .syllabus-card {
        width: calc(100% - 20px);
        margin: 12px;
        padding: 20px;
      }

      select {
        width: 100%;
      }
    }
  </style>
</head>

<body>
  <div class="teacher-dash">
    <%- include("partials/TeacherPageSidebar") %>

      <form id="syllabusForm" action="/teachers/save-syllabus" method="POST">
        <div class="syllabus-card">
          <h2>
            <%= (typeof type !=='undefined' && type==="monthly" ) ? "Add Monthly Test Syllabus" : "Add Exams Syllabus"
              %>
          </h2>

          <input type="hidden" name="type" value="<%= type %>">

          <div class="dropdowns">
            <select id="classSelect" name="className">
              <option value="">Select Class</option>
              <% classList.forEach(c=> { %>
                <option value="<%= c %>" <%=c===selectedClass ? "selected" : "" %>>
                  <%= c %>
                </option>
                <% }) %>
            </select>

            <% if (type==="monthly" ) { %>
              <select id="testType" name="period">
                <option value="">Select Month</option>
                <% ["January", "February" , "March" , "April" , "May" , "June" , "July" , "August" , "September"
                  , "October" , "November" , "December" ].forEach(m=> { %>
                  <option value="<%= m %>" <%=m===selectedPeriod ? "selected" : "" %>> <%= m %>
                  </option>
                  <% }) %>
              </select>
              <% } else { %>
                <select id="testType" name="period">
                  <option value="">Select Exam</option>
                  <% ["Quarterly", "Half-Yearly" , "Annual" , "Pre-Board" ].forEach(e=> { %>
                    <option value="<%= e %>" <%=e===selectedPeriod ? "selected" : "" %>> <%= e %>
                    </option>
                    <% }) %>
                </select>
                <% } %>
          </div>

          <div class="syllabus-grid" id="syllabusGrid">
            <% if (subjects.length===0) { %>
              <div class="selection-message">
                <p> Please select a Class and a Month/Exam to add/view syllabus.</p>
              </div>
              <% } else { %>
                <% subjects.forEach(sub=> { %>
                  <% const savedSubject=savedSyllabus?.subjects.find(s=> s.name === sub);
                    const content = savedSubject ? savedSubject.content : ''; %>
                    <div class="subject-cell">
                      <%= sub %>
                    </div>
                    <textarea name="<%= sub %>"><%= content %></textarea>
                    <% }) %>
                      <% } %>
          </div>

          <% if (subjects.length===0) { %>
            <div class="btn" style="display: none;">
              <button type="submit">Save</button>
            </div>
            <% } else { %>
              <div class="btn">
                <button type="submit">Save</button>
              </div>
              <% } %>
        </div>
      </form>
  </div>

  <script>
    const classSelect = document.getElementById('classSelect');
    const testTypeSelect = document.getElementById('testType');
    const syllabusForm = document.getElementById('syllabusForm');
    const type = "<%= type %>";

    const redirectToSyllabus = () => {
      const className = classSelect.value || 'null';
      const period = testTypeSelect.value || 'null';
      if (className !== 'null' && period !== 'null') {
        window.location.href = `/teachers/get-syllabus-view/${type}/${className}/${period}`;
      }
    };

    classSelect.addEventListener('change', redirectToSyllabus);
    testTypeSelect.addEventListener('change', redirectToSyllabus);

    syllabusForm.addEventListener("submit", function (e) {
      const className = classSelect.value;
      const period = testTypeSelect.value;

      if (!className || !period) {
        alert("⚠️ Please select a Class and a Month/Exam before saving!");
        e.preventDefault();
        return;
      }
    });
  </script>
</body>

</html>