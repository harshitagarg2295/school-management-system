<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <title>Teacher Profile</title>

  <link rel="stylesheet" href="/css/adminDashboard.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

  <style>
    :root {
      --primary: #2196f3;
      --light-bg: #f4f7fb;
      --text-dark: #2c3e50;
      --border: #e0e0e0;
      --card-bg: #ffffff;
    }

    body {
      margin: 0;
      background: var(--light-bg);
      color: var(--text-dark);
    }

    .teacher-dash {
      display: flex;
    }

    /* 🔥 MAIN CARD (same alignment as salary page) */
    .profile-card {
      font-family: "Poppins", sans-serif;
      margin: 20px 20px 20px 40px;
      width: 83%;
      background: var(--card-bg);
      padding: 35px 30px;
      border-radius: 16px;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
      transition: 0.3s;
    }

    /* 🔥 HEADER */
    .profile-header {
      display: flex;
      align-items: center;
      gap: 25px;
      margin-bottom: 20px;
      border-bottom: 2px solid var(--border);
      padding-bottom: 20px;
    }

    .profile-img {
      width: 110px;
      height: 110px;
      border-radius: 50%;
      object-fit: cover;
      border: 4px solid var(--primary);
      box-shadow: 0 3px 10px rgba(0, 0, 0, 0.15);
    }

    .profile-header h2 {
      margin: 0;
      font-size: 26px;
      font-weight: 600;
    }

    .profile-header p {
      margin: 5px 0 0;
      color: var(--primary);
      font-weight: 500;
    }

    /* 🔥 GRID */
    .profile-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 18px;
    }

    /* 🔥 ITEM BOX */
    .profile-item {
      background: var(--light-bg);
      padding: 10px;
      border-radius: 10px;
      transition: 0.3s;
    }

    .profile-item:hover {
      background: #e3f2fd;
      transform: translateY(-2px);
    }

    .profile-item label {
      font-size: 15px;
      color: #555;
      display: block;
      margin-bottom: 5px;
    }

    .profile-item span {
      font-weight: 600;
    }

    .full-width {
      grid-column: span 2;
    }

    /* 📱 Responsive */
    @media (max-width: 768px) {
      .profile-card {
        margin: 20px;
        width: 100%;
        padding: 20px;
      }

      .profile-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>

<body>

  <div class="teacher-dash">

    <!-- Sidebar -->
    <%- include("partials/TeacherPageSidebar") %>

      <!-- Profile Card -->
      <div class="profile-card">

        <!-- Header -->
        <div class="profile-header">

          <img
            src="<%= teacher?.photo ? (teacher.photo.startsWith('http') ? teacher.photo : '/uploads/teachers/' + teacher.photo) : '/default.png' %>"
            class="profile-img">
          <div>
            <h2>
              <%= teacher.name %>
            </h2>
            <p>
              <%= teacher.subject %>
            </p>
          </div>

        </div>

        <!-- Details -->
        <div class="profile-grid">

          <div class="profile-item">
            <label>Employee ID</label>
            <span>
              <%= teacher.empId %>
            </span>
          </div>

          <div class="profile-item">
            <label>Username</label>
            <span>
              <%= teacher.username %>
            </span>
          </div>

          <div class="profile-item">
            <label>Phone</label>
            <span>
              <%= teacher.phone %>
            </span>
          </div>

          <div class="profile-item">
            <label>Gender</label>
            <span>
              <%= teacher.gender || "N/A" %>
            </span>
          </div>

          <div class="profile-item">
            <label>Date of Birth</label>
            <span>
              <%= teacher.dob ? teacher.dob.toISOString().split("T")[0] : "N/A" %>
            </span>
          </div>

          <div class="profile-item">
            <label>Blood Group</label>
            <span>
              <%= teacher.bloodGroup || "N/A" %>
            </span>
          </div>

          <div class="profile-item">
            <label>Salary</label>
            <span>
              <%= teacher.salary %>
            </span>
          </div>

          <div class="profile-item">
            <label>Education</label>
            <span>
              <%= teacher.education || "N/A" %>
            </span>
          </div>

          <div class="profile-item">
            <label>Experience</label>
            <span>
              <%= teacher.experience || "N/A" %>
            </span>
          </div>

          <div class="profile-item">
            <label>Classes</label>
            <span>
              <%= teacher.class %>
            </span>
          </div>

          <div class="profile-item">
            <label>Assigned Class</label>
            <span>
              <%= teacher.assignedClass || "N/A" %>
            </span>
          </div>

          <div class="profile-item">
            <label>Class Teacher</label>
            <span>
              <%= teacher.classTeacher==="yes" ? "Yes" : "No" %>
            </span>
          </div>

          <div class="profile-item full-width">
            <label>Address</label>
            <span>
              <%= teacher.address || "N/A" %>
            </span>
          </div>

        </div>

      </div>

  </div>

</body>

</html>