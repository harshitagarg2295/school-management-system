<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>View Material Uploaded By You</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
</head>

<style>
    body {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background: #f5f7fa;
        margin: 0;
    }

    .teacher-dash {
        display: flex;
    }

    /* ------------------- Main Card ------------------- */
    .material-card {
        flex: 1;
        max-width: 1200px;
        margin: 40px auto;
        padding: 40px 50px;
        background: #ffffff;
        border-radius: 16px;
        box-shadow: 0 6px 20px rgba(0, 0, 0, 0.1);
        box-sizing: border-box;
    }

    /* Heading */
    .material-card h2 {
        font-size: 28px;
        margin-bottom: 25px;
        text-align: left;
        color: #2c3e50;
        border-bottom: 2px solid #dfe6ee;
        padding-bottom: 8px;
        font-weight: 600;
    }

    /* ------------------- Search + Filter ------------------- */
    .search-stud {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 15px;
        margin-bottom: 30px;
    }

    /* Search Box */
    .search-container {
        position: relative;
        flex-grow: 1;
        min-width: 260px;
        max-width: 400px;
    }

    .search-container i {
        position: absolute;
        left: 15px;
        top: 50%;
        transform: translateY(-50%);
        color: #7f8c8d;
    }

    .search-container input {
        width: 100%;
        padding: 12px 15px 12px 42px;
        border-radius: 30px;
        border: 1px solid #cdd6dd;
        font-size: 15px;
        transition: 0.3s;
        background: white;
    }

    .search-container input:focus {
        border-color: #3498db;
        outline: none;
        box-shadow: 0 0 0 3px rgba(52, 152, 219, 0.2);
    }

    /* Filter Dropdown */
    .select_class {
        padding: 10px 15px;
        border-radius: 10px;
        background: #f2f3f6;
        font-size: 15px;
        border: 1px solid #d0d7de;
        min-width: 180px;
    }

    /* ------------------- Material Grid ------------------- */
    .material-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 25px;
        margin-top: 10px;
    }

    /* ------------------- Material Box ------------------- */
    .material-box {
        background: #ffffff;
        border: 1px solid #e2e6ea;
        border-radius: 12px;
        padding: 20px 18px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        transition: 0.3s ease;
    }

    .material-box:hover {
        transform: translateY(-3px);
        box-shadow: 0 6px 18px rgba(0, 0, 0, 0.1);
    }

    /* Title */
    .title {
        font-size: 1.15rem;
        font-weight: 600;
        color: #2c3e50;
        margin-bottom: 8px;
        padding-bottom: 5px;
        border-bottom: 1px solid #e6ecf1;
    }

    /* Description */
    .description {
        font-size: 0.95rem;
        color: #7f8c8d;
        line-height: 1.5;
        margin-bottom: 15px;
    }

    /* Footer with date + teacher + download */
    .material-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-top: 1px solid #e6ecf1;
        padding-top: 12px;
        margin-top: auto;
    }

    .meta-info {
        display: flex;
        gap: 12px;
        font-size: 0.85em;
        color: #95a5a6;
    }

    .meta-item i {
        margin-right: 5px;
        color: #3498db;
    }

    /* Download Button */
    .btn-group {
        display: flex;
        gap: 8px;
        align-items: center;
        flex-wrap: wrap;
    }
    .preview-btn {
        background-color: #10b981;
        padding: 7px 13px;
        color: white;
        border: none;
        border-radius: 20px;
        cursor: pointer;
        font-size: 0.85em;
        font-weight: 600;
        transition: 0.3s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 5px;
    }
    .preview-btn:hover { background-color: #059669; }
    .download-btn {
        background-color: #3498db;
        padding: 7px 13px;
        color: white;
        border: none;
        border-radius: 20px;
        cursor: pointer;
        font-size: 0.85em;
        font-weight: 600;
        transition: 0.3s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 5px;
    }
    .download-btn:hover { background-color: #217dbb; }
    .file-type-badge {
        display: inline-block;
        background: #f1f5f9;
        border: 1px solid #e2e8f0;
        border-radius: 6px;
        padding: 2px 8px;
        font-size: 0.75em;
        font-weight: 700;
        color: #475569;
        text-transform: uppercase;
        margin-bottom: 8px;
    }

    /* ------------------- RESPONSIVE ------------------- */

    /* Tablets */
    @media (max-width: 992px) {
        .material-card {
            margin: 30px;
            padding: 30px;
        }
    }

    /* Mobile Screens */
    @media (max-width: 768px) {
        .material-card {
            margin: 20px;
            padding: 25px;
        }

        .material-card h2 {
            margin-left: 28px;
            text-align: center;
        }

        .search-stud {
            flex-direction: column;
            align-items: stretch;
        }

        .select_class {
            width: 100%;
        }

        .download-btn {
            padding: 10px;
            width: 100%;
        }
    }

    /* Extra Small */
    @media (max-width: 480px) {
        .material-card {
            padding: 20px;
            margin: 12px;
        }

        .title {
            font-size: 1.05rem;
        }
    }
</style>

<body>

    <div class="teacher-dash">

        <%- include("partials/TeacherPageSidebar") %>

        <div class="material-card">

            <h2>Materials Uploaded By You</h2>

            <div class="search-stud">
                <div class="search-container">
                    <i class="fas fa-search"></i>
                    <input type="text" name="search" id="searchInput" placeholder="Search by Title">
                </div>

                <div class="class-select">
                    <select id="classSelect" name="className" class="select_class">
                        <option value="">Select Class</option>
                        <% classList.forEach(c => { %>
                            <option value="<%= c %>" <%= c === selectedClass ? "selected" : "" %>>
                                <%= c %>
                            </option>
                        <% }) %>
                    </select>
                </div>
            </div>

            <div class="material-grid">
                <% if (materials && materials.length > 0) { %>
                    <% materials.forEach(material => { %>
                        <!-- Fixed Loop placement: Card div dynamically repeats inside the grid -->
                        <div class="material-box">
                            <div class="title">
                                <%= material.title %>
                            </div>
                            <div class="description">
                                <%= material.description %>
                            </div>

                            <div class="material-footer">
                                <div class="meta-info">
                                    <span class="meta-item">
                                        <i class="fas fa-user-tie"></i>
                                        <%= material.uploadedBy %>
                                    </span>
                                    <span class="meta-item">
                                        <i class="far fa-clock"></i>
                                        <%= new Date(material.uploadedAt).toISOString().split('T')[0] %>
                                    </span>
                                </div>

                                <div class="btn-group">
                                    <a href="/teachers/delete-material/<%= material._id %>"
                                       onclick="return confirm('Are you sure you want to delete this material?')"
                                       style="color: #e74c3c; font-size: 1.2rem;">
                                        <i class="fas fa-trash-alt"></i>
                                    </a>

                            <%
                                const fUrl = material.fileUrl || '';
                                const fPublicId = (material.publicId || '').toLowerCase();
                                const isImg = fUrl.includes('/image/upload/') || /\.(jpg|jpeg|png|gif|webp|svg)$/i.test(fUrl);
                                // Check BOTH fileUrl and publicId — publicId may lack extension
                                const isPdf = /\.pdf$/i.test(fUrl) || fPublicId.endsWith('.pdf');
                                let extLabel = 'FILE';
                                if (isImg) extLabel = 'IMAGE';
                                else if (isPdf) extLabel = 'PDF';
                                else if (/\.docx?$/i.test(fUrl) || fPublicId.endsWith('.doc') || fPublicId.endsWith('.docx')) extLabel = 'DOC';
                                else if (/\.xlsx?$/i.test(fUrl) || fPublicId.endsWith('.xls') || fPublicId.endsWith('.xlsx')) extLabel = 'XLS';
                                else if (/\.pptx?$/i.test(fUrl) || fPublicId.endsWith('.ppt') || fPublicId.endsWith('.pptx')) extLabel = 'PPT';
                                // Build preview URL: inject fl_inline so PDFs open in-browser
                                const previewUrl = (isPdf && fUrl.includes('/upload/'))
                                    ? fUrl.replace('/upload/', '/upload/fl_inline/')
                                    : fUrl;
                            %>

                                    <!-- Preview: server-side route handles all types -->
                                    <a href="/teachers/preview-material/<%= material._id %>" target="_blank" class="preview-btn">
                                        <i class="fas fa-eye"></i> Preview
                                    </a>

                                    <!-- Download: server-side route forces download for all types -->
                                    <a href="/teachers/download-material/<%= material._id %>" class="download-btn">
                                        <i class="fas fa-download"></i> Download
                                    </a>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <p style="grid-column: 1 / -1; text-align: center; padding: 50px; color: #7f8c8d;">
                        You haven't uploaded any study material yet.
                    </p>
                <% } %>
            </div>
        </div>
    </div>
    <script src="/backButton.js"></script>
</body>

<script>
    const searchInput = document.getElementById('searchInput');
    const materialGrid = document.querySelector('.material-grid');
    const materialCards = materialGrid ? materialGrid.querySelectorAll('.material-box') : [];

    searchInput.addEventListener('keyup', function () {
        const searchTerm = this.value.toLowerCase().trim();

        materialCards.forEach(card => {
            const titleElement = card.querySelector('.title');
            const titleText = titleElement ? titleElement.textContent.toLowerCase() : '';

            if (titleText.includes(searchTerm)) {
                card.style.display = 'flex';
            } else {
                card.style.display = 'none';
            }
        });
    });

    // Class Filter Logic
    const classSelect = document.getElementById('classSelect');

    classSelect.addEventListener('change', function () {
        const selectedClass = this.value;
        let redirectUrl = '/teachers/view-material';

        if (selectedClass) {
            redirectUrl += '?class=' + selectedClass;
        }

        window.location.href = redirectUrl;
    });
</script>

</html>