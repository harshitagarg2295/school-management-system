<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Transaction History | <%= school.name %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
    <style>
        :root {
            --bg-dark: #0f172a;
            --card-dark: #1e293b;
            --primary-blue: #3b82f6;
            --accent-blue: #60a5fa;
            --text-main: #f8fafc;
            --text-muted: #94a3b8;
            --border-color: #334155;
            --success: #22c55e;
        }

        body {
            margin: 0;
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-dark);
            color: var(--text-main);
        }

        .container {
            max-width: 1000px;
            margin: 40px auto;
            padding: 0 20px;
        }

        /* Header Section */
        .header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 30px;
            gap: 15px;
        }

        .header h2 {
            margin: 0;
            font-size: 28px;
            background: linear-gradient(to right, #fff, var(--accent-blue));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .school-info-tag {
            display: inline-block;
            background: rgba(59, 130, 246, 0.1);
            color: var(--accent-blue);
            padding: 4px 12px;
            border-radius: 6px;
            font-size: 13px;
            margin-top: 8px;
            border: 1px solid rgba(59, 130, 246, 0.2);
        }

        /* 🔥 FIX: Added z-index & pointer-events to ensure button is always clickable */
        .btn-back {
            background: var(--card-dark);
            color: var(--text-main);
            padding: 10px 18px;
            border-radius: 10px;
            text-decoration: none;
            border: 1px solid var(--border-color);
            font-size: 14px;
            display: flex;
            align-items: center;
            gap: 8px;
            white-space: nowrap;
            transition: 0.3s;
            position: relative;
            z-index: 10;
            cursor: pointer;
        }

        .btn-back:hover {
            background: #2d3a4f;
        }

        /* Summary Mini Card */
        .summary-card {
            background: linear-gradient(145deg, #1e293b, #111827);
            padding: 20px;
            border-radius: 15px;
            border: 1px solid var(--border-color);
            margin-bottom: 30px;
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .summary-icon {
            width: 50px;
            height: 50px;
            background: rgba(34, 197, 94, 0.1);
            color: var(--success);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            flex-shrink: 0;
        }

        /* 📱 RESPONSIVE SCROLLABLE TABLE CONTAINER */
        .table-container {
            background: var(--card-dark);
            border-radius: 20px;
            border: 1px solid var(--border-color);
            overflow-x: auto; 
            -webkit-overflow-scrolling: touch;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            min-width: 600px; 
        }

        th {
            background: rgba(255, 255, 255, 0.02);
            text-align: left;
            padding: 18px;
            color: var(--text-muted);
            font-size: 13px;
            text-transform: uppercase;
            letter-spacing: 1px;
            border-bottom: 1px solid var(--border-color);
            white-space: nowrap;
        }

        td {
            padding: 18px;
            border-bottom: 1px solid rgba(51, 65, 85, 0.5);
            font-size: 15px;
            white-space: nowrap; 
        }

        tr:last-child td {
            border-bottom: none;
        }

        .plan-badge {
            background: rgba(59, 130, 246, 0.1);
            color: var(--accent-blue);
            padding: 4px 10px;
            border-radius: 6px;
            font-size: 12px;
            text-transform: capitalize;
        }

        .amount-text {
            color: var(--success);
            font-weight: 600;
        }

        .date-text {
            color: var(--text-main);
        }

        .empty-state {
            padding: 60px;
            text-align: center;
            color: var(--text-muted);
        }

        .empty-state i {
            font-size: 40px;
            margin-bottom: 15px;
            display: block;
        }

        /* 📱 MOBILE MEDIA QUERIES */
        @media (max-width: 600px) {
            .container {
                margin: 20px auto;
            }

            .header {
                flex-direction: column;
                align-items: stretch;
            }

            .btn-back {
                justify-content: center;
                margin-top: 15px;
            }

            .header h2 {
                font-size: 24px;
            }

            .summary-card {
                padding: 15px;
                gap: 15px;
            }

            .summary-card h3 {
                font-size: 20px !important;
            }
        }
    </style>
</head>
<body>

    <div class="container">
        <div class="header">
            <div>
                <h2>Transaction History</h2>
                <div class="school-info-tag">
                    <i class="fa-solid fa-school"></i> <%= school.name %> (<%= school.code %>)
                </div>
            </div>
            <a href="/super-admin/schools" class="btn-back">
                <i class="fa-solid fa-arrow-left"></i> Back to Schools
            </a>
        </div>

        <!-- Mini Summary Card -->
        <div class="summary-card">
            <div class="summary-icon">
                <i class="fa-solid fa-wallet"></i>
            </div>
            <div>
                <p style="margin: 0; color: var(--text-muted); font-size: 13px;">Total Revenue from this School</p>
                <h3 style="margin: 5px 0 0 0; font-size: 24px; color: var(--success);">
                    ₹<%= history.reduce((sum, tx) => sum + tx.amount, 0).toLocaleString('en-IN') %>
                </h3>
            </div>
        </div>

        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Payment Date</th>
                        <th>Plan Details</th>
                        <th>Amount Paid</th>
                        <th>Expiry Set To</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (history && history.length > 0) { %>
                        <% history.forEach(tx => { %>
                            <tr>
                                <td class="date-text">
                                    <i class="fa-regular fa-calendar-check" style="margin-right: 8px; color: var(--text-muted);"></i>
                                    <%= tx.paymentDate.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                                </td>
                                <td>
                                    <span class="plan-badge"><%= tx.plan %></span>
                                </td>
                                <td class="amount-text">
                                    ₹<%= tx.amount.toLocaleString('en-IN') %>
                                </td>
                                <td style="color: var(--text-muted);">
                                    <%= tx.expiryDateAtThatTime ? tx.expiryDateAtThatTime.toLocaleDateString('en-GB') : 'N/A' %>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="4" class="empty-state">
                                <i class="fa-solid fa-box-open"></i>
                                No transaction records found for this school.
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
<script src="/backButton.js"></script>
</body>
</html>