<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Super Admin Dashboard</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
    <style>
        :root {
            --bg-dark: #0f172a;
            --card-dark: #1e293b;
            --primary-blue: #3b82f6;
            --accent-blue: #60a5fa;
            --text-main: #f8fafc;
            --text-muted: #94a3b8;
            --border-color: #334155;
            --success: #22c55e;
            --danger: #ef4444;
        }

        body {
            margin: 0;
            font-family: 'Inter', -apple-system, sans-serif;
            background-color: var(--bg-dark);
            color: var(--text-main);
            line-height: 1.6;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }

        /* Header */
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
            gap: 15px;
            flex-wrap: wrap;
        }

        .header h1 {
            font-size: clamp(22px, 5vw, 28px);
            margin: 0;
            background: linear-gradient(to right, #fff, var(--accent-blue));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .logout-btn {
            background: rgba(239, 68, 68, 0.1);
            color: var(--danger);
            padding: 10px 20px;
            border-radius: 10px;
            text-decoration: none;
            border: 1px solid rgba(239, 68, 68, 0.2);
            transition: 0.3s;
            font-size: 14px;
        }

        /* Stats Grid */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 20px;
            margin-bottom: 25px;
        }

        .stat-card {
            background: var(--card-dark);
            padding: 25px;
            border-radius: 20px;
            border: 1px solid var(--border-color);
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .revenue-card {
            background: linear-gradient(145deg, #1e293b, #1e1b4b) !important;
            border: 1px solid rgba(59, 130, 246, 0.5) !important;
            padding: 25px;
            display: flex;
            flex-direction: row;
            align-items: center;
            justify-content: space-between;
            gap: 15px;
            width: 100%;
            box-sizing: border-box;
        }

        .revenue-main {
            display: flex;
            align-items: center;
            gap: 20px;
            width: auto;
        }

        .revenue-badge {
            background: rgba(34, 197, 94, 0.15);
            color: var(--success);
            padding: 8px 15px;
            border-radius: 10px;
            font-size: 13px;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 8px;
            border: 1px solid rgba(34, 197, 94, 0.2);
            white-space: nowrap;
        }

        .icon-box {
            width: 55px;
            height: 55px;
            border-radius: 15px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 22px;
            background: rgba(59, 130, 246, 0.1);
            color: var(--primary-blue);
            flex-shrink: 0;
        }

        .stat-info h3 {
            margin: 0;
            font-size: 26px;
            color: #fff;
        }

        .stat-info p {
            margin: 0;
            color: var(--text-muted);
            font-size: 14px;
        }

        /* Actions */
        .actions {
            display: flex;
            gap: 15px;
            margin-bottom: 30px;
            flex-wrap: wrap;
        }

        .btn {
            padding: 12px 24px;
            border-radius: 12px;
            text-decoration: none;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: 0.3s;
        }

        .btn-primary {
            background: var(--primary-blue);
            color: white;
        }

        .btn-secondary {
            border: 1px solid var(--border-color);
            color: white;
            background: rgba(255, 255, 255, 0.05);
        }

        /* Layout Grid */
        .dashboard-main-grid {
            display: grid;
            grid-template-columns: 1.6fr 1fr;
            gap: 20px;
        }

        .content-box {
            background: var(--card-dark);
            border-radius: 20px;
            border: 1px solid var(--border-color);
            padding: 20px;
            height: fit-content;
        }

        .content-box h3 {
            margin: 0 0 20px 0;
            font-size: 18px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .table-wrapper {
            width: 100%;
            overflow-x: auto;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            min-width: 300px;
        }

        th {
            text-align: left;
            padding: 12px;
            color: var(--text-muted);
            font-size: 13px;
            border-bottom: 1px solid var(--border-color);
        }

        td {
            padding: 12px;
            font-size: 14px;
            border-bottom: 1px solid rgba(51, 65, 85, 0.5);
        }

        .badge {
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 600;
        }

        .badge-active {
            background: rgba(34, 197, 94, 0.15);
            color: var(--success);
        }

        .badge-expired {
            background: rgba(239, 68, 68, 0.15);
            color: var(--danger);
        }

        @media (max-width: 1024px) {
            .dashboard-main-grid {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 645px) {
            .stats-grid {
                grid-template-columns: 1fr;
            }

            .header {
                flex-direction: column;
                align-items: flex-start;
            }

            .logout-btn,
            .btn {
                width: 100%;
                justify-content: center;
                box-sizing: border-box;
            }
        }

        @media(max-width:550px) {
            .revenue-card {
                flex-direction: column;
                align-items: flex-start;
            }

            .revenue-badge {
                justify-content: center;
            }
        }
    </style>
</head>

<body>
    <div class="container">
        <!-- Header -->
        <header class="header">
            <div>
                <h1>Super Admin Portal</h1>
                <p style="color: var(--text-muted); margin-top: 5px;">Welcome back, here's what's happening.</p>
            </div>
            <a href="/super-admin/logout" class="logout-btn"><i class="fa-solid fa-power-off"></i> Logout</a>
        </header>

        <!-- Stats Grid -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="icon-box"><i class="fa-solid fa-school"></i></div>
                <div class="stat-info">
                    <h3>
                        <%= total %>
                    </h3>
                    <p>Total Schools</p>
                </div>
            </div>
            <div class="stat-card">
                <div class="icon-box" style="color: var(--success); background: rgba(34, 197, 94, 0.1);"><i
                        class="fa-solid fa-circle-check"></i></div>
                <div class="stat-info">
                    <h3>
                        <%= active %>
                    </h3>
                    <p>Active</p>
                </div>
            </div>
            <div class="stat-card">
                <div class="icon-box" style="color: #f59e0b; background: rgba(245, 158, 11, 0.1);"><i
                        class="fa-solid fa-ban"></i></div>
                <div class="stat-info">
                    <h3>
                        <%= inactive %>
                    </h3>
                    <p>Inactive</p>
                </div>
            </div>
            <div class="stat-card">
                <div class="icon-box" style="color: var(--danger); background: rgba(239, 68, 68, 0.1);"><i
                        class="fa-solid fa-clock-rotate-left"></i></div>
                <div class="stat-info">
                    <h3>
                        <%= expired %>
                    </h3>
                    <p>Expired</p>
                </div>
            </div>
        </div>

        <!-- REVENUE CARD -->
        <div class="stat-card revenue-card" style="margin-bottom: 30px;">
            <div class="revenue-main">
                <div class="icon-box" style="color: #fff; background: var(--primary-blue);">
                    <i class="fa-solid fa-indian-rupee-sign"></i>
                </div>
                <div class="stat-info">
                    <h3>₹<%= (totalRevenue || 0).toLocaleString('en-IN') %>
                    </h3>
                    <p style="color: rgba(255,255,255,0.7);">Total Revenue Earned</p>
                </div>
            </div>
            <div class="revenue-badge">
                <i class="fa-solid fa-chart-line"></i> This Month: ₹<%= (monthlyRevenue || 0).toLocaleString('en-IN') %>
            </div>
        </div>

        <!-- Quick Actions (Moved out of Revenue Card) -->
        <div class="actions">
            <a href="/super-admin/add-school" class="btn btn-primary"><i class="fa-solid fa-plus"></i> Add New
                School</a>
            <a href="/super-admin/schools" class="btn btn-secondary"><i class="fa-solid fa-list"></i> View All
                Schools</a>

            <a href="/super-admin/settings" class="btn btn-secondary"><i class="fa-solid fa-gear"></i> Settings</a>

        </div>

        <!-- Main Content Grid -->
        <div class="dashboard-main-grid">
            <!-- Recent Schools -->
            <div class="content-box">
                <h3><i class="fa-solid fa-clock-rotate-left" style="color: var(--accent-blue);"></i> Recently Added
                    Schools</h3>
                <div class="table-wrapper">
                    <table>
                        <thead>
                            <tr>
                                <th>School Name</th>
                                <th>Code</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% schools.slice(0, 6).forEach(school=> { %>
                                <tr>
                                    <td style="font-weight: 500; color: #fff;">
                                        <%= school.name %>
                                    </td>
                                    <td style="font-family: monospace; color: var(--accent-blue);">
                                        <%= school.code %>
                                    </td>
                                    <td>
                                        <span
                                            class="badge <%= school.subscriptionEnd > new Date() ? 'badge-active' : 'badge-expired' %>">
                                            <%= school.subscriptionEnd> new Date() ? 'Active' : 'Expired' %>
                                        </span>
                                    </td>
                                </tr>
                                <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Recent Payments -->
            <div class="content-box">
                <h3><i class="fa-solid fa-receipt" style="color: var(--success);"></i> Recent Payments</h3>
                <div class="table-wrapper">
                    <table>
                        <thead>
                            <tr>
                                <th>School</th>
                                <th>Amount</th>
                                <th>Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% transactions.forEach(t=> { %>
                                <tr>
                                    <td style="color: var(--text-main); font-size: 13px;">
                                        <%= t.schoolName %>
                                    </td>
                                    <td style="color: var(--success); font-weight: bold;">₹<%= t.amount %>
                                    </td>
                                    <td style="font-size: 12px; color: var(--text-muted);">
                                        <%= t.paymentDate.toLocaleDateString('en-GB') %>
                                    </td>
                                </tr>
                                <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    <script src="/backButton.js"></script>
</body>

</html>