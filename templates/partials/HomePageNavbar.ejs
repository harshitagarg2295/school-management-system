<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SchoolFlow Navbar</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
    <style>
        :root {
            --primary-color: #2563eb;
            --dark-color: #0f172a;
            --text-gray: #475569;
            --white: #ffffff;
            --shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        .navbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 5%;
            height: 80px;
            background: var(--white);
            box-shadow: var(--shadow);
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        @media (min-width: 1200px) {
            .navbar {
                padding: 0 8%;
            }
        }

        /* Logo Style */
        .logo a {
            font-size: 24px;
            font-weight: 800;
            color: var(--dark-color);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 10px;
            white-space: nowrap;
        }

        .logo span {
            color: var(--primary-color);
        }

        /* Nav Links */
        .nav {
            display: flex;
            list-style: none;
            align-items: center;
            gap: 24px;
        }

        /* Desktop Optimization (901px to 1100px) to prevent layout break */
        @media (min-width: 901px) and (max-width: 1100px) {
            .nav {
                gap: 14px; 
            }
            .nav a {
                font-size: 14px !important;
            }
            .login-btn {
                padding: 8px 18px !important;
            }
        }

        .nav a {
            text-decoration: none;
            color: var(--text-gray);
            font-weight: 500;
            font-size: 15px;
            transition: 0.3s;
            cursor: pointer;
            white-space: nowrap;
        }

        .nav a:hover {
            color: var(--primary-color);
        }

        /* Dropdown Styling */
        .dropdown {
            position: relative;
        }

        .dropdown-menu {
            position: absolute;
            top: 100%;
            left: 0;
            background: var(--white);
            min-width: 200px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
            border-radius: 12px;
            padding: 10px 0;
            display: none;
            border: 1px solid #f1f5f9;
            animation: slideUp 0.3s ease;
        }

        @keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @media (min-width: 901px) {
            .dropdown:hover .dropdown-menu {
                display: block;
            }
        }

        .dropdown-menu li {
            list-style: none;
        }

        .dropdown-menu a {
            padding: 7px 20px;
            display: block;
            font-size: 14px;
            color: var(--text-gray);
        }

        .dropdown-menu a:hover {
            background: #f8fbff;
            color: var(--primary-color);
        }

        /* Login Button Style */
        .login-btn {
            background: var(--primary-color);
            color: white !important;
            padding: 10px 25px;
            border-radius: 50px;
            font-weight: 600 !important;
            box-shadow: 0 4px 15px rgba(37, 99, 235, 0.2);
        }

        .login-btn:hover {
            background: var(--dark-color);
            transform: translateY(-2px);
        }

        #menuToggle {
            display: none;
            font-size: 24px;
            cursor: pointer;
            color: var(--dark-color);
        }

        /* 📱 MOBILE RESPONSIVE DESIGN (Hamburger Activates strictly at 900px) */
        @media (max-width: 900px) {
            #menuToggle {
                display: block;
            }

            .nav {
                position: absolute;
                top: 80px;
                left: -100%;
                width: 100%;
                height: calc(100vh - 80px);
                background: white;
                flex-direction: column;
                padding: 25px 20px; /* Padding kam kar di aur gap tight kiya */
                gap: 12px;          /* Elements ke beech ka gap 25px se ghatakar 12px kiya */
                transition: 0.4s ease-in-out;
                text-align: center;
                overflow-y: auto;
                box-shadow: 0 15px 30px rgba(0,0,0,0.1);
            }

            .nav.active {
                left: 0;
            }

            .nav li {
                width: 100%;
            }

            .nav a {
                display: block;
                padding: 6px 0; /* Links ka vertical space tight kar diya */
                font-size: 16px;
            }

            .login-btn {
                display: inline-block;
                width: auto;
                padding: 10px 40px;
                margin-top: 5px;
            }

            /* Mobile Dropdown Custom Settings */
            .dropdown-menu {
                position: static;
                box-shadow: none;
                border: none;
                display: none;
                background: #f8fbff;
                margin-top: 8px;
                border-radius: 8px;
            }

            /* Dropdown links ke beech ka gap bhi compress kar diya */
            .dropdown-menu a {
                padding: 6px 20px !important;
                font-size: 14px !important;
            }

            .dropdown.active .dropdown-menu {
                display: block;
            }

            .dropdown > a i {
                transition: 0.3s;
            }

            .dropdown.active > a i {
                transform: rotate(180deg);
            }
        }
    </style>
</head>

<body>

    <nav class="navbar">
        <div class="logo">
            <a href="/">
                <i class="fa-solid fa-rocket" style="color: #2563eb;"></i>
                School<span>Flow</span>
            </a>
        </div>

        <ul class="nav">
            <li><a href="/">Home</a></li>
            <li><a href="/features">Features</a></li>

            <li class="dropdown">
                <a>
                    Company <i class="fa-solid fa-chevron-down" style="font-size: 12px; margin-left: 5px;"></i>
                </a>
                <ul class="dropdown-menu">
                    <li><a href="/about-us">About Us</a></li>
                    <li><a href="/terms-conditions">Terms of Service</a></li>
                    <li><a href="/privacy-policy">Privacy Policy</a></li>
                </ul>
            </li>

            <li><a href="/contact-us">Contact & Support</a></li>
            <li><a href="/try-demo">Try Demo</a></li>
            <li>
                <a href="/login" class="login-btn">
                    <i class="fa-solid fa-user-lock"></i> Login
                </a>
            </li>
        </ul>

        <i class="fa-solid fa-bars" id="menuToggle"></i>
    </nav>

    <script>
        const menuIcon = document.getElementById("menuToggle");
        const navMenu = document.querySelector(".nav");
        const dropdowns = document.querySelectorAll(".dropdown");

        // Mobile Menu Toggle
        menuIcon.addEventListener("click", () => {
            navMenu.classList.toggle("active");

            if (navMenu.classList.contains("active")) {
                menuIcon.classList.replace("fa-bars", "fa-xmark");
            } else {
                menuIcon.classList.replace("fa-xmark", "fa-bars");
            }
        });

        // Mobile Dropdown Click Logic (Strictly under 900px)
        dropdowns.forEach(drop => {
            drop.addEventListener("click", (e) => {
                if (window.innerWidth <= 900) {
                    e.stopPropagation();
                    drop.classList.toggle("active");
                }
            });
        });

        // Safe Reset on Desktop Resize
        window.addEventListener('resize', () => {
            if (window.innerWidth > 900) {
                navMenu.classList.remove("active");
                menuIcon.classList.replace("fa-xmark", "fa-bars");
                dropdowns.forEach(drop => drop.classList.remove("active"));
            }
        });
    </script>
</body>

</html>