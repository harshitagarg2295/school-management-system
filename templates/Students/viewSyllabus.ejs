<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Syllabus</title>
    <style>
        body {
            font-family: "Segoe UI", Arial, sans-serif;
            background: #f4f6f9;
            margin: 0;
        }

        .student-dash {
            display: flex;
        }

        /* Main Card */
        .syllabus-card {
            flex: 1;
            margin: 30px;
            padding: 35px 45px;
            background: #fff;
            border-radius: 16px;
            box-shadow: 0 6px 20px rgba(0, 0, 0, 0.06);
            transition: 0.3s;
        }

        .syllabus-card:hover {
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.10);
        }

        .syllabus-card h2 {
            text-align: center;
            color: #2c3e50;
            margin-bottom: 30px;
            font-size: 26px;
            font-weight: 600;
            border-bottom: 3px solid #3498db;
            display: inline-block;
            padding-bottom: 5px;
        }

        /* Dropdown Section */
        .dropdowns {
            display: flex;
            justify-content: center;
            flex-wrap: wrap;
            gap: 20px;
            margin-bottom: 35px;
        }

        select {
            padding: 12px 16px;
            border: 1px solid #d3dae2;
            border-radius: 10px;
            font-size: 15px;
            min-width: 200px;
            background: #f8fbff;
            transition: 0.3s ease;
        }

        select:focus {
            border-color: #3498db;
            box-shadow: 0 0 6px rgba(52, 152, 219, 0.3);
            outline: none;
        }

        /* Grid Layout */
        .syllabus-grid {
            margin-top: 25px;
            width: 100%;
            display: grid;
            grid-template-columns: 250px 1fr;
            gap: 18px 25px;
            align-items: start;
        }

        .subject-cell {
            font-weight: 600;
            color: #34495e;
            background: #eef3f9;
            padding: 12px 18px;
            border-radius: 10px;
            text-align: center;
            border: 1px solid #dce3eb;
        }

        textarea {
            width: 100%;
            padding: 10px 14px;
            min-height: 45px;
            border-radius: 10px;
            border: 1px solid #d0d7de;
            resize: vertical;
            font-size: 14px;
            background: #fafafa;
            color: black;
            transition: 0.3s;
        }

        textarea:focus {
            border-color: #3498db;
            background: #fff;
            outline: none;
        }

        .selection-message {
            grid-column: 1 / -1;
            text-align: center;
            padding: 45px;
            font-size: 18px;
            color: #666;
            background: #f8fbff;
            border-radius: 12px;
            border: 1px dashed #b6d9ff;
            margin-top: 20px;
        }

        /* Responsive */
        @media (max-width: 992px) {
            .syllabus-card {
                margin: 20px;
                padding: 30px;
            }

            .syllabus-grid {
                grid-template-columns: 1fr;
            }

            .subject-cell {
                width: 100%;
            }
        }

        @media (max-width: 768px) {
            .syllabus-card {
                margin: 15px;
                padding: 25px 20px;
            }

            select {
                width: 100%;
            }

            h2 {
                font-size: 22px;
            }
        }

        @media (max-width: 480px) {
            .syllabus-card {
                margin: 10px;
                padding: 20px;
            }

            .subject-cell {
                padding: 10px 12px;
                font-size: 14px;
            }

            textarea {
                font-size: 13px;
            }
        }
    </style>

</head>

<body>
    <div class="student-dash">
        <%- include("partials/StudentPageSidebar") %>

            <div class="syllabus-card">
                <h2>
                    <%= type==="monthly" ? "View Monthly Test Syllabus" : "View Exams Syllabus" %>
                </h2>

                <!-- Period Dropdown -->
                <div class="dropdowns">
                    <% if (type==="monthly" ) { %>
                        <select id="periodSelect">
                            <option value="">Select Month</option>
                            <% ["January","February","March","April","May","June","July","August", "September"
                                ,"October","November","December"].forEach(m=> { %>
                                <option value="<%= m %>" <%=m===selectedPeriod ? "selected" :"" %>><%= m %>
                                </option>
                                <% }) %>
                        </select>
                        <% } else { %>
                            <select id="periodSelect">
                                <option value="">Select Exam</option>
                                <% ["Quarterly","Half-Yearly","Annual","Pre-Board"].forEach(e=> { %>
                                    <option value="<%= e %>" <%=e===selectedPeriod ? "selected" :"" %>><%= e %>
                                    </option>
                                    <% }) %>
                            </select>
                            <% } %>
                </div>

                <!-- Syllabus Grid -->

                <div class="syllabus-grid" id="syllabusGrid">
                    <% if (!selectedPeriod) { %>
                        <!-- Case 1: Nothing selected -->
                        <div class="selection-message">
                            Please select a Month/Exam to view syllabus.
                        </div>

                        <% } else if (!savedSyllabus) { %>
                            <!-- Case 2: Period selected but no syllabus found -->
                            <div class="selection-message">
                                No data found for <%= selectedPeriod %>.
                            </div>

                            <% } else { %>
                                <!-- Case 3: Show saved syllabus -->
                                <% subjects.forEach(sub=> {
                                    const savedSub = savedSyllabus.subjects.find(s => s.name === sub);
                                    const content = savedSub ? savedSub.content : '';
                                    %>
                                    <div class="subject-cell">
                                        <%= sub %>
                                    </div>
                                    <textarea readonly><%= content %></textarea>
                                    <% }) %>
                                        <% } %>
                </div>

            </div>
    </div>

    <script>
        const periodSelect = document.getElementById('periodSelect');
        const type = "<%= type %>";
        periodSelect.addEventListener('change', () => {
            const period = periodSelect.value;
            if (period) {
                // Redirect with selected period (student class is automatic)
                const base = type === "monthly"
                    ? "/students/view-monthly-test/syllabus"
                    : "/students/view-exams/syllabus";
                window.location.href = `${base}?period=${encodeURIComponent(period)}`;
            }
        });
    </script>
</body>

</html>