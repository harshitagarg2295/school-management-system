<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <title>
    <%= student.name %> - Attendance
  </title>

  <style>
    * {
      box-sizing: border-box;
    }

    .student-dash {
      display: flex;
    }

    .attendance_card {
      width: 80%;
      margin: 20px 10px 20px 0px;
      border-radius: 8px;
      background-color: white;
      padding: 30px 25px;
    }

    /* --- DATE SELECTORS --- */
    .date_month_year {
      display: flex;
      justify-content: flex-end;
      margin-top: 40px;
    }

    .btn {
      text-align: center;
      font-size: 16px;
      border-radius: 8px;
      padding: 2px 7px;
    }

    .date_month_year form select {
      padding: 8px 14px;
      font-size: 16px;
      border: 1px solid #cfd6dd;
      border-radius: 8px;
      background: #f8fbff;
      cursor: pointer;
      transition: 0.25s ease;
    }

    .save_month_year {
      padding: 8px 18px !important;
      background: #4fa3f7;
      color: white;
      border: none;
      border-radius: 8px;
      font-size: 16px;
      cursor: pointer;
      transition: 0.25s ease;
    }

    .save_month_year:hover {
      background: #2f8ae2;
      transform: translateY(-1px);
    }

    h2 {
      text-align: center;
      margin-bottom: 20px;
    }

    /* --- ATTENDANCE TABLE STYLES --- */

    .attendance_table {
      overflow-x: auto;
      scrollbar-width: thin;
      scrollbar-color: #b4b4b4 #f1f1f1;
      margin-top: 30px;
      padding-bottom: 10px;
      width: 100%;
    }

    .attend_list_header,
    .attend_list {
      width: fit-content;
      min-width: 100%;
    }

    /* List Structure */
    .list ul {
      list-style: none;
      display: flex;
      padding: 0;
      margin: 0;
    }

    /* Header Row Specifics */
    .attend_list_header {
      background-color: #b1e6f4;
      border-radius: 7px 7px 0 0;
      border: 1px solid rgb(186, 185, 185);
      border-bottom: none;
      padding: 5px 0px;
    }

    /* Data Row Specifics */
    .attend_list {
      border: 1px solid rgb(186, 185, 185);
      border-top: none;
      border-radius: 0 0 7px 7px;
      padding: 5px 0;
    }


    /* 1. Student Name Column (Reusing Teacher Styling Logic) */
    .students_name {
      padding: 10px;
      font-weight: 600;
      color: #2c3e50;
      width: 200px;
      min-width: 200px;
      flex-shrink: 0;
      font-size: 18px;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      word-break: break-word;
      border-right: 1px solid #ddd;
    }

    /* 2. Sticky Column Logic */
    .sticky-name {
      position: sticky;
      left: 0;
      z-index: 10;
    }

    .attend_list_header .sticky-name {
      background-color: #b1e6f4;
      z-index: 15;
      border-radius: 7px 0 0 0;
    }

    .attend_list .sticky-name {
      background-color: white;
      z-index: 10;
    }

    /* 3. Date & Status Cells Logic */
    .list ul li:not(.students_name) {
      width: 50px;
      min-width: 50px;
      flex-shrink: 0;
      height: 50px;
      display: flex;
      justify-content: center;
      align-items: center;
      font-size: 16px;
      padding: 0px 30px;
    }

    .attend_list_header ul li:not(.students_name) {
      height: 50px;
    }

    /* --- CELLS STYLING --- */
    .holiday-cell {
      margin-top: 9px;
      background-color: #b1e6f4;
      border-radius: 5px;
      width: 35px !important;
      height: 30px !important;
      display: flex;
      justify-content: center;
      align-items: center;
    }

    .today-cell {
      background-color: rgb(89, 165, 240);
      width: 50px;
      height: 100%;
      display: flex;
      justify-content: center;
      align-items: center;
      font-weight: bold;
      color: white;
    }

    img.status-icon {
      width: 30px;
      height: 30px;
      object-fit: contain;
    }

    /* --- POPUP & SUMMARY --- */
    .holiday-popup {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(0, 0, 0, 0.5);
      justify-content: center;
      align-items: center;
      z-index: 9999;
    }

    .holiday-card {
      background: #fff;
      padding: 20px 30px;
      border-radius: 12px;
      text-align: center;
      box-shadow: 0 6px 18px rgba(0, 0, 0, 0.2);
      max-width: 350px;
      width: 90%;
    }

    .holiday-card h3 {
      margin-bottom: 10px;
      color: #429af2;
    }

    .holiday-card p {
      margin-bottom: 15px;
      font-size: 18px;
      color: #333;
    }

    .holiday-card button {
      background: #429af2;
      border: none;
      color: white;
      padding: 8px 15px;
      border-radius: 6px;
      cursor: pointer;
    }

    .holiday-card button:hover {
      background: #2f7bdc;
    }

    .attendance-summary {
      margin-top: 35px;
      padding: 20px;
      border-radius: 10px;
      background: #f8f9fa;
      box-shadow: 0 3px 6px rgba(0, 0, 0, 0.1);
    }

    .attendance-summary h3 {
      text-align: center;
      margin-bottom: 25px;
      color: #333;
    }

    .summary-row {
      display: flex;
      justify-content: center;
      gap: 25px;
      margin-bottom: 25px;
      flex-wrap: wrap;
    }

    .summary-card {
      padding: 15px 25px;
      border-radius: 8px;
      font-size: 18px;
      text-align: center;
      min-width: 120px;
      box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
      background: white;
    }

    .summary-card span {
      display: block;
      font-size: 16px;
      margin-bottom: 8px;
    }

    .summary-card strong {
      font-size: 22px;
      color: #222;
    }

    .summary-card.present {
      border-left: 6px solid #28a745;
    }

    .summary-card.absent {
      border-left: 6px solid #dc3545;
    }

    /* --- SCROLLBAR --- */
    .attendance_table::-webkit-scrollbar {
      height: 9px;
    }

    .attendance_table::-webkit-scrollbar-track {
      background: #f1f1f1;
      border-radius: 10px;
    }

    .attendance_table::-webkit-scrollbar-thumb {
      background: #b4b4b4;
      border-radius: 10px;
      border: 2px solid #f1f1f1;
      transition: background 0.3s ease;
    }


    /* ---------------------- RESPONSIVE ---------------------- */

    @media (max-width: 992px) {
      .attendance_card {
        width: 100%;
        margin: 15px;
        padding: 25px 20px;
      }

      .summary-row {
        gap: 15px;
      }

      .students_name {
        width: 160px;
        min-width: 160px;
        font-size: 15px;
      }
    }

    @media (max-width: 768px) {
      .attendance_card {
        width: 100%;
        margin: 10px;
        padding: 20px 15px;
      }

      .date_month_year {
        justify-content: center;
        margin-top: 20px;
      }

      .date_month_year form {
        flex-direction: column;
        gap: 10px;
        align-items: center;
        width: 50%;
      }

      .date_month_year form select,
      .date_month_year form button {
        width: 100% !important;
        text-align: center;
      }

      .summary-card {
        min-width: 100px;
        padding: 12px 20px;
      }

      .save_month_year {
        width: 100% !important;
      }

      .students_name {
        width: 130px;
        min-width: 130px;
        font-size: 14px;
        padding: 5px;
      }

      .list ul li:not(.students_name) {
        width: 40px;
        min-width: 40px;
        font-size: 14px;
      }

      img.status-icon {
        width: 24px;
        height: 24px;
      }

      .holiday-cell {
        width: 30px !important;
        height: 25px !important;
      }
    }

    @media (max-width: 480px) {
      .students_name {
        width: 110px;
        min-width: 110px;
        font-size: 13px;
      }

      .list ul li:not(.students_name) {
        width: 35px;
        min-width: 35px;
      }

      .summary-row {
        gap: 10px;
      }

      .summary-card {
        min-width: 90px;
        padding: 10px 15px;
      }
    }
  </style>
</head>

<body>

  <div class="student-dash">

    <!-- Sidebar (menu section) -->
    <%- include("partials/StudentPageSidebar") %>

      <div class="attendance_card">
        <h2>Attendance - <%= student.name %> (<%= student.class %>)</h2>

        <div class="date_month_year">
          <form method="GET" action="/students/view-attendance" style="display: flex; gap: 15px;">
            <select name="month" class="month-btn btn">
              <% for(let m=1; m <=12; m++) { %>
                <option value="<%= m %>" <%=parseInt(month)===m ? "selected" : "" %>>
                  <%= moment().month(m - 1).format("MMMM") %>
                </option>
                <% } %>
            </select>

            <select name="year" class="year-btn btn">
              <% for(let y=2022; y <=2030; y++) { %>
                <option value="<%= y %>" <%=parseInt(year)===y ? "selected" : "" %>>
                  <%= y %>
                </option>
                <% } %>
            </select>
            <button class="save_month_year btn" type="submit">Go</button>
          </form>
        </div>

        <!-- ATTENDANCE TABLE START -->
        <div class="attendance_table">

          <div class="attend_list_header list">
            <ul>
              <li class="students_name sticky-name">Name</li>

              <% for(let i=1; i <=daysInMonth; i++) { %>
                <li id="<%= i === today ? 'today-column' : '' %>" class="<%= i === today ? 'today-cell' : '' %>">
                  <%= i < 10 ? '0' + i : i %>
                </li>
                <% } %>
            </ul>
          </div>

          <!-- Data Row -->
          <div class="attend_list list">
            <ul>
              <li class="students_name sticky-name">
                <%= student.name %>
              </li>

              <% for (let i=1; i <=daysInMonth; i++) { %>
                <% let status=attendanceMap['day_' + i]; %>

                  <li class="<%= (sundays.includes(i) || holidays.includes(i)) ? 'holiday-cell' : '' %>"
                    data-reason="<%= holidayReasons[i] || (sundays.includes(i) ? 'Sunday' : '') %>">

                    <% if (sundays.includes(i) || holidays.includes(i)) { %>
                      -
                      <% } else { %>
                        <% if (status==="P" ) { %>
                          <img src="/images/present.jpg" alt="Present" class="status-icon" />
                          <% } else if (status==="A" ) { %>
                            <img src="/images/absent.jpg" alt="Absent" class="status-icon" />
                            <% } else { %>
                              -
                              <% } %>
                                <% } %>
                  </li>
                  <% } %>
            </ul>
          </div>

          <!-- Pop up for holiday reason -->
          <div id="holidayPopup" class="holiday-popup">
            <div class="holiday-card">
              <h3>Holiday</h3>
              <p id="holidayReason"></p>
              <button id="closePopup">Close</button>
            </div>
          </div>

        </div>
        <!-- ATTENDANCE TABLE END -->

        <div class="attendance-summary">
          <h3>Attendance Summary</h3>
          <div class="summary-row">
            <div class="summary-card present">
              <span>✅ Present</span>
              <strong>
                <%= presentCount %>
              </strong>
            </div>
            <div class="summary-card absent">
              <span>❌ Absent</span>
              <strong>
                <%= absentCount %>
              </strong>
            </div>
          </div>
        </div>

      </div>
  </div>
  <script src="/backButton.js"></script>
</body>

<script>
  window.addEventListener("DOMContentLoaded", () => {
    const todayElement = document.getElementById("today-column");
    if (todayElement) {
      todayElement.scrollIntoView({
        behavior: "smooth",
        inline: "center",
        block: "nearest"
      });
    }
  });

  document.querySelectorAll(".holiday-cell").forEach(cell => {
    cell.addEventListener("click", () => {
      const reason = cell.getAttribute("data-reason");
      if (reason) {
        document.getElementById("holidayReason").innerText = reason;
        document.getElementById("holidayPopup").style.display = "flex";
      }
    });
  });

  document.getElementById("closePopup").addEventListener("click", () => {
    document.getElementById("holidayPopup").style.display = "none";
  });
</script>

</html>