<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <title>
    <%= success ? "Payment Successful" : "Payment Failed" %>
  </title>

  <style>
    body {
      font-family: "Poppins", sans-serif;
      background: linear-gradient(135deg, #dce6ff, #f7faff);
      margin: 0;
      padding: 20px;
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
      box-sizing: border-box;
    }

    /* MAIN CARD (success / failed) */
    .container {
      background: rgba(255, 255, 255, 0.85);
      backdrop-filter: blur(10px);
      padding: 35px 25px;
      border-radius: 16px;
      box-shadow: 0 12px 30px rgba(0, 0, 0, 0.12);
      max-width: 420px;
      width: 100%;
      text-align: center;
      animation: fadeIn 0.4s ease;
    }

    @keyframes fadeIn {
      from {
        opacity: 0;
        transform: translateY(10px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .icon {
      font-size: 72px;
      margin-bottom: 10px;
    }

    .success {
      color: #2ecc71;
      text-shadow: 0px 0px 8px rgba(46, 204, 112, 0.4);
    }

    .failure {
      color: #e74c3c;
      text-shadow: 0px 0px 8px rgba(231, 76, 60, 0.4);
    }

    h1 {
      font-size: 26px;
      margin: 10px 0;
      color: #1f2d45;
    }

    p {
      color: #555;
      margin-bottom: 8px;
      font-size: 15px;
      line-height: 1.4;
    }

    /* BUTTONS */
    .btn {
      background: linear-gradient(135deg, #4a90e2, #3578d3);
      color: white;
      border: none;
      padding: 10px 22px;
      border-radius: 8px;
      cursor: pointer;
      font-size: 15px;
      font-weight: 600;
      margin: 6px;
      transition: 0.3s ease;
      box-shadow: 0 5px 14px rgba(53, 120, 211, 0.4);
    }

    .btn:hover {
      transform: translateY(-2px);
      background: #2f6dc0;
    }

    /* RECEIPT */
    #receipt {
      display: none;
      margin-top: 25px;
      background: #ffffff;
      border-radius: 14px;
      padding: 25px 20px;
      box-shadow: 0 6px 20px rgba(0, 0, 0, 0.1);
      animation: fadeIn 0.3s ease;
      max-width: 750px;
      width: 100%;
    }

    #receipt h2 {
      text-align: center;
      font-size: 24px;
      color: #1f2d45;
      margin-bottom: 5px;
    }

    .receipt-section {
      display: flex;
      justify-content: space-between;
      flex-wrap: wrap;
      margin: 10px 0;
      padding-bottom: 8px;
      border-bottom: 1px dashed #dcdcdc;
    }

    strong,
    span {
      font-size: 15px;
      word-break: break-word;
    }

    /* TABLE */
    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 18px;
    }

    th,
    td {
      padding: 10px;
      font-size: 15px;
      border: 1px solid #ccc;
      text-align: left;
      background-color: #ffffff;
    }

    th {
      background: #eef3ff;
      font-weight: 600;
      color: #2c3e50;
    }

    .total {
      text-align: right;
      font-weight: bold;
    }

    /* PRINT RECEIPT */
    @media print {

      /* Hide everything except receipt */
      body * {
        visibility: hidden !important;
      }

      /* Show receipt fully */
      #receipt,
      #receipt * {
        visibility: visible !important;
      }

      #receipt {
        position: absolute;
        top: 0;
        left: 0;
        width: 100% !important;
        max-width: 100% !important;
        padding: 20px !important;
        box-sizing: border-box !important;
      }

      /* Table full width (very important) */
      table {
        width: 100% !important;
        table-layout: auto !important;
      }

      th,
      td {
        white-space: normal !important;
        /* Wrap long text */
        overflow: visible !important;
        text-overflow: unset !important;
        word-break: break-word !important;
        font-size: 15px !important;
        padding: 8px !important;
      }

      /* Receipt sections wrap properly */
      .receipt-section {
        flex-direction: row !important;
        display: flex !important;
        width: 100% !important;
        gap: 5px !important;
      }

      strong,
      span {
        font-size: 15px !important;
        width: auto !important;
        max-width: 100% !important;
        white-space: normal !important;
      }
    }

    /* RESPONSIVE */
    @media (max-width: 480px) {

      .container {
        padding: 25px 18px;
      }

      h1 {
        font-size: 22px;
      }

      .icon {
        font-size: 60px;
      }

      #receipt {
        padding: 20px 14px;
      }

      table th,
      table td {
        font-size: 13px;
        padding: 7px;
      }

      .btn {
        width: 100%;
        margin-top: 10px;
      }
    }
  </style>
</head>

<body>

  <div class="container">
    <% if (success) { %>

      <div class="icon success">✔</div>
      <h1>Payment Successful!</h1>
      <p>Amount: ₹<%= amount %>
      </p>
      <p>Order ID: <%= orderId %>
      </p>

      <button class="btn" onclick="showReceipt()">Download Receipt</button>
      <button class="btn" onclick="window.location.href='/studentDashboard'">Go to Dashboard</button>

      <% } else { %>

        <div class="icon failure">✖</div>
        <h1>Payment Failed!</h1>
        <p>Something went wrong. Please try again.</p>

        <button class="btn" onclick="window.location.href='/students/checkout-fees'">Try Again</button>

        <% } %>
  </div>

  <% if (success) { %>
    <div id="receipt">
     <h2><%= schoolName %></h2>
      <hr>

      <div class="receipt-section"><strong>Student Name:</strong> <span>
          <%= student.name %>
        </span></div>
      <div class="receipt-section"><strong>Student ID:</strong> <span>
          <%= student.id %>
        </span></div>
      <div class="receipt-section"><strong>Class:</strong> <span>
          <%= student.class %>
        </span></div>
      <div class="receipt-section"><strong>Date:</strong> <span>
          <%= new Date().toLocaleDateString() %>
        </span></div>
      <div class="receipt-section"><strong>Transaction ID:</strong><span>
          <%= orderId %>
        </span></div>

      <table>
        <thead>
          <tr>
            <th>Installment</th>
            <th>Fee Type</th>
            <th>Amount (₹)</th>
          </tr>
        </thead>
        <tbody>
          <% installments.forEach(i=> { %>
            <tr>
              <td>
                <%= i.installment %>
              </td>
              <td>
                <%= i.feeType %>
              </td>
              <td>
                <%= i.amount %>
              </td>
            </tr>
            <% }) %>
        </tbody>
        <tfoot>
          <tr>
            <td colspan="2" class="total">Total Amount</td>
            <td>₹<%= amount %>
            </td>
          </tr>
        </tfoot>
      </table>

      <p style="margin-top:20px; text-align:center;">Thank you for your payment!</p>
    </div>
    <% } %>

      <script>
        function showReceipt() {
          const receipt = document.getElementById("receipt");
          receipt.style.display = "block";
          window.print();
        }
      </script>

</body>

</html>