<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>
    <%= success ? "Payment Status" : "Payment Failed" %>
  </title>

  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap"
    rel="stylesheet">

  <style>
    :root {
      --primary: #1e3a8a;
      --success: #10b981;
      --failure: #ef4444;
      --text-main: #0f172a;
      --text-muted: #64748b;
      --bg-gradient: linear-gradient(135deg, #f1f5f9 0%, #e2e8f0 100%);
    }

    body {
      font-family: "Plus Jakarta Sans", sans-serif;
      background: var(--bg-gradient);
      margin: 0;
      padding: 40px 20px;
      display: flex;
      justify-content: flex-start;
      align-items: center;
      min-height: 100vh;
      box-sizing: border-box;
      flex-direction: column;
    }

    .container {
      background: #ffffff;
      padding: 40px;
      border-radius: 24px;
      box-shadow: 0 20px 40px rgba(15, 23, 42, 0.08);
      max-width: 480px;
      width: 100%;
      text-align: center;
      animation: slideUp 0.4s ease;
    }

    @keyframes slideUp {
      from {
        opacity: 0;
        transform: translateY(20px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .status-badge {
      width: 80px;
      height: 80px;
      border-radius: 50%;
      display: flex;
      justify-content: center;
      align-items: center;
      margin: 0 auto 24px;
      font-size: 36px;
    }

    .status-badge.success {
      background: #ecfdf5;
      color: var(--success);
      box-shadow: 0 0 0 8px #f0fdf4;
    }

    .status-badge.failure {
      background: #fef2f2;
      color: var(--failure);
      box-shadow: 0 0 0 8px #fef2f2;
    }

    h1 {
      font-size: 28px;
      font-weight: 700;
      margin-bottom: 10px;
      color: var(--text-main);
    }

    .payment-subtitle {
      color: var(--text-muted);
      font-size: 15px;
      margin-bottom: 30px;
    }

    .btn-group {
      display: flex;
      gap: 12px;
      justify-content: center;
      flex-wrap: wrap;
    }

    .btn {
      padding: 12px 24px;
      border-radius: 12px;
      cursor: pointer;
      font-size: 15px;
      font-weight: 600;
      border: none;
      transition: 0.2s ease;
      min-width: 160px;
    }

    .btn-primary {
      background: var(--primary);
      color: white;
    }

    .btn-primary:hover {
      background: #1d4ed8;
    }

    .btn-secondary {
      background: #f1f5f9;
      color: var(--text-main);
    }

    .btn-secondary:hover {
      background: #e2e8f0;
    }

    #receipt {
      display: none;
      margin-top: 30px;
      background: white;
      border-radius: 20px;
      padding: 30px;
      border: 1px solid #e2e8f0;
      width: 100%;
      max-width: 850px;
      box-sizing: border-box;
    }

    .receipt-header {
      text-align: center;
      margin-bottom: 24px;
    }

    .receipt-header h2 {
      margin: 0;
      font-size: 24px;
      color: var(--primary);
    }

    .receipt-header p {
      margin-top: 5px;
      color: var(--text-muted);
      font-size: 14px;
    }

    .meta-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 18px;
      border-top: 1px dashed #dbe3f0;
      border-bottom: 1px dashed #dbe3f0;
      padding: 20px 0;
      margin-bottom: 24px;
    }

    .meta-item label {
      display: block;
      font-size: 12px;
      color: var(--text-muted);
      margin-bottom: 4px;
      text-transform: uppercase;
    }

    .meta-item span {
      font-size: 14px;
      color: var(--text-main);
      font-weight: 600;
      word-break: break-word;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 18px;
    }

    th {
      background: #f8fafc;
      color: var(--text-muted);
      font-size: 13px;
      padding: 12px;
      text-align: left;
    }

    td {
      padding: 14px 12px;
      border-bottom: 1px solid #f1f5f9;
      font-size: 14px;
    }

    .text-right {
      text-align: right;
    }


    .row-breakup td {
      border: none;
      padding: 8px 12px;
      color: var(--text-muted);
    }

    .row-total td {
      border-top: 1px solid #dbe3f0;
      font-weight: 700;
      color: var(--primary);
      font-size: 16px;
      padding-top: 14px;
    }

    .receipt-footer-text {
      margin-top: 24px;
      text-align: center;
      color: var(--text-muted);
      font-size: 13px;
    }

    @media print {
      @page {
        margin: 10mm;
      }

      html,
      body {
        margin: 0 !important;
        padding: 0 !important;
        min-height: auto !important;
      }

      body {
        background: white;
      }

      .container {
        display: none !important;
      }

      #receipt {
        display: block !important;
        border: none;
        box-shadow: none;
        max-width: 100%;
        width: 100%;
        padding: 0;
      }
    }

    @media (max-width: 480px) {

      .container {
        padding: 24px;
      }

      .btn-group {
        flex-direction: column;
      }

      .btn {
        width: 100%;
      }
    }
  </style>
</head>

<body>

  <div class="container">

    <% if (success) { %>

      <div class="status-badge success">✔</div>

      <h1>Payment Successful!</h1>

      <p class="payment-subtitle">
        Your transaction has been processed securely.
      </p>

      <div class="btn-group">

        <button class="btn btn-primary" onclick="showReceipt()">
          Download Receipt
        </button>

        <button class="btn btn-secondary" onclick="window.location.href='/studentDashboard'">
          Go to Dashboard
        </button>

      </div>

      <% } else { %>

        <div class="status-badge failure">✖</div>

        <h1>Payment Failed!</h1>

        <p class="payment-subtitle">
          <%= typeof message !=='undefined' ? message : "Something went wrong." %>
        </p>

        <% } %>

  </div>

  <% if (typeof success !=='undefined' && success) { %>

    <% let parsedInstallments=[]; try { parsedInstallments=typeof installments==="string" ? JSON.parse(installments) :
      installments || []; } catch (err) { parsedInstallments=[]; } let schoolFees=parsedInstallments.reduce( (sum, i)=>
      {

      return sum +
      parseFloat(i.amount || 0);

      },

      0
      );

      let portalCharges = parseFloat((schoolFees * 0.002).toFixed(2));
      let grandTotal = schoolFees + portalCharges;

      %>

      <div id="receipt">

        <div class="receipt-header">

          <h2>
            <%= schoolName || "School Fee Receipt" %>
          </h2>

          <p>
            Official Digital Payment Invoice
          </p>

        </div>

        <div class="meta-grid">

          <div class="meta-item">
            <label>Student Name</label>
            <span>
              <%= student?.name || "-" %>
            </span>
          </div>

          <div class="meta-item">
            <label>Student ID</label>
            <span>
              <%= student?.id || "-" %>
            </span>
          </div>

          <div class="meta-item">
            <label>Class</label>
            <span>
              <%= student?.class || "-" %>
            </span>
          </div>

          <div class="meta-item">
            <label>Date</label>
            <span>
              <%= new Date().toLocaleDateString('en-GB') %>
            </span>
          </div>

          <div class="meta-item">
            <label>Order ID</label>
            <span>
              <%= orderId || "-" %>
            </span>
          </div>

          <div class="meta-item">
            <label>Transaction ID</label>
            <span>
              <%= paymentId || "-" %>
            </span>
          </div>

        </div>

        <table>

          <thead>

            <tr>
              <th>Installment</th>
              <th>Fee Type</th>
              <th class="text-right">Amount</th>
            </tr>

          </thead>

          <tbody>

            <% parsedInstallments.forEach(i=> { %>

              <tr>

                <td>
                  <%= i.installment %>
                </td>

                <td>
                  <%= i.feeType %>
                </td>

                <td class="text-right">
                  ₹<%= parseFloat(i.amount).toLocaleString('en-IN') %>
                </td>

              </tr>

              <% }) %>

          </tbody>

          <tfoot>

            <tr class="row-breakup">

              <td colspan="2" class="text-right">
                School Fees
              </td>

              <td class="text-right">
                ₹<%= schoolFees.toLocaleString('en-IN', { minimumFractionDigits: 2 }) %>
              </td>

            </tr>

            <tr class="row-breakup">

              <td colspan="2" class="text-right">
                Portal & Payment Charges (0.2%)
              </td>

              <td class="text-right">
                ₹<%= portalCharges.toLocaleString('en-IN', { minimumFractionDigits: 2 }) %>
              </td>

            </tr>

            <tr class="row-total">

              <td colspan="2" class="text-right">
                Grand Total Paid
              </td>

              <td class="text-right">
                ₹<%= grandTotal.toLocaleString('en-IN', { minimumFractionDigits: 2 }) %>
              </td>

            </tr>

          </tfoot>

        </table>

        <p class="receipt-footer-text">
          This is a system-generated electronic receipt.
        </p>

      </div>

      <% } %>

        <script>

          function showReceipt() {

            const receipt =
              document.getElementById("receipt");

            if (!receipt) return;

            receipt.style.display = "block";

            window.print();
          }

        </script>
<script src="/backButton.js"></script>
</body>

</html>