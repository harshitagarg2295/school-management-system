<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Admit Card — <%= student.studentName %>
    </title>
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Playfair+Display:wght@700&display=swap"
        rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: #f4f6f9;
            color: #1a1a2e;
        }

        .print-toolbar {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 16px;
            padding: 14px 20px;
            background: #1a1a6e;
            color: white;
            position: sticky;
            top: 0;
            z-index: 999;
            font-size: 14px;
        }

        .print-toolbar span {
            opacity: 0.8;
        }

        .btn-print {
            background: #f6a623;
            color: #1a1a2e;
            border: none;
            padding: 9px 22px;
            border-radius: 8px;
            font-weight: 700;
            font-size: 14px;
            cursor: pointer;
            font-family: 'Inter', sans-serif;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .btn-back {
            background: rgba(255, 255, 255, 0.15);
            color: white;
            border: none;
            padding: 9px 18px;
            border-radius: 8px;
            font-size: 13px;
            cursor: pointer;
            font-family: 'Inter', sans-serif;
        }

        .btn-back:hover {
            background: rgba(255, 255, 255, 0.25);
        }

        .page {
            width: 210mm;
            min-height: 297mm;
            margin: 20px auto;
            padding: 12mm 15mm;
            position: relative;
            background: white;
            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.12);
        }

        .page::before {
            content: '';
            position: absolute;
            inset: 5mm;
            border: 4px double #1a1a6e;
            pointer-events: none;
        }

        .page::after {
            content: '';
            position: absolute;
            inset: 8mm;
            border: 1px solid #b0b0d8;
            pointer-events: none;
        }

        .watermark {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%) rotate(-45deg);
            font-size: 80px;
            font-weight: 900;
            color: rgba(74, 74, 138, 0.05);
            white-space: nowrap;
            pointer-events: none;
            letter-spacing: 10px;
        }

        .school-header {
            text-align: center;
            padding-bottom: 12px;
            border-bottom: 3px solid #1a1a6e;
            margin-bottom: 12px;
        }

        .school-name {
            font-family: 'Playfair Display', serif;
            font-size: 22px;
            font-weight: 700;
            color: #1a1a6e;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .school-address {
            font-size: 11px;
            color: #555;
            margin-top: 3px;
        }

        .doc-title {
            background: #1a1a6e;
            color: white;
            text-align: center;
            padding: 8px 20px;
            font-size: 16px;
            font-weight: 700;
            letter-spacing: 3px;
            text-transform: uppercase;
            margin: 10px 0 18px;
            border-radius: 4px;
        }

        .admit-body {
            display: flex;
            gap: 20px;
            margin-bottom: 20px;
        }

        .photo-box {
            width: 100px;
            height: 120px;
            border: 2px solid #1a1a6e;
            border-radius: 6px;
            flex-shrink: 0;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #f0f0fa;
        }

        .photo-box img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .photo-placeholder {
            font-size: 11px;
            color: #888;
            text-align: center;
            padding: 10px;
        }

        .student-info {
            flex: 1;
        }

        .info-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 12px;
        }

        .info-table td {
            padding: 7px 10px;
            border: 1px solid #d0d0f0;
        }

        .info-table td:first-child {
            background: #f0f0fa;
            font-weight: 600;
            color: #1a1a6e;
            width: 38%;
        }

        .notice-box {
            background: #fff8dc;
            border: 1.5px solid #f6a623;
            border-radius: 6px;
            padding: 10px 14px;
            font-size: 11px;
            color: #744210;
            margin: 14px 0;
        }

        .notice-box strong {
            display: block;
            margin-bottom: 4px;
            font-size: 12px;
        }

        .schedule-title {
            background: #1a1a6e;
            color: white;
            padding: 8px 14px;
            font-size: 13px;
            font-weight: 700;
            border-radius: 4px 4px 0 0;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .schedule-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 12px;
            margin-bottom: 20px;
        }

        .schedule-table th {
            background: #e8e8f8;
            color: #1a1a6e;
            padding: 8px 14px;
            text-align: left;
            font-weight: 700;
            border: 1px solid #c0c0e0;
        }

        .schedule-table td {
            padding: 8px 14px;
            border: 1px solid #d0d0f0;
            color: #2d2d2d;
        }

        .schedule-table tr:nth-child(even) td {
            background: #f7f7ff;
        }

        .exam-strip {
            display: flex;
            justify-content: space-around;
            background: #f0f0fa;
            border: 1px solid #d0d0f0;
            border-radius: 6px;
            padding: 10px 14px;
            margin-bottom: 14px;
            font-size: 12px;
        }

        .exam-strip .es-item {
            text-align: center;
        }

        .exam-strip .es-label {
            font-size: 10px;
            text-transform: uppercase;
            color: #888;
            font-weight: 600;
        }

        .exam-strip .es-value {
            font-weight: 700;
            color: #1a1a6e;
            margin-top: 3px;
            font-size: 13px;
        }

        .signatures {
            display: flex;
            justify-content: space-between;
            margin-top: 30px;
            font-size: 11px;
        }

        .sig-box {
            text-align: center;
        }

        .sig-line {
            border-top: 1.5px solid #333;
            width: 120px;
            margin-bottom: 5px;
        }

        .sig-label {
            font-weight: 600;
            color: #333;
            font-size: 11px;
        }

        .sig-sub {
            color: #777;
            font-size: 10px;
            margin-top: 2px;
        }

        .doc-footer {
            text-align: center;
            font-size: 9.5px;
            color: #aaa;
            border-top: 1px solid #eee;
            padding-top: 6px;
            margin-top: 14px;
        }

        @media print {
            body {
                background: white !important;
            }

            .print-toolbar {
                display: none !important;
            }

            .page {
                margin: 0 !important;
                box-shadow: none !important;
                width: 100% !important;
                -webkit-print-color-adjust: exact;
                print-color-adjust: exact;
            }

        }
    </style>
</head>

<body>

    <div class="print-toolbar">
        <button class="btn-back" onclick="window.close()">← Back</button>
        <span>🎫 Admit Card — <%= student.studentName %></span>
        <button class="btn-print" onclick="window.print()">🖨️ Print / Save as PDF</button>
    </div>

    <div class="page">
        <div class="watermark">ADMIT CARD</div>

        <div class="school-header">
            <div class="school-name">
                <%= schoolName %>
            </div>
            <% if (schoolAddress) { %>
                <div class="school-address">
                    <%= schoolAddress %>
                </div>
                <% } %>
        </div>
        <div class="doc-title">Admit Card</div>

        <div class="exam-strip">
            <div class="es-item">
                <div class="es-label">Examination</div>
                <div class="es-value">
                    <%= examName %>
                </div>
            </div>
            <div class="es-item">
                <div class="es-label">Year</div>
                <div class="es-value">
                    <%= examYear %>
                </div>
            </div>
            <div class="es-item">
                <div class="es-label">Exam Center</div>
                <div class="es-value">
                    <%= examCenter %>
                </div>
            </div>
        </div>

        <div class="admit-body">
            <div class="photo-box">
                <% if (student.photo) { %>
                    <img src="<%= student.photo %>" alt="Student Photo">
                    <% } else { %>
                        <div class="photo-placeholder">Student<br>Photo</div>
                        <% } %>
            </div>
            <div class="student-info">
                <table class="info-table">
                    <tr>
                        <td>Student Name</td>
                        <td><strong>
                                <%= student.studentName %>
                            </strong></td>
                    </tr>
                    <tr>
                        <td>Roll No.</td>
                        <td>
                            <%= student.rollNo || '—' %>
                        </td>
                    </tr>
                    <tr>
                        <td>Class & Section</td>
                        <td>Class <%= student.class %> — Section <%= student.section || '—' %>
                        </td>
                    </tr>
                    <tr>
                        <td>Admission No.</td>
                        <td>
                            <%= student.admissionNo || '—' %>
                        </td>
                    </tr>
                    <tr>
                        <td>Father's Name</td>
                        <td>
                            <%= student.fatherName || '—' %>
                        </td>
                    </tr>
                    <tr>
                        <td>Date of Birth</td>
                        <td>
                            <%= student.DOB ? new Date(student.DOB).toLocaleDateString('en-IN', {day:'2-digit',
                                month:'long', year:'numeric'}) : '—' %>
                        </td>
                    </tr>
                </table>
            </div>
        </div>

        <% if (schedule && schedule.length> 0) { %>
            <div class="schedule-title">📅 Examination Schedule</div>
            <table class="schedule-table">
                <thead>
                    <tr>
                        <th>S.No.</th>
                        <th>Subject</th>
                        <th>Date</th>
                        <th>Time</th>
                    </tr>
                </thead>
                <tbody>
                    <% schedule.forEach((row, i)=> { %>
                        <tr>
                            <td>
                                <%= i + 1 %>
                            </td>
                            <td>
                                <%= row.subject %>
                            </td>
                            <td>
                                <%= row.date ? new Date(row.date).toLocaleDateString('en-IN', {day:'2-digit',
                                    month:'short', year:'numeric'}) : '—' %>
                            </td>
                            <td>
                                <%= row.time || '—' %>
                            </td>
                        </tr>
                        <% }) %>
                </tbody>
            </table>
            <% } %>

                <div class="notice-box">
                    <strong>⚠️ Important Instructions</strong>
                    1. This admit card must be brought to the examination hall. No candidate will be allowed without it.
                    &nbsp;
                    2. Mobile phones are strictly prohibited inside the examination hall. &nbsp;
                    3. Please be seated 10 minutes before the start of the examination.
                </div>

                <div class="signatures">
                    <div class="sig-box">
                        <div class="sig-line"></div>
                        <div class="sig-label">Student Signature</div>
                    </div>
                    <div class="sig-box">
                        <div class="sig-label" style="margin-bottom: 6px; font-size:10px; color:#777;">Date of Issue
                        </div>
                        <div class="sig-label">
                            <%= generatedDate %>
                        </div>
                    </div>
                    <div class="sig-box">
                        <div class="sig-line"></div>
                        <div class="sig-label">Principal</div>
                        <div class="sig-sub">Signature & Stamp</div>
                    </div>
                </div>
                <div class="doc-footer">This is a computer-generated admit card. — <%= schoolName %>
                </div>
    </div>
</body>

</html>