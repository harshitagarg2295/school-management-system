<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Academics | Rishikulam School</title>
    <link rel="stylesheet" href="/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
</head>

<style>
    body {
        font-family: 'Poppins', sans-serif;
        color: #222;
        margin: 0;
        padding: 0;
    }

    .hero {
        padding: 60px 20px;
    }

    .hero h1 {
        text-align: center;
        color: #2b5fe0;
        font-size: 2.2rem;
        margin-bottom: 40px;
    }

    .heading {
        padding-top: 20px;
    }

    .classes,
    .facility {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 40px;
        padding: 40px 0;
        border-radius: 12px;
    }

    .classes {
        background-color: #f0f6ff;
    }

    .facility {
        background-color: #f8fdf3;
    }

    .box {
        width: 260px;
        background: white;
        border-radius: 12px;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
        text-align: center;
        overflow: hidden;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .box:hover {
        transform: translateY(-10px);
        box-shadow: 0 6px 15px rgba(0, 0, 0, 0.15);
    }

    .box img {
        width: 100%;
        height: 180px;
        object-fit: cover;
    }

    .box p {
        margin: 10px 0;
        font-size: 1rem;
    }

    .box p:first-of-type {
        font-weight: 600;
        color: #2b5fe0;
    }

    .box p:last-of-type {
        color: #444;
    }

    @media (max-width: 768px) {
        .hero h1 {
            font-size: 1.8rem;
        }

        .box {
            width: 80%;
        }

        .classes,
        .facility {
            gap: 25px;
            padding: 20px 0;
        }

    }

    @media (max-width: 480px) {
        .box {
            width: 90%;
        }

        .box img {
            height: 160px;
        }

        .box p {
            font-size: 0.95rem;
        }
        
    }
</style>

<body>
    <%- include("partials/HomePageSchoolName") %>
    <%- include("partials/HomePageNavbar") %>

            <div class="hero">
                <h1>Explore Our Curriculum</h1>

                <div class="classes">
                    <div class="box">
                        <img src="images/pre-primary.jpg" alt="">
                        <p>Pre-Primary</p>
                        <p>Play Group to UKG</p>
                    </div>

                    <div class="box">
                        <img src="images/primary.jpg" alt="">
                        <p>Primary</p>
                        <p>1 to 4</p>
                    </div>

                    <div class="box">
                        <img src="images/middle.jpg" alt="">
                        <p>Middle</p>
                        <p>5 to 8</p>
                    </div>

                    <div class="box">
                        <img src="images/senior.jpg" alt="">
                        <p>Senior</p>
                        <p>9 to 12</p>
                    </div>
                </div>

                <h1 class="heading">Teaching Approaches</h1>

                <div class="facility">
                    <div class="box">
                        <img src="images/classroom.jpg" alt="">
                        <p>Smart Classrooms</p>
                    </div>

                    <div class="box">
                        <img src="images/library.jpg" alt="">
                        <p>Library</p>
                    </div>

                    <div class="box">
                        <img src="images/lab.jpg" alt="">
                        <p>Science Lab</p>
                    </div>

                    <div class="box">
                        <img src="images/computer.jpg" alt="">
                        <p>Computer Lab</p>
                    </div>
                </div>
            </div>

            <%- include("partials/HomePageContact") %>
                <%- include("partials/HomePageFooter") %>
</body>

</html>