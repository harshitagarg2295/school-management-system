<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <title>Forgot Password</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />

  <style>
    :root {
      --bg: #f3f4f6;
      --card: #ffffff;
      --text: #111827;
      --muted: #6b7280;
      --primary: #4f46e5;
      --radius: 14px;
      --shadow: 0 10px 25px rgba(15, 23, 42, 0.12);
    }

    body {
      margin: 0;
      padding: 0;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background: radial-gradient(circle at top, #e5e7eb, #f9fafb);
      font-family: "Inter", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      color: var(--text);
    }

    .fp-wrapper {
      width: 100%;
      /* max-width: 420px; */
      max-width: 500px;
      padding: 18px;
      box-sizing: border-box;
    }

    .fp-card {
      background: var(--card);
      border-radius: var(--radius);
      padding: 26px 22px 24px;
      box-shadow: var(--shadow);
    }

    .fp-title {
      font-size: 22px;
      font-weight: 700;
      margin: 0 0 4px 0;
      text-align: center;
    }

    .fp-sub {
      margin: 0 0 18px 0;
      font-size: 13px;
      color: var(--muted);
      text-align: center;
    }

    .fp-role {
      font-size: 13px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--primary);
      text-align: center;
      margin-bottom: 14px;
      font-weight: 600;
    }

    form {
      display: flex;
      flex-direction: column;
      gap: 10px;
      margin-top: 6px;
    }

    .field {
      display: flex;
      flex-direction: column;
      gap: 4px;
      position: relative;
    }

    .field label {
      font-size: 13px;
      font-weight: 500;
      color: #4b5563;
    }

    .field input {
      /* width: 100%; */
      padding: 9px 11px;
      border-radius: 10px;
      border: 1px solid #d1d5db;
      font-size: 14px;
      background: #f9fafb;
      outline: none;
      transition: border-color 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
    }

    input:focus {
      border-color: var(--primary);
      box-shadow: 0 0 0 1px rgba(79, 70, 229, 0.25);
      background: #ffffff;
    }

    .eye-icon {
      position: absolute;
      right: 12px;
      top: 70%;
      transform: translateY(-50%);
      cursor: pointer;
      color: #9ca3af;
      font-size: 13px;
    }

    .fp-btn {
      margin-top: 8px;
      padding: 10px 12px;
      border-radius: 10px;
      border: none;
      background: linear-gradient(90deg, #4f46e5, #6366f1);
      color: white;
      font-weight: 600;
      font-size: 14px;
      cursor: pointer;
      transition: transform 0.12s ease, box-shadow 0.12s ease, opacity 0.12s ease;
      box-shadow: 0 10px 20px rgba(79, 70, 229, 0.25);
    }

    .fp-btn:hover {
      transform: translateY(-1px);
      opacity: 0.96;
      box-shadow: 0 14px 30px rgba(79, 70, 229, 0.3);
    }

    .fp-footer {
      margin-top: 10px;
      text-align: center;
      font-size: 13px;
      color: var(--muted);
    }

    .fp-footer a {
      color: var(--primary);
      text-decoration: none;
      font-weight: 500;
    }

    .fp-footer a:hover {
      text-decoration: underline;
    }

    @media (max-width: 480px) {
      .fp-card {
        padding: 22px 18px 20px;
      }
    }
  </style>
</head>

<body>

  <div class="fp-wrapper">
    <div class="fp-card">
      <div class="fp-role">
        <% if (role==="admin" ) { %>
          Admin Account
          <% } else if (role==="teacher" ) { %>
            Teacher Account
            <% } else { %>
              Student Account
              <% } %>
      </div>

      <h1 class="fp-title">Forgot Password</h1>
      <p class="fp-sub">
        Verify your details and set a new password.
      </p>

      <form action="/forgot-password" method="post">
        <!-- role hidden -->
        <input type="hidden" name="role" value="<%= role %>">

        <!-- COMMON: Username -->
        <div class="field">
          <label for="username">Username</label>
          <input type="text" name="username" id="username" required>
        </div>

        <div class="field">
          <label>School Code</label>
          <input type="text" name="schoolCode" required>
        </div>

        <!-- STUDENT EXTRA FIELDS -->
        <% if (role==="student" ) { %>
          <div class="field">
            <label for="dob">Date of Birth</label>
            <input type="date" name="dob" id="dob" required>
          </div>

          <div class="field">
            <label for="phone">Registered Phone Number</label>
            <input type="text" name="phone" id="phone" placeholder="Enter your phone number" required>
          </div>
          <% } %>

            <!-- TEACHER: Username + Phone -->
            <% if (role==="teacher" ) { %>
              <div class="field">
                <label for="phone">Registered Phone Number</label>
                <input type="text" name="phone" id="phone" placeholder="Enter your phone number" required>
              </div>
              <% } %>

                <!-- ADMIN: Username + Mobile -->
                <% if (role==="admin" ) { %>
                  <div class="field">
                    <label for="phone">Registered Mobile Number</label>
                    <input type="text" name="phone" id="phone" placeholder="Enter your mobile number" required>
                  </div>
                  <% } %>

                    <!-- New password -->
                    <div class="field">
                      <label for="newPassword">New Password</label>
                      <input type="password" name="newPassword" id="newPassword" required>
                      <i class="fa fa-eye eye-icon" id="toggleNew"></i>
                    </div>

                    <!-- Confirm password -->
                    <div class="field">
                      <label for="confirmPassword">Confirm New Password</label>
                      <input type="password" name="confirmPassword" id="confirmPassword" required>
                      <i class="fa fa-eye eye-icon" id="toggleConfirm"></i>
                    </div>

                    <button type="submit" class="fp-btn">Reset Password</button>
      </form>

      <div class="fp-footer">
        Back to <a href="/login"> Login</a>
      </div>
    </div>
  </div>

  <script>
    function setupToggle(inputId, iconId) {
      const input = document.getElementById(inputId);
      const icon = document.getElementById(iconId);
      if (!input || !icon) return;

      icon.addEventListener("click", () => {
        const type = input.type === "password" ? "text" : "password";
        input.type = type;
        icon.classList.toggle("fa-eye");
        icon.classList.toggle("fa-eye-slash");
      });
    }

    setupToggle("newPassword", "toggleNew");
    setupToggle("confirmPassword", "toggleConfirm");
  </script>
</body>

</html>

<!-- Routes of this file is in loginRoutes -->