<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Non-Academics | Rishikulam School</title>
  <link rel="stylesheet" href="/style.css">
  <link rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
  <style>
    /* ---------- HERO SECTION ---------- */
    .hero {
      position: relative;
      text-align: center;
      overflow: hidden;
    }

    .hero img {
      width: 100%;
      height: 680px;
      object-fit: cover;
      filter: brightness(90%) contrast(105%);
    }

    .hero h1 {
      position: absolute;
      top: 10%;
      left: 50%;
      transform: translate(-50%, -50%);
      color: #fff;
      font-size: 2.6rem;
      font-weight: 700;
      text-align: center;
      font-family: 'Poppins', sans-serif;
      letter-spacing: 1px;
      text-shadow: 3px 3px 8px rgba(0, 0, 0, 0.7);
      z-index: 10;
    }

    .hero p {
      position: absolute;
      bottom: 12%;
      left: 50%;
      transform: translateX(-50%);
      color: #fff;
      font-size: 1.5rem;
      font-weight: 600;
      max-width: 80%;
      text-align: center;
      text-shadow: 2px 2px 6px rgba(0, 0, 0, 0.6);
      line-height: 1.5;
      z-index: 10;
    }

    /* ---------- ACTIVITIES SECTION ---------- */
    .activities {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 25px;
      background-color: #f5f7ff;
      padding: 50px 20px;
    }

    .activities img {
      width: 300px;
      height: 220px;
      object-fit: cover;
      border-radius: 10px;
      transition: all 0.4s ease;
      opacity: 0.85;
      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
    }

    .activities img:hover {
              opacity: 1;
      transform: scale(1.05);
      box-shadow: 0 6px 15px rgba(0, 0, 0, 0.2);
    }

    /* ---------- RESPONSIVE DESIGN ---------- */
    @media (max-width: 768px) {
      .hero img {
        height: 420px;
      }

      .hero h1 {
        font-size: 1.8rem;
        top: 35%;
      }

      .hero p {
        font-size: 1.2rem;
        bottom: 10%;
        max-width: 90%;
      }

      .activities img {
        width: 90%;
        height: auto;
      }
    }

    @media (max-width: 480px) {
      .hero h1 {
        font-size: 1.4rem;
        top: 30%;
      }

      .hero p {
        font-size: 1.05rem;
        bottom: 8%;
      }
    }
  </style>
</head>

<body>
  <%- include("partials/HomePageSchoolName") %>
  <%- include("partials/HomePageNavbar") %>

  <div class="hero">
    <img src="images/football.jpg" alt="Football Activity">
    <h1>Explore Our Co-Curricular Activities</h1>
    <p>At Rishikulam, we believe that sports and creativity nurture confidence, discipline, and teamwork — shaping
      future leaders.</p>
  </div>

  <div class="activities">
    <img src="images/basketball.jpg" alt="Basketball">
    <img src="images/badminton.jpg" alt="Badminton">
    <img src="images/chess.jpg" alt="Chess">
    <img src="images/archery.jpg" alt="Archery">
  </div>

  <%- include("partials/HomePageContact") %>
  <%- include("partials/HomePageFooter") %>
</body>

</html>
