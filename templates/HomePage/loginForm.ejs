<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    <%= title %>
  </title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
  <link rel="stylesheet" href="loginForm.css">
</head>

<style>
  .forgot{
    display: flex;
    justify-content: center;
    align-items: center;
    margin: 10px 0px 2px 5px;
  }
  .forgot a{
    text-decoration: none;
    color:  #4f46e5;
  }
</style>
<body>
  <div class="login-form">
    <div class="form-title">
      <%= loginTitle%>
    </div>

    <form id="loginForm" method="POST" action="/login">

      <!-- role hidden input (admin/teacher/student) -->
      <input type="hidden" id="role" name="role" value="<%= role %>">

      <div class="form-input">
        <label for="username">Username</label>
        <input type="text" id="username" name="username" required>
      </div>

      <div class="form-input">
        <label for="password">Password</label>
        <div style="position: relative;">
          <input type="password" id="password" name="password" required>
          <i class="fa fa-eye" id="togglePassword"
            style="position: absolute; right: 10px; top: 50%; transform: translateY(-50%); cursor: pointer;"></i>
        </div>
      </div>

      <!-- Captcha -->
      <div class="captcha">
        <label for="captcha-input">Captcha</label>
        <div class="captcha-question"></div>
        <div class="captcha-form">
          <input type="text" class="captcha-answer" name="captcha" required placeholder="Enter captcha">
          <button class="refresh"><i class="fa fa-refresh"></i></button>
        </div>
      </div>

      <div class="form-btn">
        <button type="submit" class="login-btn">Login</button>
      </div>

      <div class="forgot">
        <a href="/forgot-password?role=<%= role %>">Forgot password?</a>
      </div>

    </form>
  </div>

  <script src="loginForm.js"></script>
</body>

</html>