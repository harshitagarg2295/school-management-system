<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <title>Login</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: linear-gradient(135deg, #1e3c72, #2a5298);
      height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
    }

    .login-box {
      background: #fff;
      padding: 30px;
      border-radius: 12px;
      width: 330px;
      box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
      text-align: center;
    }

    .login-box h2 {
      margin-bottom: 20px;
      color: #2a5298;
    }

    input,
    select {
      width: 100%;
      padding: 10px;
      margin: 8px 0;
      border-radius: 6px;
      border: 1px solid #ccc;
      outline: none;
    }

    button {
      width: 100%;
      padding: 10px;
      background: #2a5298;
      color: white;
      border: none;
      border-radius: 6px;
      margin-top: 10px;
      cursor: pointer;
      font-weight: bold;
    }

    button:hover {
      background: #1e3c72;
    }

    .super-admin {
      margin-top: 10px;
      font-size: 13px;
    }

    .super-admin a {
      color: #2a5298;
      text-decoration: none;
    }

    .super-admin a:hover {
      text-decoration: underline;
    }
  </style>
</head>

<body>

  <div class="login-box">
    <h2>School Login</h2>

    <p id="errorMsg" style="color:red; font-size:14px;"></p>
    <form action="/login" method="POST">

      <input type="text" name="schoolCode" placeholder="Enter School Code" required>

      <select name="role" required>
        <option value="">Select Role</option>
        <option value="admin">Admin</option>
        <option value="teacher">Teacher</option>
        <option value="student">Student</option>
      </select>

      <input type="text" name="username" placeholder="Username" required>
      <input type="password" name="password" placeholder="Password" required>
      <div style="display:flex; justify-content:flex-end; margin-top:4px;">
        <a href="/forgot-password?role=admin" id="forgotLink"
          style="font-size:13px; color:#4f46e5; text-decoration:none;">
          Forgot Password?
        </a>
      </div>

      <button type="submit">Login</button>

    </form>

    <!-- Super Admin hidden access -->
    <div class="super-admin">
      <a href="/super-admin/login">Super Admin Login</a>
    </div>

  </div>

</body>


<script>
  const roleSelect = document.querySelector("select[name='role']");
  const forgotLink = document.getElementById("forgotLink");
 const params = new URLSearchParams(window.location.search);
  if (params.get("error")) {
    document.getElementById("errorMsg").innerText =
      "Invalid username / password / school code";
  }
  
  forgotLink.addEventListener("click", (e) => {
    if (!roleSelect.value) {
      e.preventDefault();
      alert("Please select role first");
    }
  });

  roleSelect.addEventListener("change", () => {
    const role = roleSelect.value;
    if (role) {
      forgotLink.href = `/forgot-password?role=${role}`;
    }
  });
</script>

</html>