<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>About School</title>
    <link rel="stylesheet" href="/style.css">
    <link rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
</head>

<style>
    .hero {
        margin: 60px 70px;
    }

    .heading {
        text-align: center;
        color: rgb(70, 126, 246);
        margin-bottom: 60px;
        font-size: 2.2rem;
        letter-spacing: 1px;
        font-weight: 700;
    }

    .main {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 60px;
    }

    .box {
        width: 340px;
        background: #f5f8ff;
        border-radius: 15px;
        padding: 25px 20px;
        text-align: center;
        box-shadow: 0 6px 25px rgba(0, 0, 0, 0.1);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .box:hover {
        transform: translateY(8px);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
    }

    .box img {
        width: 100%;
        height: 320px;
        object-fit: cover;
        border-radius: 10px;
        margin-bottom: 15px;
        border: 3px solid rgba(70, 126, 246, 0.2);
    }

    .box h2 {
        color: #2b5fe0;
        font-size: 1.3rem;
        margin-bottom: 10px;
        letter-spacing: 0.5px;
    }

    .box h3 {
        color: #1a1a1a;
        font-size: 1.1rem;
        margin-bottom: 10px;
        font-weight: 600;
    }

    .box p {
        color: #333;
        font-size: 0.95rem;
        line-height: 1.7;
        padding: 0 10px;
    }

    /* Responsive Styling */
    @media (max-width: 992px) {
        .hero {
            margin: 40px 30px;
        }

        .box {
            width: 300px;
        }
    }

    @media (max-width: 768px) {
        .main {
            flex-direction: column;
            align-items: center;
        }

        .box {
            width: 90%;
        }

        .box img {
            height: 280px;
        }
    }

    @media (max-width: 480px) {
        .heading {
            font-size: 1.7rem;
        }

        .box {
            padding: 20px 15px;
        }

        .box h2 {
            font-size: 1.2rem;
        }

        .box h3 {
            font-size: 1rem;
        }

        .box p {
            font-size: 0.9rem;
        }
    }
</style>

<body>
    <%- include("partials/HomePageSchoolName") %>
    <%- include("partials/HomePageNavbar") %>

    <section class="hero">
        <h1 class="heading">Our Management Team</h1>

        <div class="main">
            <div class="box">
                <h2>Director</h2>
                <img src="images/director.jpg" alt="Director">
                <h3>Mr. Rajesh Mehta</h3>
                <p>With over 20 years of experience, he leads the school with dedication and a vision for holistic growth.</p>
            </div>

            <div class="box">
                <h2>Principal</h2>
                <img src="images/principal.jpg" alt="Principal">
                <h3>Mrs. Anjali Sharma</h3>
                <p>Her innovative teaching methods and student-first approach make her a key pillar of Rishikulam.</p>
            </div>

            <div class="box">
                <h2>Vice Principal</h2>
                <img src="/images/vice principal.jpg" alt="Vice Principal">
                <h3>Mr. Vivek Verma</h3>
                <p>Responsible for operations and development, ensuring smooth management and infrastructure growth.</p>
            </div>
        </div>
    </section>

    <%- include("partials/HomePageContact") %>
    <%- include("partials/HomePageFooter") %>
</body>

</html>
