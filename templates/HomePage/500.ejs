<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport"
        content="width=device-width, initial-scale=1.0">

    <title>
        Server Error
    </title>

    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap"
        rel="stylesheet">

    <style>

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {

            font-family:
                "Plus Jakarta Sans",
                sans-serif;

            min-height: 100vh;

            display: flex;

            justify-content: center;

            align-items: center;

            background:
                linear-gradient(
                    135deg,
                    #fef2f2 0%,
                    #fee2e2 100%
                );

            padding: 20px;
        }

        .container {

            max-width: 700px;

            width: 100%;

            background: white;

            border-radius: 28px;

            padding: 50px 35px;

            text-align: center;

            box-shadow:
                0 20px 50px
                rgba(239, 68, 68, 0.12);

            animation:
                fadeUp 0.4s ease;
        }

        @keyframes fadeUp {

            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .error-code {

            font-size: 110px;

            font-weight: 800;

            color: #ef4444;

            line-height: 1;
        }

        h1 {

            font-size: 34px;

            margin-top: 10px;

            color: #0f172a;
        }

        p {

            margin-top: 16px;

            font-size: 17px;

            color: #64748b;

            line-height: 1.7;
        }

        .btn-group {

            margin-top: 35px;

            display: flex;

            justify-content: center;
        }

        .btn {

            text-decoration: none;

            padding: 14px 28px;

            border-radius: 14px;

            background: #ef4444;

            color: white;

            font-size: 15px;

            font-weight: 600;

            transition: 0.2s ease;
        }

        .btn:hover {

            background: #dc2626;

            transform: translateY(-2px);
        }

        .illustration {

            font-size: 70px;

            margin-bottom: 15px;
        }

        @media (max-width: 600px) {

            .container {

                padding: 40px 25px;
            }

            .error-code {

                font-size: 85px;
            }

            h1 {

                font-size: 28px;
            }

            p {

                font-size: 15px;
            }

            .btn {

                width: 100%;
            }
        }

    </style>

</head>

<body>

    <div class="container">

        <div class="illustration">
            ⚠️
        </div>

        <div class="error-code">
            500
        </div>

        <h1>
            Internal Server Error
        </h1>

        <p>

            Something went wrong on our side.
            Please try again after some time.

        </p>

        <div class="btn-group">

            <a href="/"
                class="btn">

                Back To Home

            </a>

        </div>

    </div>

</body>

</html>