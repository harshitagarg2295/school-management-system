<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Terms & Conditions | VidhyaLitee</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
    <style>
        :root {
            --primary: #1e293b;
            --accent: #2563eb;
            --text: #475569;
            --bg: #f8fafc;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg);
            color: var(--primary);
            line-height: 1.8;
            margin: 0;
        }

        .terms-header {
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
            color: white;
            padding: 80px 20px;
            text-align: center;
        }

        .container {
            max-width: 900px;
            margin: -50px auto 100px;
            background: white;
            padding: 50px;
            border-radius: 24px;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.05);
        }

        h2 {
            color: var(--accent);
            border-bottom: 2px solid #f1f5f9;
            padding-bottom: 10px;
            margin-top: 40px;
            font-size: 1.4rem;
        }

        p,
        li {
            color: var(--text);
            font-size: 1.05rem;
        }

        .highlight-box {
            background: #eff6ff;
            border-left: 4px solid var(--accent);
            padding: 20px;
            margin: 20px 0;
            border-radius: 8px;
        }

        @media (max-width: 768px) {
            .container {
                margin-top: 0;
                padding: 30px 20px;
                border-radius: 0;
            }
        }
    </style>
</head>

<body>

    <%- include("partials/HomePageNavbar") %>

