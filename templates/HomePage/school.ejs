<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>About School</title>
  <link rel="stylesheet" href="/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
</head>

<style>
  .box {
    margin: 80px auto;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 0 20px;
  }

  .hero img {
    object-fit: cover;
    object-position: center;
    border-radius: 0 0 15px 15px;
    box-shadow: 0 5px 20px rgba(0, 0, 0, 0.1);
  }

  .para-section {
    background: rgba(197, 232, 247, 0.9);
    backdrop-filter: blur(10px);
    width: 100%;
    max-width: 1100px;
    border-radius: 20px;
    padding: 50px 40px;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.15);
    text-align: center;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .para-section:hover {
     transform: scale(1.01);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
  }

  .para-section h1 {
    font-size: 2rem;
    color: #004aad;
    margin-bottom: 25px;
    font-family: 'Poppins', sans-serif;
    letter-spacing: 0.5px;
  }

  .para-section p {
    font-size: 1.05rem;
    color: #333;
    line-height: 1.8;
    text-align: justify;
    font-family: 'Inter', sans-serif;
  }

  /* ===== Responsive ===== */
  @media (max-width: 992px) {
    .box {
      margin: 60px auto;
    }

    .para-section {
      padding: 40px 30px;
    }

    .para-section h1 {
      font-size: 1.7rem;
    }
  }

  @media (max-width: 768px) {
    .hero img {
      height: 45vh;
    }

    .para-section {
      padding: 30px 25px;
    }

    .para-section h1 {
      font-size: 1.5rem;
    }

    .para-section p {
      font-size: 0.95rem;
    }
  }

  @media (max-width: 480px) {
    .box {
      margin: 40px auto;
      padding: 0 15px;
    }

    .hero img {
      height: 40vh;
    }

    .para-section {
      padding: 25px 20px;
    }

    .para-section h1 {
      font-size: 1.3rem;
    }

    .para-section p {
      font-size: 0.9rem;
      line-height: 1.6;
    }
  }
</style>

<body>
  <%- include("partials/HomePageSchoolName") %>
  <%- include("partials/HomePageNavbar") %>

  <section class="hero">
    <img src="images/img3.jpg" alt="" width="100%">
    <div class="box">
      <div class="para-section">
        <h1>About RISHIKULAM</h1>
        <p>Rishikulam School, Morena was established in 2010 with the aim of providing quality education
          that nurtures both knowledge and values. The school offers a supportive environment where
          students grow academically, socially, and emotionally.
          <br><br>
          With well-equipped classrooms, modern facilities, and a team of experienced teachers, Rishikulam
          focuses on overall development through academics, sports, and cultural activities. Our goal is
          to prepare students to face future challenges with confidence and integrity.
        </p>
      </div>
    </div>
  </section>

  <%- include("partials/HomePageContact") %>
  <%- include("partials/HomePageFooter") %>
</body>

</html>
