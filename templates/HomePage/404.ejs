<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>404 - Page Not Found</title>
    <!-- Font Awesome for clean modern icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Google Fonts: Plus Jakarta Sans for premium tech look -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 24px;
            /* Premium minimal light background with soft tech gradients */
            background-color: #f8fafc;
            background-image: 
                radial-gradient(at 0% 0%, rgba(99, 102, 241, 0.05) 0px, transparent 50%),
                radial-gradient(at 100% 100%, rgba(79, 70, 229, 0.03) 0px, transparent 50%);
            color: #334155;
            overflow-x: hidden;
        }

        .container {
            position: relative;
            z-index: 2;
            max-width: 480px;
            width: 100%;
            background: #ffffff;
            border: 1px solid #e2e8f0;
            border-radius: 32px;
            padding: 50px 40px;
            text-align: center;
            /* Layered premium shadow for sleek depth */
            box-shadow: 0 20px 50px rgba(148, 163, 184, 0.1), 0 1px 3px rgba(148, 163, 184, 0.05);
            animation: cardEntrance 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }

        @keyframes cardEntrance {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Modern Typography Graphic - Floating Animation */
        .error-graphic {
            font-size: 110px;
            font-weight: 800;
            line-height: 1;
            margin-bottom: 16px;
            background: linear-gradient(135deg, #4f46e5 0%, #2563eb 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            letter-spacing: -4px;
            position: relative;
            display: inline-block;
            animation: float 5s ease-in-out infinite;
        }

        @keyframes float {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-8px); }
        }

        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: #fef2f2;
            border: 1px solid #fee2e2;
            color: #ef4444;
            padding: 6px 14px;
            border-radius: 999px;
            font-size: 12px;
            font-weight: 600;
            letter-spacing: 0.5px;
            margin-bottom: 24px;
            text-transform: uppercase;
        }

        .error-title {
            font-size: 26px;
            font-weight: 700;
            color: #0f172a;
            letter-spacing: -0.5px;
            margin-bottom: 12px;
        }

        .error-desc {
            color: #64748b;
            font-size: 15px;
            line-height: 1.6;
            margin-bottom: 32px;
            font-weight: 400;
        }

        .btn-wrapper {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .action-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            text-decoration: none;
            padding: 15px 24px;
            border-radius: 14px;
            font-size: 14px;
            font-weight: 600;
            transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
            width: 100%;
        }

        .btn-primary {
            background: linear-gradient(135deg, #2563eb 0%, #4f46e5 100%);
            color: #ffffff;
            box-shadow: 0 4px 12px rgba(37, 99, 235, 0.15);
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(37, 99, 235, 0.25);
            filter: brightness(1.05);
        }

        .btn-secondary {
            border: 1px solid #e2e8f0;
            background: #ffffff;
            color: #475569;
        }

        .btn-secondary:hover {
            transform: translateY(-2px);
            background: #f8fafc;
            border-color: #cbd5e1;
            color: #0f172a;
        }

        .network-footer {
            margin-top: 36px;
            padding-top: 20px;
            border-top: 1px solid #f1f5f9;
            color: #94a3b8;
            font-size: 13px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            font-weight: 500;
        }

        @media (min-width: 480px) {
            .btn-wrapper {
                flex-direction: row;
            }
        }
    </style>
</head>
<body>

<div class="container">
    <!-- Premium Floating Typography Graphic -->
    <div class="error-graphic">404</div>

    <div>
        <div class="status-badge">
            <i class="fa-solid fa-circle-exclamation"></i> Error: Page Not Found
        </div>
    </div>

    <h1 class="error-title">Page Not Found</h1>
    <p class="error-desc">
        The page you are looking for might have been removed, had its name changed, or is temporarily unavailable.
    </p>

    <div class="btn-wrapper">
        <a href="/" class="action-btn btn-primary">
            <i class="fa-solid fa-house"></i> Back to Dashboard
        </a>
        <a href="/login" class="action-btn btn-secondary">
            <i class="fa-solid fa-key"></i> Login Again
        </a>
    </div>

    <div class="network-footer">
        <i class="fa-solid fa-circle-check" style="color: #10b981;"></i> 
        <span>All backend networks are operational.</span>
    </div>
</div>

<script src="/backButton.js"></script>
</body>
</html>