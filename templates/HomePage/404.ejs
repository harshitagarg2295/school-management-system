<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>
        Page Not Found
    </title>

    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap"
        rel="stylesheet">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {

            font-family:
                "Plus Jakarta Sans",
                sans-serif;

            min-height: 100vh;

            display: flex;

            justify-content: center;

            align-items: center;

            background:
                linear-gradient(135deg,
                    #eff6ff 0%,
                    #dbeafe 100%);

            padding: 20px;
        }

        .container {

            max-width: 700px;

            width: 100%;

            background: white;

            border-radius: 28px;

            padding: 50px 35px;

            text-align: center;

            box-shadow:
                0 20px 50px rgba(37, 99, 235, 0.12);

            animation:
                fadeUp 0.4s ease;
        }

        @keyframes fadeUp {

            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .error-code {

            font-size: 120px;

            font-weight: 800;

            color: #2563eb;

            line-height: 1;
        }

        h1 {

            font-size: 34px;

            margin-top: 10px;

            color: #0f172a;
        }

        p {

            margin-top: 16px;

            font-size: 17px;

            color: #64748b;

            line-height: 1.7;
        }

        .btn-group {

            margin-top: 35px;

            display: flex;

            gap: 15px;

            justify-content: center;

            flex-wrap: wrap;
        }

        .btn {

            text-decoration: none;

            padding: 14px 24px;

            border-radius: 14px;

            font-size: 15px;

            font-weight: 600;

            transition: 0.2s ease;
        }

        .primary-btn {

            background: #2563eb;

            color: white;
        }

        .primary-btn:hover {

            background: #1d4ed8;

            transform: translateY(-2px);
        }

        .secondary-btn {

            background: #eff6ff;

            color: #2563eb;
        }

        .secondary-btn:hover {

            background: #dbeafe;

            transform: translateY(-2px);
        }

        .illustration {

            font-size: 70px;

            margin-bottom: 15px;
        }

        @media (max-width: 600px) {

            .container {

                padding: 40px 25px;
            }

            .error-code {

                font-size: 90px;
            }

            h1 {

                font-size: 28px;
            }

            p {

                font-size: 15px;
            }

            .btn {

                width: 100%;
            }
        }
    </style>

</head>

<body>

    <div class="container">

        <div class="illustration">
            📚
        </div>

        <div class="error-code">
            404
        </div>

        <h1>
            Page Not Found
        </h1>

        <p>

            Oops! The page you are looking for
            does not exist or may have been moved.

        </p>

        <div class="btn-group">

            <a href="/" class="btn primary-btn">

                Go To Home

            </a>

            <a href="/login" class="btn secondary-btn">

                Login Again

            </a>

        </div>

    </div>
    <%- include("../partials/app-back-handler") %>
</body>

</html>