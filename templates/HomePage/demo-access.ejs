<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Live Demo | VidhyaLitee</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
    <style>
        :root {
            --primary: #2563eb;
            --dark: #0f172a;
            --text-slate: #64748b;
            --bg-light: #f1f5f9;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-light);
            margin: 0;
            color: var(--dark);
        }

        .demo-hero {
            background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
            color: white;
            padding: 60px 20px 100px;
            text-align: center;
        }

        .demo-hero h1 {
            margin: 0;
            font-size: 2.5rem;
        }

        .demo-hero p {
            padding-top: 10px;
            margin: 0;
            font-size: 1.1rem;
            opacity: 0.9;
        }

        .container {
            max-width: 900px;
            margin: -60px auto 80px;
            padding: 0 20px;
            box-sizing: border-box;
        }

        /* School Code Section */
        .school-code-banner {
            background: #fff;
            padding: 20px;
            border-radius: 16px;
            margin-bottom: 30px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 15px;
            border: 2px dashed var(--primary);
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.05);
        }

        .code-display {
            font-size: 1.5rem;
            font-weight: 800;
            color: var(--primary);
            letter-spacing: 2px;
            background: #eff6ff;
            padding: 5px 15px;
            border-radius: 8px;
            cursor: pointer;
        }

        /* Demo Card Layout */
        .demo-card {
            background: white;
            display: flex;
            align-items: center;
            padding: 20px 30px;
            border-radius: 16px;
            margin-bottom: 20px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
            transition: 0.3s;
            gap: 15px;
        }

        .demo-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.08);
        }

        .icon-box {
            width: 50px;
            height: 50px;
            background: #eff6ff;
            color: var(--primary);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.4rem;
            flex-shrink: 0;
        }

        .info {
            flex-grow: 1;
        }

        .info h3 {
            margin: 0;
            font-size: 1.2rem;
        }

        .info p {
            margin: 2px 0 0;
            font-size: 0.9rem;
            color: var(--text-slate);
        }

        .cred-tags {
            display: flex;
            gap: 10px;
        }

        .tag {
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            padding: 6px 12px;
            border-radius: 6px;
            font-size: 0.85rem;
            cursor: pointer;
            transition: 0.2s;
            white-space: nowrap;
        }

        .tag:hover {
            background: #e2e8f0;
        }

        .tag b {
            color: var(--primary);
        }

        .login-link {
            background: var(--primary);
            color: white;
            text-decoration: none;
            padding: 12px 24px;
            border-radius: 8px;
            font-weight: 600;
            font-size: 0.9rem;
            white-space: nowrap;
            transition: 0.2s;
            text-align: center;
        }

        .login-link:hover {
            background: #1d4ed8;
        }

        /* Toast Notification */
        #toast {
            visibility: hidden;
            min-width: 200px;
            background-color: #333;
            color: #fff;
            text-align: center;
            border-radius: 50px;
            padding: 12px;
            position: fixed;
            z-index: 999;
            bottom: 30px;
            left: 50%;
            transform: translateX(-50%);
        }

        #toast.show {
            visibility: visible;
            animation: fadein 0.5s, fadeout 0.5s 2.5s;
        }

        @keyframes fadein {
            from {
                bottom: 0;
                opacity: 0;
            }

            to {
                bottom: 30px;
                opacity: 1;
            }
        }

        @keyframes fadeout {
            from {
                bottom: 30px;
                opacity: 1;
            }

            to {
                bottom: 0;
                opacity: 0;
            }
        }

        @media (max-width: 768px) {
            .demo-hero {
                padding: 40px 20px 80px;
            }

            .demo-hero h1 {
                font-size: 2rem;
            }


            .demo-card {
                flex-direction: row !important;
                flex-wrap: wrap;
                align-items: center;
                padding: 15px;
                gap: 12px;
            }

            .icon-box {
                width: 42px;
                height: 42px;
                font-size: 1.1rem;
            }

            .info {
                flex: 1;     
                min-width: 150px;
            }

            .info h3 {
                font-size: 1.05rem;
            }

            .cred-tags {
                width: 100%;               
                flex-wrap: nowrap;
                justify-content: space-between;
            }

            .tag {
                flex: 1;
                text-align: center;
                padding: 6px 8px;
                font-size: 0.8rem;
            }

            .login-link {
                width: 100%;
                box-sizing: border-box;
                padding: 12px;
            }
        }
        @media (max-width:550px){
             .school-code-banner {
                flex-direction: column;
                text-align: center;
                gap: 10px;
            }
        }
    </style>
</head>

<body>

    <%- include("partials/HomePageNavbar") %>

        <section class="demo-hero">
            <h1>VidhyaLitee Live Demo</h1>
            <p>Try the system with our pre-configured Demo School</p>
        </section>

        <div class="container">

            <div class="school-code-banner">
                <span><i class="fa-solid fa-school"></i> <b>Demo School Code:</b></span>
                <div class="code-display" onclick="copyText('DEMO248')">DEMO248</div>
                <small style="color: var(--text-slate);">(Click to copy)</small>
            </div>

            <!-- Admin Card -->
            <div class="demo-card">
                <div class="icon-box"><i class="fa-solid fa-user-shield"></i></div>
                <div class="info">
                    <h3>Admin Portal</h3>
                    <p>Full Management</p>
                </div>
                <div class="cred-tags">
                    <div class="tag" onclick="copyText('admin_demo')"><b>ID:</b> admin_demo</div>
                    <div class="tag" onclick="copyText('demo123')"><b>Pass:</b> demo123</div>
                </div>
                <!-- Added query string for Auto-Fill -->
                <a href="/login?code=DEMO248&username=admin_demo&password=demo123" class="login-link">Login as Admin</a>
            </div>

            <!-- Teacher Card -->
            <div class="demo-card">
                <div class="icon-box"><i class="fa-solid fa-chalkboard-user"></i></div>
                <div class="info">
                    <h3>Teacher Portal</h3>
                    <p>Academic Tools</p>
                </div>
                <div class="cred-tags">
                    <div class="tag" onclick="copyText('teacher_demo')"><b>ID:</b> teacher_demo</div>
                    <div class="tag" onclick="copyText('demo123')"><b>Pass:</b> demo123</div>
                </div>
                <!-- Added query string for Auto-Fill -->
                <a href="/login?code=DEMO248&username=teacher_demo&password=demo123" class="login-link">Login as
                    Teacher</a>
            </div>

            <!-- Student Card -->
            <div class="demo-card">
                <div class="icon-box"><i class="fa-solid fa-user-graduate"></i></div>
                <div class="info">
                    <h3>Student/Parent</h3>
                    <p>Learning & Fees</p>
                </div>
                <div class="cred-tags">
                    <div class="tag" onclick="copyText('student_demo')"><b>ID:</b> student_demo</div>
                    <div class="tag" onclick="copyText('demo123')"><b>Pass:</b> demo123</div>
                </div>
                <!-- Added query string for Auto-Fill -->
                <a href="/login?code=DEMO248&username=student_demo&password=demo123" class="login-link">Login as
                    Student</a>
            </div>

        </div>

        <div id="toast">Copied to clipboard!</div>

        <script>
            function copyText(text) {
                navigator.clipboard.writeText(text);
                var x = document.getElementById("toast");
                x.className = "show";
                setTimeout(function () { x.className = x.className.replace("show", ""); }, 3000);
            }
        </script>

        <%- include("partials/HomePageFooter") %>
        <script src="/backButton.js"></script>
</body>

</html>