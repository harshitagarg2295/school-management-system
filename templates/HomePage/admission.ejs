<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>About School</title>
  <link rel="stylesheet" href="/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
</head>

<style>
  /* ---------- HERO SECTION ---------- */
  .hero {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .hero img {
    width: 100%;
    height: 70vh;
    object-fit: cover;
    filter: brightness(90%) contrast(105%);
  }

  .hero h1 {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    color: #fff;
    background: rgba(0, 0, 0, 0.5);
    padding: 15px 25px;
    border-radius: 10px;
    font-family: 'Poppins', sans-serif;
    font-size: 2.4rem;
    font-weight: 600;
    letter-spacing: 1px;
    text-align: center;
    z-index: 2;
  }

  .btn-fee {
    position: absolute;
    top: 70%;
    left: 50%;
    transform: translate(-50%, -50%);
    background-color: #2b5fe0;
    color: white;
    padding: 12px 28px;
    border: none;
    border-radius: 8px;
    font-size: 1.1rem;
    text-decoration: none;
    font-weight: 600;
    transition: 0.3s ease;
  }

  .btn-fee:hover {
    background-color: #1e3fa3;
    transform: translate(-50%, -50%) scale(1.05);
  }

  /* ---------- MAIN CONTAINER ---------- */
  .main {
    padding: 60px 8%;
    background: #f9fafc;
    font-family: 'Poppins', sans-serif;
  }

  /* ---------- STEPS SECTION ---------- */
  .steps {
    background: linear-gradient(135deg, #e8f0fe, #f8faff);
    padding: 45px;
    border-radius: 16px;
    margin-bottom: 60px;
    box-shadow: 0 6px 14px rgba(0, 0, 0, 0.07);
    text-align: center;
    transition: 0.3s ease;
  }

  .steps:hover {
    transform: translateY(-3px);
  }

  .steps h2 {
    font-family: 'Poppins', sans-serif;
    font-size: 2rem;
    color: #2b5fe0;
    margin-bottom: 30px;
    font-weight: 600;
    letter-spacing: 0.5px;
  }

  .step-box {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 18px;
    max-width: 700px;
    margin: 0 auto;
  }

  .step-box p {
    background: #fff;
    width: 100%;
    text-align: left;
    padding: 15px 20px;
    border-radius: 10px;
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.05);
    font-size: 1.05rem;
    color: #333;
    font-weight: 500;
    display: flex;
    align-items: center;
    gap: 12px;
    transition: all 0.3s ease;
  }

  .step-box p:hover {
    background: #2b5fe0;
    color: #fff;
    transform: scale(1.02);
  }

  .step-box p i {
    color: #2b5fe0;
    font-size: 1.2rem;
    transition: color 0.3s ease;
  }

  .step-box p:hover i {
    color: #fff;
  }

  /* ---------- FORM SECTION ---------- */
  .form-card {
    background: #ffffff;
    padding: 40px;
    border-radius: 15px;
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.08);
    max-width: 850px;
    margin: auto;
  }

  .form-card h3 {
    font-size: 1.8rem;
    color: #2b5fe0;
    text-align: center;
    margin-bottom: 25px;
    font-weight: 600;
  }

  .form-row {
    display: flex;
    gap: 30px;
    margin-bottom: 25px;
  }

  .form-row div {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  label {
    margin-bottom: 6px;
    color: #444;
    font-weight: 500;
  }

  input,
  select {
    padding: 10px 14px;
    border: 1px solid #ccc;
    border-radius: 8px;
    font-size: 1rem;
    transition: 0.3s ease;
  }

  input:focus,
  select:focus {
    border-color: #2b5fe0;
    outline: none;
    box-shadow: 0 0 5px rgba(43, 95, 224, 0.3);
  }

  .required {
    color: red;
  }

  .submit-row {
    text-align: center;
    margin-top: 30px;
  }

  .btn-primary {
    background: #2b5fe0;
    color: #fff;
    border: none;
    padding: 12px 28px;
    border-radius: 10px;
    font-size: 1.05rem;
    cursor: pointer;
    transition: 0.3s ease;
  }

  .btn-primary:hover {
    background: #1e4ccc;
    transform: scale(1.05);
  }

  .muted {
    font-size: 0.9rem;
    color: #666;
    margin-top: 15px;
  }


  /* Fee structure css */

  /* Trigger button (Admission) */
  .admission-btn {
    display: inline-block;
    background: linear-gradient(135deg, #2b5fe0, #5aa0ff);
    color: #fff;
    padding: 10px 16px;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    box-shadow: 0 6px 18px rgba(43, 95, 224, .18);
    transition: transform .18s ease, box-shadow .18s ease;
  }

  .admission-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 30px rgba(43, 95, 224, .22);
  }

  /* ---------- Modal base (hidden by default) ---------- */
  .modal-overlay {
    position: fixed;
    inset: 0;
    display: grid;
    place-items: center;
    background: rgba(10, 12, 20, 0.6);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity .25s ease, visibility .25s ease;
    z-index: 9999;
  }

  /* when target is active (URL fragment #feeModal) show modal */
  .modal-overlay:target {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  /* Card */
  .modal-card {
    width: 760px;
    max-width: calc(100% - 40px);
    background: linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
    border-radius: 12px;
    box-shadow: 0 18px 50px rgba(6, 16, 40, 0.45);
    overflow: hidden;
    transform: translateY(-10px);
    animation: cardIn .28s ease forwards;
    font-family: system-ui, -apple-system, "Segoe UI", Roboto, "Poppins", sans-serif;
  }

  /* subtle opening */
  @keyframes cardIn {
    from {
      transform: translateY(-20px) scale(.995);
      opacity: .96;
    }

    to {
      transform: translateY(0) scale(1);
      opacity: 1;
    }
  }

  /* close button (top-right X) */
  .modal-close {
    position: absolute;
    right: 14px;
    top: 10px;
    font-size: 26px;
    line-height: 26px;
    color: #444;
    text-decoration: none;
    padding: 6px 8px;
    border-radius: 8px;
    transition: background .15s ease, color .15s ease;
    z-index: 10;
  }

  .modal-close:hover {
    background: rgba(0, 0, 0, 0.06);
    color: #111;
  }

  /* header */
  .modal-header {
    padding: 22px 28px;
    border-bottom: 1px solid #eef2ff;
    background: linear-gradient(90deg, #f5f8ff 0, #ffffff 100%);
  }

  .modal-header h2 {
    margin: 0;
    color: #2b5fe0;
    font-size: 1.25rem;
    letter-spacing: .2px;
  }

  .modal-sub {
    margin: 6px 0 0;
    font-size: .92rem;
    color: #58627a;
  }

  /* body */
  .modal-body {
    max-height: 58vh;
    /* scroll if too tall */
    overflow: auto;
    padding: 14px 20px 6px;
  }

  /* fee item */
  .fee-list {
    padding: 6px 6px 18px;
  }

  .fee-item {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    padding: 12px 14px;
    border-radius: 8px;
    align-items: center;
    margin: 8px 0;
    background: linear-gradient(180deg, #ffffff, #fbfdff);
    border: 1px solid rgba(50, 60, 120, 0.04);
    box-shadow: 0 2px 8px rgba(33, 47, 88, 0.02);
  }

  .fee-item .fee-left {
    font-weight: 600;
    color: #1f2937;
  }

  .fee-item .fee-left small {
    display: block;
    font-weight: 500;
    font-size: .82rem;
    color: #6b7280;
    margin-top: 4px;
  }

  .fee-item .fee-right {
    font-weight: 700;
    color: #0f1724;
  }

  /* highlighted admission fee row */
  .fee-item.highlight {
    background: linear-gradient(90deg, #fff9f1, #fffdf7);
    border-left: 6px solid #ffb74d;
  }

  /* footer */
  .modal-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    padding: 14px 20px;
    border-top: 1px solid #eef2ff;
    background: #fcfdff;
  }

  .modal-footer .note {
    margin: 0;
    color: #556;
    font-size: .92rem;
  }

  .close-cta {
    background: #2b5fe0;
    color: #fff;
    padding: 8px 14px;
    text-decoration: none;
    border-radius: 8px;
    font-weight: 600;
  }


  /* ---------- RESPONSIVE DESIGN ---------- */
  @media (max-width: 992px) {
    .form-row {
      flex-direction: column;
      gap: 15px;
    }

    .hero h1 {
      font-size: 1.8rem;
      padding: 10px 20px;
    }

    .main {
      padding: 50px 6%;
    }

    .btn-fee {
      top: 72%;
      font-size: 1rem;
      padding: 10px 24px;
    }
  }

  @media (max-width:680px) {
    .modal-card {
      width: 94%;
      max-width: 520px;
    }

    .modal-header {
      padding: 16px;
    }

    .modal-footer {
      flex-direction: column;
      align-items: stretch;
      gap: 8px;
    }

    .fee-item {
      padding: 10px;
    }

    .modal-close {
      right: 10px;
      top: 6px;
      font-size: 22px;
    }
  }

  @media (max-width: 600px) {
    .hero img {
      height: 50vh;
    }

    .hero h1 {
      font-size: 1.4rem;
      padding: 8px 16px;
    }

    .form-card {
      padding: 25px;
    }

    .btn-primary {
      width: 100%;
      padding: 12px;
    }

    .steps {
      padding: 20px;
    }

    .steps p {
      font-size: 0.95rem;
    }

    .btn-fee {
      top: 80%;
      font-size: 0.9rem;
      padding: 9px 20px;
      border-radius: 6px;
    }
  }

  @media (max-width: 450px) {
    .btn-fee {
      top: 82%;
      font-size: 0.85rem;
      padding: 8px 18px;
    }
  }
</style>

<body>
  <%- include("partials/HomePageSchoolName") %>
    <%- include("partials/HomePageNavbar") %>

      <div class="hero">
        <img src="images/img2.png" alt="">
        <h1>Explore Admissions — Join Rishikulam</h1>
        <a href="#feeModal" class="btn-fee">View Fee Structure</a>

      </div>

      <div class="main">

        <div class="steps">
          <h2>Steps to Enroll at RISHIKULAM</h2>
          <div class="step-box">
            <p><i class="fa-solid fa-file-lines"></i> Fill out the Admission Form with accurate details.</p>
            <p><i class="fa-solid fa-phone-volume"></i> Receive a call to schedule an Assessment Test.</p>
            <p><i class="fa-solid fa-folder-open"></i> Submit the required documents at the school office.</p>
            <p><i class="fa-solid fa-circle-check"></i> Get a confirmation call for successful admission.</p>
          </div>
        </div>

        <section class="form-card" aria-labelledby="formTitle">
          <h3 id="formTitle">Admission Form</h3>
          <form action="/admissions/submit" method="POST" enctype="multipart/form-data" novalidate>
            <div class="form-row">
              <div>
                <label for="studentName">Student name <span class="required">*</span></label>
                <input id="studentName" name="studentName" type="text" required placeholder="Full name">
              </div>
              <div>
                <label for="dob">Date of birth <span class="required">*</span></label>
                <input id="dob" name="dob" type="date" required>
              </div>
            </div>

            <div class="form-row">
              <div>
                <label for="applyClass">Applying for (class) <span class="required">*</span></label>
                <select id="applyClass" name="applyClass" required>
                  <option value="">Select class</option>
                  <option>Pre-Primary (Play - UKG)</option>
                  <option>Primary (1 - 4)</option>
                  <option>Middle (5 - 8)</option>
                  <option>Senior (9 - 12)</option>
                </select>
              </div>
              <div>
                <label for="gender">Gender</label>
                <select id="gender" name="gender">
                  <option value="">Select Gender</option>
                  <option>Male</option>
                  <option>Female</option>
                  <option>Other</option>
                </select>
              </div>
            </div>

            <div class="form-row">
              <div>
                <label for="parentName">Parent / Guardian name <span class="required">*</span></label>
                <input id="parentName" name="parentName" type="text" required placeholder="Parent full name">
              </div>
              <div>
                <label for="phone">Phone <span class="required">*</span></label>
                <input id="phone" name="phone" type="tel" required placeholder="eg. +91 98XXXXXXXX">
              </div>
            </div>

            <div class="form-row">
              <div>
                <label for="email">Email</label>
                <input id="email" name="email" type="email" placeholder="parent@example.com">
              </div>
              <div>
                <label for="prevSchool">Previous school (if any)</label>
                <input id="prevSchool" name="prevSchool" type="text" placeholder="School name">
              </div>
            </div>

            <div class="submit-row">
              <div>
                <button type="submit" class="btn-primary">Submit Application</button>
              </div>

              <div class="muted center" style="min-width:200px;">
                After submit you'll get a confirmation message and next steps by phone/email.
              </div>
            </div>
          </form>
        </section>
      </div>
      <%- include("partials/HomePageContact") %>
        <%- include("partials/HomePageFooter") %>



          <!-- Fee Structure Card -->

          <div id="feeModal" class="modal-overlay" aria-hidden="true">
            <div class="modal-card" role="dialog" aria-labelledby="feeTitle" aria-modal="true">
              <a class="modal-close" href="#" aria-label="Close fee structure">&times;</a>

              <header class="modal-header">
                <h2 id="feeTitle">Fee Structure — Session 2025–26</h2>
                <p class="modal-sub">Complete one-time admission & annual tuition overview</p>
              </header>

              <main class="modal-body">
                <div class="fee-item highlight">
                  <div class="fee-left">Admission Fee <small>(One time)</small></div>
                  <div class="fee-right">₹1,500</div>
                </div>

                <div class="fee-list">
                  <div class="fee-item">
                    <div class="fee-left">Play Group (PG)</div>
                    <div class="fee-right">₹25,000</div>
                  </div>

                  <div class="fee-item">
                    <div class="fee-left">Nursery</div>
                    <div class="fee-right">₹36,500</div>
                  </div>

                  <div class="fee-item">
                    <div class="fee-left">LKG — UKG</div>
                    <div class="fee-right">₹36,500</div>
                  </div>

                  <div class="fee-item">
                    <div class="fee-left">Class I — II</div>
                    <div class="fee-right">₹44,500</div>
                  </div>

                  <div class="fee-item">
                    <div class="fee-left">Class III — V</div>
                    <div class="fee-right">₹47,500</div>
                  </div>

                  <div class="fee-item">
                    <div class="fee-left">Class VI — VIII</div>
                    <div class="fee-right">₹53,000</div>
                  </div>

                  <div class="fee-item">
                    <div class="fee-left">Class IX</div>
                    <div class="fee-right">₹58,500</div>
                  </div>

                  <div class="fee-item">
                    <div class="fee-left">Class X</div>
                    <div class="fee-right">₹60,500</div>
                  </div>

                  <div class="fee-item">
                    <div class="fee-left">Class XI</div>
                    <div class="fee-right">₹60,500</div>
                  </div>

                  <div class="fee-item">
                    <div class="fee-left">Class XII</div>
                    <div class="fee-right">₹61,500</div>
                  </div>
                </div>
              </main>

              <footer class="modal-footer">
                <p class="note"><strong>Note:</strong> Books, transport & uniform charges are not included.</p>
                <a class="close-cta" href="#">Okay</a>
              </footer>
            </div>
          </div>

</body>

</html>