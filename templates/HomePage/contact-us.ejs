<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact Us | SchoolFlow</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            margin: 0;
            background-color: #f8fafc;
            color: #1e293b;
        }

        .contact-container {
            max-width: 1100px;
            margin: 80px auto;
            padding: 0 20px;
        }

        .contact-card {
            background: white;
            border-radius: 24px;
            overflow: hidden;
            display: flex;
            flex-wrap: wrap;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.05);
        }

        .info-panel {
            background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
            color: white;
            padding: 60px;
            flex: 1;
            min-width: 350px;
        }

        .form-panel {
            padding: 60px;
            flex: 1.5;
            min-width: 350px;
        }

        .info-item {
            display: flex;
            align-items: center;
            margin-bottom: 30px;
            gap: 20px;
        }

        .info-icon {
            width: 50px;
            height: 50px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
        }

        h1 {
            font-size: 36px;
            margin-bottom: 15px;
            font-weight: 800;
        }

        p {
            opacity: 0.8;
            line-height: 1.6;
        }

        .social-dots {
            display: flex;
            gap: 15px;
            margin-top: 40px;
        }

        .dot {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.1);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        @media (max-width: 768px) {

            .info-panel,
            .form-panel {
                padding: 40px;
            }
        }
    </style>
</head>

<body>
    <%- include("partials/HomePageNavbar") %>

        <div class="contact-container">
            <div class="contact-card">
                <div class="info-panel">
                    <h1>Let's Talk</h1>
                    <p>Have questions about SchoolFlow? We're here to help you digitize your school.</p>

                    <div style="margin-top: 50px;">
                        <div class="info-item">
                            <div class="info-icon"><i class="fas fa-phone-alt"></i></div>
                            <div>
                                <div style="font-size: 14px; opacity: 0.6;">Call Us</div>
                                <div style="font-weight: 600;">+91 9826230803</div>
                            </div>
                        </div>
                        <div class="info-item">
                            <div class="info-icon"><i class="fas fa-envelope"></i></div>
                            <div>
                                <div style="font-size: 14px; opacity: 0.6;">Email Support</div>
                                <div style="font-weight: 600;">harshitagarg2295@gmail.com</div>
                            </div>
                        </div>
                        <div class="info-item">
                            <div class="info-icon"><i class="fas fa-map-marker-alt"></i></div>
                            <div>
                                <div style="font-size: 14px; opacity: 0.6;">Headquarters</div>
                                <div style="font-weight: 600;">Morena, Madhya Pradesh, India</div>
                            </div>
                        </div>
                    </div>

                    <div class="social-dots">
                        <div class="dot"><i class="fab fa-facebook-f"></i></div>
                        <div class="dot"><i class="fab fa-instagram"></i></div>
                        <div class="dot"><i class="fab fa-linkedin-in"></i></div>
                    </div>
                </div>

                <div class="form-panel">
                    <h2 style="font-size: 28px; margin-bottom: 30px;">Direct Support</h2>
                    <p style="color: #64748b; margin-bottom: 40px;">
                        We are currently providing 1-on-1 support for all our partner schools. If you need assistance
                        with integration or have billing queries, feel free to reach out via phone or email.
                    </p>

                    <div
                        style="padding: 30px; background: #f1f5f9; border-radius: 16px; border-left: 4px solid #3b82f6;">
                        <h4 style="margin: 0 0 10px 0;">Business Hours</h4>
                        <p style="margin: 0; font-size: 14px;">Monday - Friday: 10:00 AM to 6:00 PM</p>
                        <p style="margin: 5px 0 0 0; font-size: 14px;">Saturday: 10:00 AM to 2:00 PM</p>
                    </div>

                    <div style="margin-top: 50px; text-align: center; opacity: 0.4;">
                        <i class="fas fa-shield-alt" style="font-size: 40px;"></i>
                        <p style="font-size: 12px; margin-top: 10px;">Secure Business Communication</p>
                    </div>
                </div>
            </div>
        </div>

        <%- include("partials/HomePageFooter") %>
            <%- include("../partials/app-back-handler") %>
</body>

</html>