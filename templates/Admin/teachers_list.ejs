<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Teachers</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
    <link rel="stylesheet" href="/adminDashboard.css">
</head>
<style>
    body {
        background-color: #f1f1f1;
    }

    .teachers-section {
        width: 82%;
    }

    .teachers-page {
        background-color: white;
        padding: 10px 18px;
        margin: 20px 10px 20px 20px;
        border-radius: 8px;
    }

    .headers {
        display: flex;
        justify-content: space-between;
        margin-top: 20px;
    }

    .search-teach {
        display: flex;
        align-items: center;
    }

    .search-teach i {
        position: relative;
        left: 25px;
        font-size: 16px;
    }

    .search-teach input {
        padding: 7px 2px 7px 30px;
        border-radius: 16px;
        border: 1px solid grey;
        font-size: 15px;
    }

    .teachers-header {
        background-color: #b1e6f4;
        border-radius: 7px;
        margin-top: 15px;
        /* min-width: max-content; */
        min-width: 1100px;
    }

    .teachers-header ul {
        list-style: none;
        font-size: 20px;
        color: rgb(70, 66, 66);
        padding: 10px 6px 13px 5px;
    }

    .teachers-header ul li {
        margin-top: 22px;
    }

    .list {
        font-size: 18px;
        padding: 20px 10px;
        word-break: break-word;
        border-bottom: 1px solid black;
    }

    .teachers-header ul,
    .teacher-list .list {
        display: grid;
        grid-template-columns: 0.2fr 1.8fr 1fr 1fr 1.2fr 1fr 1.5fr 1.5fr 1fr;
        min-width: 1100px;
        align-items: center;
        gap: 10px;
    }


    .list:hover {
        background-color: rgb(231, 194, 219);
    }

    .icons {
        display: flex;
        gap: 10px;
        cursor: pointer;
    }

    .btn {
        display: flex;
        justify-content: flex-end;
        align-items: center;
    }

    .add_teach {
        margin: 10px 5px;
        padding: 7px 10px;
        font-size: 16px;
        border-radius: 6px;
        outline: none;
        border: none;
        background-color: rgb(66, 154, 242);
        color: white;
    }

    .teacher-form {
        display: none;
        margin: 10px 10px 15px;
    }

    .teacher-form input {
        margin: 5px;
        text-align: center;
        padding: 5px 3px;
        border-radius: 3px;
        border: 1px solid grey;
        width: 160px;
    }

    .teacher-form button {
        padding: 7px 14px;
        background-color: rgb(66, 154, 242);
        color: white;
        border: none;
        border-radius: 5px;

    }

    .teacher-edit-form input {
        margin: 4px;
        padding: 5px 3px;
        width: 150px;
    }

    .teacher-edit-form button {
        width: 70px;
        padding: 6px 10px;
        background-color: #60A5FA;
        border: none;
        color: white;
        border-radius: 4px;
    }

    .dropdown {
        position: relative;
    }

    .dropdown-menu {
        position: absolute;
        top: 100%;
        right: -100px;
        background-color: rgba(15, 15, 15, 0.8);
        min-width: 200px;
        z-index: 1000;
        padding: 8px 0px 8px;
        text-align: center;
        display: none;
        border-radius: 6px;
    }

    .dropdown-menu a {
        text-decoration: none;
        color: white;
        transition: all 0.3s ease;

    }

    .table-wrapper {
        width: 100%;
        overflow-x: auto;
        overflow-y: hidden;
        border-radius: 6px;
    }

    .teachers-header ul,
    .list {
        min-width: 950px;
    }


    .teacher-form-wrapper {
        width: 100%;
        overflow-x: auto;
    }

    .teacher-form.show {
        display: flex !important;
        flex-wrap: nowrap;
        gap: 12px;
        min-width: max-content;
    }

    .teacher-form-wrapper::-webkit-scrollbar {
        height: 5px;
    }

    .teacher-form-wrapper::-webkit-scrollbar-thumb {
        background: #bbb;
        border-radius: 50px;
    }


    @media (max-width:1300px) and (min-width:900px) {
        .teachers-section {
            margin-left: 280px !important;
            /* EXACT Sidebar width */
            width: calc(100% - 280px);
        }

        .teacher-edit-form input {
            width: 130px;
        }
    }

    @media(max-width:900px) {
        .teachers-section {
            width: 100%;
        }

        .teacher-edit-form input {
            width: 130px;
        }
    }

    @media(max-width: 534px) {
        .headers {
            flex-direction: column;
            justify-content: center;
            align-items: center;
            gap: 10px;
        }

        .headers h1 {
            padding-top: 15px;
        }

        .teachers-page {
            margin: 0 10px;
            padding: 0;
        }

    }

    .pdf-btn {
        display: flex;
        justify-content: center;
        align-items: center;
        margin-top: 15px;
        margin-bottom: 15px;
    }

    .print-btn {
        padding: 10px 15px;
        border-radius: 8px;
        border: none;
        font-size: 14px;
        background-color: rgb(66, 154, 242);
        color: white;

    }

    @media print {
        body {
            background: white !important;
            -webkit-print-color-adjust: exact !important;
            print-color-adjust: exact !important;
            font-size: 12px;
        }

        .menu-section,
        .hamburger,
        .no-print,
        .headers,
        .teacher-form-wrapper,
        .pdf-btn,
        .btn,
        .notification {
            display: none !important;
        }

        /* 2. Reset Container Margins/Widths */
        .teachers-section {
            margin-left: 0 !important;
            width: 100% !important;
        }

        .teachers-page {
            width: 100% !important;
            margin: 0 !important;
            box-shadow: none !important;
            padding: 0px !important;
        }

        .table-wrapper {
            overflow: visible !important;
        }

        /* 3. FIX THE GRID & HIDE ACTION COLUMN */
        .teachers-header ul,
        .list {
            display: grid !important;
            grid-template-columns: 0.2fr 1.5fr 1fr 1fr 1fr 1fr 1.5fr 1.5fr !important;
            min-width: 100% !important;
            padding: 5px 0 !important;
            font-size: 12px !important;
            gap: 5px !important;
        }

        .teachers-header ul li:last-child {
            display: none !important;
        }

        .icons {
            display: none !important;
        }

        .teacher-edit-form {
            display: none !important;
        }

        .teacher-wrapper {
            page-break-inside: avoid;
        }
    }
</style>

<body>

    <div class="admin_dash">

        <!-- Include sidebar -->
        <%- include("partials/AdminPageSidebar") %>

            <section class="teachers-section">

                <%- include("partials/adminNotification", { admin: admin }) %>

                    <div class="teachers-page">

                        <div class="headers">

                            <h1>All Teachers List</h1>
                            <div class="search-teach">
                                <i class="fa fa-search"></i>
                                <input type="text" id="searchInput" placeholder="Search by Name">
                            </div>
                        </div>

                        <div class="table-wrapper">
                            <div class="teachers-header">
                                <ul>
                                    <li></li>
                                    <li>Teacher Name</li>
                                    <li>Id</li>
                                    <li>Subject</li>
                                    <li>Class(es)</li>
                                    <li>Salary</li>
                                    <li>DOB</li>
                                    <li>Phone Number</li>
                                    <li>Action</li>
                                </ul>
                            </div>

                            <div class="btn">
                                <button class="add_teach">Add Teacher</button>
                            </div>

                            <div class="teacher-form-wrapper">
                                <!-- Hidden Form for add teacher -->
                                <form class="teacher-form" action="/add-teacher" method="POST">
                                    <input type="text" name="name" placeholder="Name" required
                                        style="text-transform: capitalize;">
                                    <input type="text" name="empId" placeholder="Id" required
                                        style="text-transform: capitalize;">
                                    <input type="text" name="subject" placeholder="Subject" required
                                        style="text-transform: capitalize;">
                                    <input type="text" name="class" placeholder="Classes (comma-separated)" required
                                        style="text-transform:  uppercase;;">
                                    <input type="text" onfocus="(this.type='date')" name="dob" placeholder="DOB"
                                        required>
                                    <!-- <input type="text" name="address" placeholder="Address" required
                                        style="text-transform: capitalize;"> -->
                                    <input type="text" name="salary" placeholder="Salary" required>
                                    <input type="text" name="phone" placeholder="Phone Number" required>
                                    <button type="submit">Save</button>
                                </form>
                            </div>

                            <div class="teacher-list">

                                <% teachers.forEach((teacher, index)=> { %>
                                    <div class="teacher-wrapper " id="wrapper-<%= teacher._id %>"
                                        data-name="<%= teacher.name.toLowerCase() %>">

                                        <!-- Normal View -->
                                        <div class="list" id="display-<%= teacher._id %>">
                                            <div class="id">
                                                <%= index + 1 %>
                                            </div>
                                            <div class="name">
                                                <a href="/teacher/<%= teacher._id %>"
                                                    style="text-decoration:none; color:inherit;">
                                                    <%= teacher.name %>
                                                </a>
                                            </div>
                                            <div class="id">
                                                <%= teacher.empId%>
                                            </div>
                                            <div class="subject">
                                                <%= teacher.subject %>
                                            </div>
                                            <div class="class">
                                                <%= teacher.class%>
                                            </div>
                                            <div class="salary">
                                                <%= teacher.salary ? teacher.salary.toLocaleString('en-IN') : '0' %>
                                            </div>
                                           <div class="DOB">
                                                <%= teacher.dob ? teacher.dob.toISOString().split("T")[0] : 'N/A' %>
                                            </div>
                                            <div class="number">
                                                <%= teacher.phone %>
                                            </div>
                                            <div class="icons">

                                                <!-- Edit icon -->
                                                <i class="fa-solid fa-pen-to-square" style="cursor:pointer"
                                                    onclick="enableEdit('<%= teacher._id %>')"></i>

                                                <!-- Delete Form -->
                                                <form action="/delete-teacher/<%= teacher._id %>" method="POST"
                                                    style="display:inline;" onsubmit="return confirmDelete()">
                                                    <button type="submit" style="background:none; border:none;">
                                                        <i class="fa-solid fa-trash" style="color: red;"></i>
                                                    </button>
                                                </form>

                                                <div class="dropdown">
                                                    <i class="fa-solid fa-ellipsis three-dots"></i>

                                                    <div class="dropdown-menu">
                                                        <a href="/view-attendance-teachers">View Attendance</a>

                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Editable Form View -->
                                        <form id="edit-<%= teacher._id %>" class="teacher-edit-form list"
                                            action="/edit-teacher/<%= teacher._id %>" method="POST"
                                            style="display:none;">
                                            <div class="id">
                                                <%= index + 1 %>
                                            </div>
                                            <input type="text" name="name" value="<%= teacher.name %>" required
                                                style="text-transform: capitalize;">
                                            <input type="text" name="empId" value="<%= teacher.empId %>" required
                                                style="text-transform: capitalize;">
                                            <input type="text" name="subject" value="<%= teacher.subject %>" required
                                                style="text-transform: capitalize;">
                                            <input type="text" name="class" value="<%= teacher.class %>" required
                                                style="text-transform:  uppercase;;">
                                            <input type="text" name="salary" value="<%= teacher.salary %>" required>
                                             <input type="date" name="DOB"
                                                value="<%= teacher.dob ? teacher.dob.toISOString().split("T")[0] : 'N/A' %>" required>
                                            <input type="text" name="phone" value="<%= teacher.phone %>" required>
                                            <button type="submit">Save</button>

                                        </form>
                                    </div>
                                    <% }) %>

                            </div>
                        </div>
                    </div>

                    <div class="pdf-btn">
                        <button onclick="window.print()" class="print-btn no-print">
                            Download PDF
                        </button>
                    </div>

            </section>
    </div>

    <script>
        const searchInput = document.getElementById("searchInput");

        searchInput.addEventListener("input", function () {
            const searchText = this.value.toLowerCase();
            const teacherRows = document.querySelectorAll(".teacher-wrapper");

            teacherRows.forEach(row => {
                const name = row.dataset.name;
                row.style.display = name.includes(searchText) ? "" : "none";
            });
        });

        let btn = document.querySelector(".add_teach");

        btn.addEventListener("click", () => {
            // document.querySelector(".teacher-form").style.display = 'block';
            document.querySelector(".teacher-form").classList.add("show");

        });

        function enableEdit(id) {
            document.getElementById("display-" + id).style.display = "none";
            document.getElementById("edit-" + id).style.display = "grid";  // grid for layout
        }

        function confirmDelete() {
            return confirm("Are you sure you want to delete this teacher?");
        }

        const allDots = document.querySelectorAll(".three-dots");
        const allMenus = document.querySelectorAll(".dropdown-menu");

        allDots.forEach((dot, index) => {
            dot.addEventListener("click", () => {
                // Hide all dropdowns first
                allMenus.forEach(menu => menu.style.display = "none");

                // Show clicked one
                allMenus[index].style.display = "block";
            });
        });

        // Hide if clicked outside
        document.addEventListener("click", function (e) {
            if (!e.target.closest(".dropdown")) {
                allMenus.forEach(menu => menu.style.display = "none");
            }
        });
    </script>
  <%- include("../partials/app-back-handler") %>

</body>

</html>