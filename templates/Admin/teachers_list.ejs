<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Teachers</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
    <link rel="stylesheet" href="/adminDashboard.css">
</head>
<style>
    body {
        background-color: #f1f1f1;
    }

    .teachers-section {
        width: 82%;
    }

    .teachers-page {
        background-color: white;
        padding: 10px 18px;
        margin: 20px 10px 20px 20px;
        border-radius: 8px;
    }

    .headers {
        display: flex;
        justify-content: space-between;
        margin-top: 20px;
    }

    .search-teach {
        display: flex;
        align-items: center;
    }

    .search-teach i {
        position: relative;
        left: 25px;
        font-size: 16px;
    }

    .search-teach input {
        padding: 7px 2px 7px 30px;
        border-radius: 16px;
        border: 1px solid grey;
        font-size: 15px;
    }

    .teachers-header {
        background-color: #b1e6f4;
        border-radius: 7px;
        margin-top: 15px;
        /* min-width: max-content; */
        min-width: 1100px;
    }

    .teachers-header ul {
        list-style: none;
        font-size: 20px;
        color: rgb(70, 66, 66);
        padding: 10px 6px 13px 5px;
    }

    .teachers-header ul li {
        margin-top: 22px;
    }

    .list {
        font-size: 18px;
        padding: 20px 10px;
        word-break: break-word;
        border-bottom: 1px solid black;
    }

    .teachers-header ul,
    .teacher-list .list {
        display: grid;
        grid-template-columns: 0.2fr 1.8fr 1fr 1fr 1.2fr 1fr 1.5fr 1.5fr 1fr;
        min-width: 1100px;
        align-items: center;
        gap: 10px;
    }


    .list:hover {
        background-color: rgb(231, 194, 219);
    }

    .icons {
        display: flex;
        gap: 10px;
        cursor: pointer;
    }

    .btn {
        display: flex;
        justify-content: flex-end;
        align-items: center;
    }

    .add_teach {
        margin: 10px 5px;
        padding: 7px 10px;
        font-size: 16px;
        border-radius: 6px;
        outline: none;
        border: none;
        background-color: rgb(66, 154, 242);
        color: white;
    }

    .teacher-form {
        display: none;
        margin: 10px 10px 15px;
    }

    .teacher-form input {
        margin: 5px;
        text-align: center;
        padding: 5px 3px;
        border-radius: 3px;
        border: 1px solid grey;
        width: 160px;
    }

    .teacher-form button {
        padding: 7px 14px;
        background-color: rgb(66, 154, 242);
        color: white;
        border: none;
        border-radius: 5px;

    }

    .teacher-edit-form input {
        margin: 4px;
        padding: 5px 3px;
        width: 150px;
    }

    .teacher-edit-form button {
        width: 70px;
        padding: 6px 10px;
        background-color: #60A5FA;
        border: none;
        color: white;
        border-radius: 4px;
    }

    .dropdown {
        position: relative;
    }

    .dropdown-menu {
        position: absolute;
        top: 100%;
        right: -100px;
        background-color: rgba(15, 15, 15, 0.8);
        min-width: 200px;
        z-index: 1000;
        padding: 8px 0px 8px;
        text-align: center;
        display: none;
        border-radius: 6px;
    }

    .dropdown-menu a {
        text-decoration: none;
        color: white;
        transition: all 0.3s ease;

    }

    .table-wrapper {
        width: 100%;
        overflow-x: auto;
        overflow-y: hidden;
        border-radius: 6px;
    }

    .teachers-header ul,
    .list {
        min-width: 950px;
    }


    .teacher-form-wrapper {
        width: 100%;
        overflow-x: auto;
    }

    .teacher-form.show {
        display: flex !important;
        flex-wrap: nowrap;
        gap: 12px;
        min-width: max-content;
    }

    .teacher-form-wrapper::-webkit-scrollbar {
        height: 5px;
    }

    .teacher-form-wrapper::-webkit-scrollbar-thumb {
        background: #bbb;
        border-radius: 50px;
    }


    @media (max-width:1300px) and (min-width:900px) {
        .teachers-section {
            margin-left: 280px !important;
            /* EXACT Sidebar width */
            width: calc(100% - 280px);
        }

        .teacher-edit-form input {
            width: 130px;
        }
    }

    @media(max-width:900px) {
        .teachers-section {
            width: 100%;
        }

        .teacher-edit-form input {
            width: 130px;
        }
    }

    @media(max-width: 534px) {
        .headers {
            flex-direction: column;
            justify-content: center;
            align-items: center;
            gap: 10px;
        }

        .headers h1 {
            padding-top: 15px;
        }

        .teachers-page {
            margin: 0 10px;
            padding: 0;
        }

    }

    .pdf-btn {
        display: flex;
        justify-content: center;
        align-items: center;
        margin-top: 15px;
        margin-bottom: 15px;
    }

    .print-btn {
        padding: 10px 15px;
        border-radius: 8px;
        border: none;
        font-size: 14px;
        background-color: rgb(66, 154, 242);
        color: white;

    }

    /* ── Bulk Upload Modal ── */
    .bulk-upload-btn {
        margin: 10px 5px;
        padding: 7px 12px;
        font-size: 15px;
        border-radius: 6px;
        outline: none;
        border: none;
        background-color: #16a34a;
        color: white;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 6px;
        transition: background 0.2s;
    }
    .bulk-upload-btn:hover { background-color: #15803d; }
    .bulk-modal-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.55);
        z-index: 9999;
        justify-content: center;
        align-items: center;
    }
    .bulk-modal-overlay.active { display: flex; }
    .bulk-modal {
        background: #fff;
        border-radius: 14px;
        padding: 30px 32px;
        width: 420px;
        max-width: 95vw;
        box-shadow: 0 8px 40px rgba(0,0,0,0.18);
        position: relative;
        animation: modalIn 0.22s ease;
    }
    @keyframes modalIn {
        from { transform: scale(0.92); opacity: 0; }
        to   { transform: scale(1);    opacity: 1; }
    }
    .bulk-modal h2 { margin: 0 0 6px; font-size: 20px; color: #1e293b; }
    .bulk-modal p.bulk-sub { font-size: 13px; color: #64748b; margin-bottom: 18px; }
    .bulk-modal .sample-link {
        display: inline-flex; align-items: center; gap: 5px;
        font-size: 13px; color: #2563eb; text-decoration: none;
        margin-bottom: 16px; font-weight: 500;
    }
    .bulk-modal .sample-link:hover { text-decoration: underline; }
    .bulk-modal .file-drop-area {
        border: 2px dashed #93c5fd; border-radius: 10px; padding: 22px 16px;
        text-align: center; color: #475569; font-size: 14px; background: #f0f9ff;
        cursor: pointer; transition: border-color 0.2s, background 0.2s;
        margin-bottom: 16px; position: relative;
    }
    .bulk-modal .file-drop-area:hover, .bulk-modal .file-drop-area.dragover {
        border-color: #3b82f6; background: #dbeafe;
    }
    .bulk-modal .file-drop-area input[type=file] {
        position: absolute; inset: 0; opacity: 0; cursor: pointer; width: 100%; height: 100%;
    }
    .bulk-modal .file-name-display { font-size: 13px; color: #16a34a; font-weight: 600; margin-top: 6px; min-height: 18px; }
    .bulk-modal .modal-actions { display: flex; gap: 10px; margin-top: 6px; }
    .bulk-modal .upload-submit-btn {
        flex: 1; padding: 10px; background: #16a34a; color: white; border: none;
        border-radius: 8px; font-size: 15px; cursor: pointer; font-weight: 600; transition: background 0.2s;
    }
    .bulk-modal .upload-submit-btn:hover { background: #15803d; }
    .bulk-modal .upload-submit-btn:disabled { background: #86efac; cursor: not-allowed; }
    .bulk-modal .cancel-btn {
        padding: 10px 18px; background: #f1f5f9; border: 1px solid #cbd5e1;
        border-radius: 8px; font-size: 15px; cursor: pointer; color: #475569;
    }
    .bulk-modal .cancel-btn:hover { background: #e2e8f0; }
    .bulk-modal .close-modal {
        position: absolute; top: 14px; right: 16px; background: none; border: none;
        font-size: 22px; cursor: pointer; color: #94a3b8; line-height: 1;
    }
    .bulk-uploading-spinner { display: none; font-size: 13px; color: #2563eb; text-align: center; margin-top: 8px; }

    @media print {
        body {
            background: white !important;
            -webkit-print-color-adjust: exact !important;
            print-color-adjust: exact !important;
            font-size: 12px;
        }

        .menu-section,
        .hamburger,
        .no-print,
        .headers,
        .teacher-form-wrapper,
        .pdf-btn,
        .btn,
        .notification {
            display: none !important;
        }

        /* 2. Reset Container Margins/Widths */
        .teachers-section {
            margin-left: 0 !important;
            width: 100% !important;
        }

        .teachers-page {
            width: 100% !important;
            margin: 0 !important;
            box-shadow: none !important;
            padding: 0px !important;
        }

        .table-wrapper {
            overflow: visible !important;
        }

        /* 3. FIX THE GRID & HIDE ACTION COLUMN */
        .teachers-header ul,
        .list {
            display: grid !important;
            grid-template-columns: 0.2fr 1.5fr 1fr 1fr 1fr 1fr 1.5fr 1.5fr !important;
            min-width: 100% !important;
            padding: 5px 0 !important;
            font-size: 12px !important;
            gap: 5px !important;
        }

        .teachers-header ul li:last-child {
            display: none !important;
        }

        .icons {
            display: none !important;
        }

        .teacher-edit-form {
            display: none !important;
        }

        .teacher-wrapper {
            page-break-inside: avoid;
        }
    }
</style>

<body>

    <div class="admin_dash">

        <!-- Include sidebar -->
        <%- include("partials/AdminPageSidebar") %>

            <section class="teachers-section">

                <%- include("partials/adminNotification", { admin: admin }) %>

                    <div class="teachers-page">

                        <div class="headers">

                            <h1>All Teachers List</h1>
                            <div class="search-teach">
                                <i class="fa fa-search"></i>
                                <input type="text" id="searchInput" placeholder="Search by Name">
                            </div>
                        </div>

                        <div class="table-wrapper">
                            <div class="teachers-header">
                                <ul>
                                    <li></li>
                                    <li>Teacher Name</li>
                                    <li>Id</li>
                                    <li>Subject</li>
                                    <li>Class(es)</li>
                                    <li>Salary</li>
                                    <li>DOB</li>
                                    <li>Phone Number</li>
                                    <li>Action</li>
                                </ul>
                            </div>

                            <div class="btn">
                                <button class="add_teach">Add Teacher</button>
                                <button class="bulk-upload-btn no-print" id="openTeacherBulkModal">
                                    <i class="fa-solid fa-file-arrow-up"></i> Bulk Upload (Excel)
                                </button>
                            </div>

                            <div class="teacher-form-wrapper">
                                <!-- Hidden Form for add teacher -->
                                <form class="teacher-form" action="/add-teacher" method="POST">
                                    <input type="text" name="name" placeholder="Name" required
                                        style="text-transform: capitalize;">
                                    <input type="text" name="empId" placeholder="Id" required
                                        style="text-transform: capitalize;">
                                    <input type="text" name="subject" placeholder="Subject" required
                                        style="text-transform: capitalize;">
                                    <input type="text" name="class" placeholder="Classes (comma-separated)" required
                                        style="text-transform:  uppercase;;">
                                    <input type="text" onfocus="(this.type='date')" name="dob" placeholder="DOB"
                                        required>
                                    <!-- <input type="text" name="address" placeholder="Address" required
                                        style="text-transform: capitalize;"> -->
                                    <input type="text" name="salary" placeholder="Salary" required>
                                    <input type="text" name="phone" placeholder="Phone Number" required>
                                    <button type="submit">Save</button>
                                </form>
                            </div>

                            <div class="teacher-list">

                                <% teachers.forEach((teacher, index)=> { %>
                                    <div class="teacher-wrapper " id="wrapper-<%= teacher._id %>"
                                        data-name="<%= teacher.name.toLowerCase() %>">

                                        <!-- Normal View -->
                                        <div class="list" id="display-<%= teacher._id %>">
                                            <div class="id">
                                                <%= index + 1 %>
                                            </div>
                                            <div class="name">
                                                <a href="/teacher/<%= teacher._id %>"
                                                    style="text-decoration:none; color:inherit;">
                                                    <%= teacher.name %>
                                                </a>
                                            </div>
                                            <div class="id">
                                                <%= teacher.empId%>
                                            </div>
                                            <div class="subject">
                                                <%= teacher.subject %>
                                            </div>
                                            <div class="class">
                                                <%= teacher.class%>
                                            </div>
                                            <div class="salary">
                                                <%= teacher.salary ? teacher.salary.toLocaleString('en-IN') : '0' %>
                                            </div>
                                           <div class="DOB">
                                                <%= teacher.dob ? teacher.dob.toISOString().split("T")[0] : 'N/A' %>
                                            </div>
                                            <div class="number">
                                                <%= teacher.phone %>
                                            </div>
                                            <div class="icons">

                                                <!-- Edit icon -->
                                                <i class="fa-solid fa-pen-to-square" style="cursor:pointer"
                                                    onclick="enableEdit('<%= teacher._id %>')"></i>

                                                <!-- Delete Form -->
                                                <form action="/delete-teacher/<%= teacher._id %>" method="POST"
                                                    style="display:inline;" onsubmit="return confirmDelete()">
                                                    <button type="submit" style="background:none; border:none;">
                                                        <i class="fa-solid fa-trash" style="color: red;"></i>
                                                    </button>
                                                </form>

                                                <div class="dropdown">
                                                    <i class="fa-solid fa-ellipsis three-dots"></i>

                                                    <div class="dropdown-menu">
                                                        <a href="/view-attendance-teachers">View Attendance</a>

                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Editable Form View -->
                                        <form id="edit-<%= teacher._id %>" class="teacher-edit-form list"
                                            action="/edit-teacher/<%= teacher._id %>" method="POST"
                                            style="display:none;">
                                            <div class="id">
                                                <%= index + 1 %>
                                            </div>
                                            <input type="text" name="name" value="<%= teacher.name %>" required
                                                style="text-transform: capitalize;">
                                            <input type="text" name="empId" value="<%= teacher.empId %>" required
                                                style="text-transform: capitalize;">
                                            <input type="text" name="subject" value="<%= teacher.subject %>" required
                                                style="text-transform: capitalize;">
                                            <input type="text" name="class" value="<%= teacher.class %>" required
                                                style="text-transform:  uppercase;;">
                                            <input type="text" name="salary" value="<%= teacher.salary %>" required>
                                             <input type="date" name="DOB"
                                                value="<%= teacher.dob ? teacher.dob.toISOString().split("T")[0] : 'N/A' %>" required>
                                            <input type="text" name="phone" value="<%= teacher.phone %>" required>
                                            <button type="submit">Save</button>

                                        </form>
                                    </div>
                                    <% }) %>

                            </div>
                        </div>
                    </div>

                    <!-- BULK UPLOAD MODAL (TEACHER) -->
                    <div class="bulk-modal-overlay" id="teacherBulkModalOverlay">
                        <div class="bulk-modal" id="teacherBulkModal">
                            <button class="close-modal" id="closeTeacherBulkModal">&times;</button>

                            <!-- UPLOAD VIEW -->
                            <div id="teacherUploadView">
                                <h2><i class="fa-solid fa-chalkboard-teacher" style="color:#16a34a"></i> Bulk Upload Teachers</h2>
                                <p class="bulk-sub">Upload an Excel file to add all teachers at once</p>

                                <a href="/download-sample/teacher" class="sample-link" download>
                                    <i class="fa-solid fa-download"></i> Download Sample Excel Template
                                </a>

                                <div class="file-drop-area" id="teacherDropArea">
                                    <i class="fa-solid fa-cloud-arrow-up" style="font-size:28px; color:#3b82f6; margin-bottom:8px;"></i>
                                    <p style="margin:0;">Drop file here or <strong>Click to Browse</strong></p>
                                    <p style="margin:4px 0 0; font-size:12px; color:#94a3b8;">.xlsx, .xls, .csv supported</p>
                                    <input type="file" id="teacherFileInput" accept=".xlsx,.xls,.csv">
                                </div>
                                <p class="file-name-display" id="teacherFileName"></p>

                                <div class="modal-actions">
                                    <button type="button" class="upload-submit-btn" id="teacherUploadBtn">
                                        <i class="fa-solid fa-upload"></i> Upload
                                    </button>
                                    <button type="button" class="cancel-btn" id="cancelTeacherBulk">Cancel</button>
                                </div>
                                <div id="teacherProcessingState" style="display:none; text-align:center; padding:14px 0;">
                                    <i class="fa-solid fa-spinner fa-spin" style="font-size:26px; color:#3b82f6;"></i>
                                    <p style="margin:8px 0 0; color:#475569; font-size:14px;">Processing file, please wait...</p>
                                </div>
                            </div>

                            <!-- RESULT VIEW -->
                            <div id="teacherResultView" style="display:none;">
                                <div id="teacherResultSuccess" style="display:none;">
                                    <div style="text-align:center; margin-bottom:16px;">
                                        <i class="fa-solid fa-circle-check" style="font-size:40px; color:#16a34a;"></i>
                                        <h2 style="margin:8px 0 4px; color:#1e293b;">Upload Successful!</h2>
                                    </div>
                                    <div id="teacherResultStats" style="display:flex; gap:12px; margin-bottom:16px;"></div>
                                </div>
                                <div id="teacherResultError" style="display:none;">
                                    <div style="text-align:center; margin-bottom:16px;">
                                        <i class="fa-solid fa-circle-xmark" style="font-size:40px; color:#ef4444;"></i>
                                        <h2 style="margin:8px 0 4px; color:#1e293b;">Upload Failed</h2>
                                        <p id="teacherErrorMsg" style="color:#64748b; font-size:14px; margin:0;"></p>
                                    </div>
                                </div>
                                <div id="teacherSkippedSection" style="display:none;">
                                    <p style="font-size:13px; font-weight:600; color:#b45309; margin:0 0 8px;"><i class="fa-solid fa-triangle-exclamation"></i> Records Not Uploaded:</p>
                                    <div id="teacherSkippedList" style="max-height:180px; overflow-y:auto; font-size:12px; background:#fef9c3; border-radius:8px; padding:10px;"></div>
                                </div>
                                <div class="modal-actions" style="margin-top:16px;">
                                    <button type="button" class="upload-submit-btn" id="teacherGoToListBtn" style="display:none;" onclick="window.location.href='/teach-menu'">
                                        <i class="fa-solid fa-list"></i> View Teachers List
                                    </button>
                                    <button type="button" class="cancel-btn" id="teacherUploadAnotherBtn">Upload Another File</button>
                                </div>
                            </div>

                        </div>
                    </div>

                    <div class="pdf-btn">
                        <button onclick="window.print()" class="print-btn no-print">
                            Download PDF
                        </button>
                    </div>

            </section>
    </div>

    <script>
        const searchInput = document.getElementById("searchInput");

        searchInput.addEventListener("input", function () {
            const searchText = this.value.toLowerCase();
            const teacherRows = document.querySelectorAll(".teacher-wrapper");
            teacherRows.forEach(row => {
                const name = row.dataset.name;
                row.style.display = name.includes(searchText) ? "" : "none";
            });
        });

        let btn = document.querySelector(".add_teach");
        btn.addEventListener("click", () => {
            document.querySelector(".teacher-form").classList.add("show");
        });

        function enableEdit(id) {
            document.getElementById("display-" + id).style.display = "none";
            document.getElementById("edit-" + id).style.display = "grid";
        }

        function confirmDelete() {
            return confirm("Are you sure you want to delete this teacher?");
        }

        const allDots = document.querySelectorAll(".three-dots");
        const allMenus = document.querySelectorAll(".dropdown-menu");

        allDots.forEach((dot, index) => {
            dot.addEventListener("click", () => {
                allMenus.forEach(menu => menu.style.display = "none");
                allMenus[index].style.display = "block";
            });
        });

        document.addEventListener("click", function (e) {
            if (!e.target.closest(".dropdown")) {
                allMenus.forEach(menu => menu.style.display = "none");
            }
        });

        // ── Bulk Upload Modal Logic (Teacher) — AJAX ──
        const teacherOverlay   = document.getElementById("teacherBulkModalOverlay");
        const openTeacherBtn   = document.getElementById("openTeacherBulkModal");
        const closeTeacherBtn  = document.getElementById("closeTeacherBulkModal");
        const cancelTeacherBtn = document.getElementById("cancelTeacherBulk");
        const teacherFileInput = document.getElementById("teacherFileInput");
        const teacherFileName  = document.getElementById("teacherFileName");
        const teacherUploadBtn = document.getElementById("teacherUploadBtn");
        const teacherDropArea  = document.getElementById("teacherDropArea");

        function openTeacherModal() { teacherOverlay.classList.add("active"); showTeacherUploadView(); }
        function closeTeacherModal() { teacherOverlay.classList.remove("active"); }
        function showTeacherUploadView() {
            document.getElementById("teacherUploadView").style.display = "";
            document.getElementById("teacherResultView").style.display = "none";
            document.getElementById("teacherProcessingState").style.display = "none";
            teacherUploadBtn.disabled = false;
            teacherUploadBtn.style.display = "";
            teacherFileInput.value = "";
            teacherFileName.textContent = "";
        }

        openTeacherBtn.addEventListener("click", openTeacherModal);
        closeTeacherBtn.addEventListener("click", closeTeacherModal);
        cancelTeacherBtn.addEventListener("click", closeTeacherModal);
        document.getElementById("teacherUploadAnotherBtn").addEventListener("click", showTeacherUploadView);
        teacherOverlay.addEventListener("click", (e) => { if (e.target === teacherOverlay) closeTeacherModal(); });

        teacherFileInput.addEventListener("change", () => {
            teacherFileName.textContent = teacherFileInput.files[0]?.name || "";
        });
        teacherDropArea.addEventListener("dragover", (e) => { e.preventDefault(); teacherDropArea.classList.add("dragover"); });
        teacherDropArea.addEventListener("dragleave", () => teacherDropArea.classList.remove("dragover"));
        teacherDropArea.addEventListener("drop", (e) => {
            e.preventDefault(); teacherDropArea.classList.remove("dragover");
            teacherFileInput.files = e.dataTransfer.files;
            teacherFileName.textContent = e.dataTransfer.files[0]?.name || "";
        });

        teacherUploadBtn.addEventListener("click", async () => {
            if (!teacherFileInput.files || !teacherFileInput.files[0]) { alert("Please select a file first."); return; }
            teacherUploadBtn.disabled = true;
            document.getElementById("teacherProcessingState").style.display = "block";
            teacherUploadBtn.style.display = "none";
            document.getElementById("cancelTeacherBulk").style.display = "none";

            const formData = new FormData();
            formData.append("excelFile", teacherFileInput.files[0]);

            try {
                const res  = await fetch("/bulk-upload-teachers", { method: "POST", body: formData });
                const data = await res.json();
                document.getElementById("teacherUploadView").style.display = "none";
                document.getElementById("teacherResultView").style.display = "";
                document.getElementById("cancelTeacherBulk").style.display = "";

                if (data.success) {
                    document.getElementById("teacherResultSuccess").style.display = "";
                    document.getElementById("teacherResultError").style.display = "none";
                    document.getElementById("teacherResultStats").innerHTML = `
                        <div style="flex:1; background:#dcfce7; border-radius:10px; padding:12px; text-align:center;">
                            <div style="font-size:26px; font-weight:700; color:#16a34a;">${data.created}</div>
                            <div style="font-size:12px; color:#15803d;">Teachers Added</div>
                        </div>
                        <div style="flex:1; background:${data.skipped > 0 ? '#fef9c3' : '#f1f5f9'}; border-radius:10px; padding:12px; text-align:center;">
                            <div style="font-size:26px; font-weight:700; color:${data.skipped > 0 ? '#b45309' : '#64748b'};">${data.skipped}</div>
                            <div style="font-size:12px; color:#64748b;">Skipped</div>
                        </div>
                        <div style="flex:1; background:#f1f5f9; border-radius:10px; padding:12px; text-align:center;">
                            <div style="font-size:26px; font-weight:700; color:#475569;">${data.total}</div>
                            <div style="font-size:12px; color:#64748b;">Total Rows</div>
                        </div>
                    `;
                    if (data.skipped > 0 && data.skippedList?.length > 0) {
                        document.getElementById("teacherSkippedSection").style.display = "";
                        document.getElementById("teacherSkippedList").innerHTML = data.skippedList.map(s =>
                            `<div style="padding:4px 0; border-bottom:1px solid #fde68a;"><strong>${s.name}</strong> [${s.id}] — ${s.reason}</div>`
                        ).join("") + (data.hasMoreSkipped ? `<div style="color:#b45309;">...and more records were skipped.</div>` : "");
                    } else { document.getElementById("teacherSkippedSection").style.display = "none"; }
                    document.getElementById("teacherGoToListBtn").style.display = data.created > 0 ? "" : "none";
                } else {
                    document.getElementById("teacherResultSuccess").style.display = "none";
                    document.getElementById("teacherResultError").style.display = "";
                    document.getElementById("teacherSkippedSection").style.display = "none";
                    document.getElementById("teacherGoToListBtn").style.display = "none";
                    document.getElementById("teacherErrorMsg").textContent = data.message || "Upload failed. Please try again.";
                }
            } catch (err) {
                document.getElementById("teacherUploadView").style.display = "none";
                document.getElementById("teacherResultView").style.display = "";
                document.getElementById("teacherResultSuccess").style.display = "none";
                document.getElementById("teacherResultError").style.display = "";
                document.getElementById("teacherSkippedSection").style.display = "none";
                document.getElementById("teacherGoToListBtn").style.display = "none";
                document.getElementById("teacherErrorMsg").textContent = "Network error. Please check your connection and try again.";
                document.getElementById("cancelTeacherBulk").style.display = "";
            }
        });
    </script>
  <script src="/backButton.js"></script>

</body>

</html>