<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Fees Collection</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
    <link rel="stylesheet" href="/adminDashboard.css">

</head>

<style>
    body {
        background-color: #f1f1f1;
        overflow-x: hidden;
    }

    .admin_dash {
        display: flex;
        background: #ffffff;
    }

    .fees-page {
        width: 100%;
    }

    .fees-card {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
    }

    /* GRAPH — full responsive like Expense page */
    .fees-graph {
        background: #ffffff;
        padding: 20px;
        border-radius: 12px;
        box-shadow: 0 0 10px rgba(0, 0, 0, 0.05);
        width: 100%;
        max-width: 750px;
        margin: 40px 20px 20px 30px;
        position: relative;
        overflow: hidden !important;
    }

    .fees-graph h2 {
        text-align: center;
        margin: 7px 0px 12px 0px;
    }

    #feesLineChart {
        width: 100% !important;
        height: 380px !important;
        max-width: 100% !important;
    }

    .boxes {
        display: grid;
        grid-template-columns: 1fr 1fr;
    }

    .box {
        width: 220px;
        height: 200px;
        background-color: rgb(171, 211, 246);
        margin: 4px 7px;
        border-radius: 13px;
        text-align: left;
    }

    .box1,
    .box2 {
        margin-top: 40px;
    }

    .box h1 {
        margin: 70px 5px 10px 20px;
    }

    .box p {
        margin-left: 20px;
        font-size: 20px;
    }

    .fees-collection-data {
        background: #ffffff;
        padding: 20px;
        border-radius: 12px;
        box-shadow: 0 0 10px rgba(0, 0, 0, 0.05);
        width: calc(100% - 80px) !important;
        margin: 40px auto !important;
    }

    .fees-header {
        display: flex;
        justify-content: space-between;
        margin: 20px 0px 30px 0px;
    }

    .search-stud {
        display: flex;
        align-items: center;
    }

    .search-stud i {
        position: relative;
        left: 25px;
        font-size: 16px;
    }

    .search-stud input {
        padding: 7px 2px 7px 30px;
        border-radius: 16px;
        border: 1px solid grey;
        font-size: 15px;
    }

    .select_class {
        outline: none;
        padding: 7px 9px;
        border-radius: 8px;
        border: none;
        background-color: rgb(237, 237, 239);
        font-size: 13px;
    }

    .students-header ul,
    .student-list ul {
        display: grid;
        grid-template-columns: 1.8fr 1fr 1fr 1.5fr 1.5fr 1.5fr 1.2fr;
        list-style: none;
        font-size: 18px;
        padding: 10px 10px;
        align-items: center;
        gap: 8px;
    }

    .students-header ul {
        background-color: #b1e6f4;
        border-radius: 7px 7px 0px 0px;
        font-size: 20px;
        color: rgb(70, 66, 66);
    }

    .students-header ul li {
        margin-top: 15px;
    }

    .student-list ul {
        background-color: white;
        border-bottom: 1px solid #ddd;
        padding: 15px 10px;
    }

    .student-list ul:hover {
        background-color: rgb(231, 194, 219);
    }

    .student-list ul li {
        list-style: none;
        word-break: break-word;
    }

    .icons {
        display: flex;
        gap: 12px;
        align-items: center;
        cursor: pointer;
    }

    .status {
        display: inline-flex;
        align-items: center;
        padding: 6px 8px;
        border-radius: 20px;
        font-size: 14px;
        font-weight: 500;
        gap: 8px;
        width: 100px;
        border: none;
        outline: none;
    }

    .status.paid {
        background-color: #e0f8f1;
        color: #1aaa55;
        font-size: 18px;
    }

    .status.pending {
        background-color: #fff1e5;
        color: #e67817;
        font-size: 18px;
        cursor: pointer;
    }

    .status .dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background-color: currentColor;
    }

    .year-dropdown {
        position: absolute;
        right: 20px;
        top: 20px;
        padding: 7px 10px;
        font-size: 14px;
    }

    .table-wrapper {
        display: block;
        width: 100%;
        overflow-x: auto !important;
        overflow-y: hidden;
        border-radius: 8px;
        scrollbar-width: thin;
    }

    .table-wrapper::-webkit-scrollbar {
        height: 6px;
    }

    .table-wrapper::-webkit-scrollbar-thumb {
        background: #bbbbbb;
        border-radius: 50px;
    }

    .students-header ul,
    .student-list ul {
        min-width: 950px !important;
    }

    @media (max-width:1300px) and (min-width:900px) {
        .fees-page {
            margin-left: 280px !important;
            width: calc(100% - 280px) !important;
        }
    }

    @media (max-width:1400px) {
        .fees-card {
            flex-direction: column !important;
            align-items: center !important;
        }

        .fees-graph {
            width: 95% !important;
            margin: 20px auto !important;
        }

        .boxes {
            width: 95%;
            grid-template-columns: 1fr 1fr 1fr 1fr;
            justify-items: center;
            align-items: center;
            margin: 0 auto;
        }

        .box {
            width: 200px;
            height: 170px;
            margin: 0px 4px;
        }
    }

    @media(max-width:1125px) {
        .boxes {
            width: 95% !important;
            grid-template-columns: 1fr 1fr;
            margin: 0 20px;
            gap: 20px;
        }

        .box {
            width: 250px;
            height: 200px;
        }
    }

    @media(max-width:900px) {
        .fees-page {
            width: 100% !important;
            margin-left: 0 !important;
        }

        .fees-card {
            flex-direction: column !important;
            width: 100%;
            align-items: center;
        }

        .fees-graph {
            width: 100% !important;
            max-width: 100% !important;
            margin: 20px auto !important;
        }

        #feesLineChart {
            height: 340px !important;
        }

        .year-dropdown {
            right: 15px;
            top: 15px;
            font-size: 13px;
            padding: 6px 8px;
        }

        .boxes {
            width: 100%;
            justify-items: center;
            padding: 10px 0;
        }

        .fees-collection-data {
            width: 95% !important;
            margin: 20px auto !important;
        }
    }

    @media(max-width:815px) {
        .fees-header {
            flex-direction: column;
            gap: 15px;
            align-items: center;
            text-align: center;
        }

        .fees-header form {
            flex-wrap: wrap;
            justify-content: center;
        }

        .search-stud {
            width: 100%;
            justify-content: center;
        }

        .dropdown {
            width: 140px;
            font-size: 13px;
            padding: 6px 5px;
        }
    }

    @media(max-width:700px) {
        .boxes {
            grid-template-columns: 1fr;
        }

        .box {
            width: 90% !important;
            height: 160px;
            margin: 12px auto !important;
        }

        .box h1 {
            margin-top: 45px !important;
            font-size: 28px;
        }

    }

    @media (max-width: 600px) {
        #feesLineChart {
            height: 300px !important;
        }

        .year-dropdown {
            right: 10px;
            top: 12px;
            font-size: 12px;
            padding: 5px 7px;
        }
    }



    @media (max-width: 480px) {
        #feesLineChart {
            width: 100% !important;
            height: 300px !important;
        }

        .status {
            gap: 2px;
        }

        .status .dot {
            width: 6px;
            height: 6px;
        }
    }

    @media (max-width: 380px) {
        #feesLineChart {
            height: 260px !important;
        }

        .year-dropdown {
            right: 8px;
            top: 10px;
            font-size: 11px;
            padding: 4px 6px;
        }

    }

    .fees-graph canvas {
        display: block;
        box-sizing: border-box;
    }

    .pdf-btn {
        display: flex;
        justify-content: center;
        align-items: center;
        margin-top: 15px;
        margin-bottom: 15px;
    }

    .print-btn {
        padding: 10px 15px;
        border-radius: 8px;
        border: none;
        font-size: 14px;
        background-color: rgb(66, 154, 242);
        color: white;

    }
    .print-report-title{
    display: none;
}

    @media print {
        body {
            background: white !important;
            -webkit-print-color-adjust: exact !important;
            print-color-adjust: exact !important;
            font-size: 12px;
        }
         .print-report-title{
        display: block !important;
        text-align: center;
        font-size: 20px;
        font-weight: bold;
        margin-bottom: 20px;
        color: black !important;
    }

        /* 1. Hide Unwanted Elements */
        .menu-section,
        .hamburger,
        .no-print,
        .fees-card,
        .fees-header,
        .pdf-btn,
        .notification-wrapper,
        .notification-icon-btn,
        .notification-dropdown,
        .dot {
            display: none !important;
        }

        .fees-page {
            width: 100% !important;
            margin: 0 !important;
            padding: 0 !important;
            box-shadow: none !important;
            margin-left: 0 !important;
            background: white !important;
        }

        .fees-collection-data {
            width: 100% !important;
            margin: 0 !important;
            box-shadow: none !important;
            padding: 10px 0 !important;
            border: none !important;
        }

        .table-wrapper {
            overflow: visible !important;
            display: block !important;
        }

        /* 3. FIX THE GRID Columns (Matching your desktop layout) */
        .students-header ul,
        .student-list ul {
            min-width: 100% !important;
            padding: 8px 0 !important;
            font-size: 12px !important;
            gap: 5px !important;
            /* border-bottom: 1px solid #ddd; */
            align-items: center;
        }

        .students-header ul {
            font-weight: bold;
            color: black !important;
            -webkit-print-color-adjust: exact;
        }

        /* 5. Prevent Row Breaking */
        .student-wrapper {
            page-break-inside: avoid;
            page-break-after: auto;
        }

        .student-list ul li {
            white-space: nowrap;
            /* Prevent text wrapping if needed */
        }
    }
</style>

<body>
    <div class="admin_dash">

        <%- include("partials/AdminPageSidebar") %>

            <div class="fees-page">

                <%- include("partials/adminNotification", { admin: admin }) %>

                    <div class="fees-card">
                        <div class="fees-graph">

                            <h2>Fees Collection</h2>
                            <form method="GET" action="/school_fees_collection">
                                <!--Year dropdown  -->
                                <select name="year" onchange="this.form.submit()" class="select_class year-dropdown">
                                    <% availableYears.forEach(yr=> { %>
                                        <option value="<%= yr %>" <%=selectedYear===yr ? "selected" : "" %>>
                                            <%= yr %> - <%= yr + 1 %>
                                        </option>
                                        <% }) %>
                                </select>
                            </form>

                            <canvas id="feesLineChart"></canvas>
                        </div>
                        <div class="boxes">
                            <div class="box box1">
                                <h1>₹<%= totalAmount.toLocaleString('en-IN') %>
                                </h1>
                                <p>Total Amount</p>
                            </div>
                            <div class="box box2">
                                <h1>₹<%= totalProfit.toLocaleString('en-IN') %>
                                </h1>
                                <p>Total Profit</p>
                            </div>
                            <div class="box box3">
                                <h1>₹<%= totalReceived.toLocaleString('en-IN') %>
                                </h1>
                                <p>Total Received</p>
                            </div>
                            <div class="box box4">
                                <h1>₹<%= totalPending.toLocaleString('en-IN') %>
                                </h1>
                                <p>Total Pending</p>
                            </div>
                        </div>
                    </div>

                    <div class="fees-collection-data">

                        <h4 class="print-report-title">
                            <%= classFilter && classFilter !=="All Classes" ? `Class : ${classFilter} Fees Collection Report`
                                : "All Classes Fees Collection Report" %>
                        </h4>
                        <div class="fees-header">
                            <h2>Fees Collection</h2>


                            <form method="GET" action="/school_fees_collection" style="display: flex; gap: 10px;">
                                <div class="search-stud">
                                    <i class="fa fa-search"></i>
                                    <input type="text" name="search" id="searchInput"
                                        placeholder="Search by Name or ID">

                                </div>

                                <!-- Class Dropdown -->
                                <select name="classFilter" onchange="this.form.submit()" class="select_class dropdown">
                                    <% sortedClasses.forEach(c=> { %>
                                        <option value="<%= c %>" <%=classFilter===c ? "selected" : "" %>><%= c %>
                                        </option>
                                        <% }) %>
                                </select>

                                <!-- Status Dropdown -->
                                <select name="statusFilter" onchange="this.form.submit()" class="select_class dropdown"
                                    style="margin-left: 5px;">
                                    <% ["All Status", "Paid" , "Pending" ].forEach(status=> { %>
                                        <option value="<%= status %>" <%=statusFilter===status ? "selected" : "" %>><%=
                                                status %>
                                        </option>
                                        <% }) %>
                                </select>
                            </form>

                        </div>
                        <div class="table-wrapper">

                            <div class="students-header">
                                <ul>
                                    <li>Student Name</li>
                                    <li>ID</li>
                                    <li>Class</li>
                                    <li>Total Fees</li>
                                    <li>Paid Fees</li>
                                    <li>Remaining Fees</li>
                                    <li>Status</li>
                                </ul>
                            </div>

                            <div class="student-list">
                                <% students.forEach(student=> { %>

                                    <div class="student-wrapper" data-name="<%= student.name.toLowerCase() %>"
                                        data-id="<%= student.id %>">
                                        <ul>
                                            <li style="cursor: pointer;">
                                                <a href="/fee-status/<%= student._id %>"
                                                    style="text-decoration: none; color: inherit;">
                                                    <%= student.name %>
                                                </a>
                                            </li>
                                            <li>
                                                <%= student.id %>
                                            </li>
                                            <li>
                                                <%= student.class %>
                                            </li>

                                            <li>₹<%= student.fees.toLocaleString('en-IN') %>
                                            </li>
                                            <li>₹<%= student.paidFees.toLocaleString('en-IN') %>
                                            </li>
                                            <li>₹<%= student.remainingFees.toLocaleString('en-IN') %>
                                            </li>

                                            <li>
                                                <% if (student.overallStatus==="Paid" ) { %>
                                                    <span class="status paid"><span class="dot"></span> Paid</span>
                                                    <% } else { %>
                                                        <span class="status pending"><span class="dot"></span>
                                                            Pending</span>
                                                        <% } %>
                                            </li>


                                        </ul>
                                    </div>
                                    <% }) %>
                            </div>

                        </div>

                        <div class="pdf-btn">
                            <button onclick="window.print()" class="print-btn no-print">
                                Download PDF
                            </button>
                        </div>

                    </div>
            </div>
    </div>
    <%- include("../partials/app-back-handler") %>
</body>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    const monthlyData = JSON.parse('<%- JSON.stringify(monthlyCollection) %>');
</script>

<script src="/feesCollection.js"></script>


</html>