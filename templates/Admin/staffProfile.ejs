<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Staff Profile</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.css" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.js"></script>

    <style>
        :root {
            --bg: #f0f4ff;
            --card-bg: #ffffff;
            --primary: #4361ee;
            --primary-dark: #2f4ac2;
            --primary-light: #eef1ff;
            --accent: #7209b7;
            --green: #06d6a0;
            --green-light: #e8fdf7;
            --yellow: #f9c74f;
            --red: #ef476f;
            --muted: #8897ae;
            --text: #1a2342;
            --text-light: #4a5568;
            --border: #e2e8f6;
            --shadow-sm: 0 2px 8px rgba(67, 97, 238, 0.08);
            --shadow-md: 0 8px 24px rgba(67, 97, 238, 0.12);
            --shadow-lg: 0 16px 40px rgba(67, 97, 238, 0.14);
            --radius-lg: 20px;
            --radius-md: 14px;
            --radius-sm: 10px;
            --transition: 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: var(--bg);
            color: var(--text);
        }

        .admin_dash {
            display: flex;
            gap: 24px;
            align-items: flex-start;
            min-height: 100vh;
            padding: 24px;
        }

        .profile-card {
            font-family: "Segoe UI", Arial, sans-serif;
            width: 100%;
            max-width: 1180px;
            margin: 10px auto;
            background: var(--card-bg);
            border-radius: var(--radius-lg);
            box-shadow: 0 12px 30px var(--shadow);
            overflow: hidden;
            display: grid;
            grid-template-columns: 340px 1fr;
            min-height: 680px;
        }

        /* LEFT SECTION */
        .profile-section {
            background: linear-gradient(160deg, #1a2342 0%, #2d3e8c 55%, #4361ee 100%);
            padding: 36px 24px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 20px;
            position: relative;
            overflow: hidden;
        }

        .profile-section::before {
            content: '';
            position: absolute;
            top: -60px;
            right: -60px;
            width: 180px;
            height: 180px;
            background: rgba(255, 255, 255, 0.04);
            border-radius: 50%;
        }

        .profile-section::after {
            content: '';
            position: absolute;
            bottom: -40px;
            left: -40px;
            width: 130px;
            height: 130px;
            background: rgba(255, 255, 255, 0.04);
            border-radius: 50%;
        }

        .image {
            width: 160px;
            height: 160px;
            border-radius: 50%;
            overflow: hidden;
            border: 4px solid rgba(255, 255, 255, 0.35);
            box-shadow: 0 0 0 8px rgba(255, 255, 255, 0.08), 0 16px 32px rgba(0, 0, 0, 0.25);
            background: rgba(255, 255, 255, 0.1);
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            z-index: 1;
            transition: transform var(--transition);
        }

        .image:hover {
            transform: scale(1.03);
        }

        .image img.preview {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .staff-basic {
            text-align: center;
            position: relative;
            z-index: 1;
        }

        .staff-basic h2 {
            font-size: 20px;
            font-weight: 800;
            color: #fff;
            text-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
        }

        .staff-basic p {
            color: rgba(255, 255, 255, 0.8);
            font-size: 15px;
            margin-bottom: 4px;
        }

        .staff-badge {
            display: inline-block;
            margin-top: 8px;
            background: rgba(255, 255, 255, 0.15);
            backdrop-filter: blur(8px);
            color: #fff;
            border: 1px solid rgba(255, 255, 255, 0.25);
            padding: 5px 16px;
            border-radius: 999px;
            font-size: 12px;
            font-weight: 600;
            letter-spacing: 0.5px;
        }

        .upload-actions {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 12px;
            width: 100%;
        }

        .upload-actions button {
            border: none;
            border-radius: 10px;
            padding: 11px 16px;
            cursor: pointer;
            font-size: 14px;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: 0.2s;
        }

        #chooseBtn {
            background: #fff;
            color: #24313a;
            border: 1px solid #dbe3f0;
        }

        #cameraBtn {
            background: linear-gradient(90deg, var(--primary), #6ea2ff);
            color: white;
        }

        .left-meta {
            width: 100%;
            position: relative;
            z-index: 1;
            display: flex;
            flex-direction: column;
            gap: 0;
            background: rgba(255, 255, 255, 0.08);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.15);
            border-radius: 14px;
            overflow: hidden;
        }

        .meta-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 11px 16px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.08);
            font-size: 13px;
            transition: background var(--transition);
        }

        .meta-item span:first-child {
            color: rgba(255, 255, 255, 0.72);
            font-weight: 500;
        }

        .meta-item span:last-child {
            color: #ffffff;
            font-weight: 700;
        }

        /* RIGHT SECTION */
        .details {
            padding: 34px 36px;
            display: flex;
            flex-direction: column;
            gap: 18px;
        }

        .details-header h1 {
            font-size: 30px;
            color: #172033;
        }

        .subtitle {
            color: var(--muted);
            font-size: 15px;
        }

        .section-title {
            font-size: 14px;
            font-weight: 700;
            color: var(--primary);
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            gap: 10px;
            text-transform: uppercase;
            letter-spacing: 0.6px;
        }

        .section-title::before {
            content: '';
            width: 4px;
            height: 18px;
            background: linear-gradient(180deg, var(--primary), var(--accent));
            border-radius: 4px;
        }

        .section-divider {
            height: 1px;
            background: linear-gradient(90deg, var(--border), transparent);
            margin: 22px 0;
        }

        .section-subtitle {
            color: var(--muted);
            font-size: 14px;
            margin-bottom: 12px;
        }

        .readonly,
        .edit-form {
            background: linear-gradient(180deg, #fcfdff, #f7faff);
            border: 1px solid #e8eef8;
            border-radius: 16px;
            padding: 22px;
        }

        .info-grid,
        .form-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 12px;
        }

        .info-card {
            background: var(--primary-light);
            border: 1px solid #dde4ff;
            border-radius: var(--radius-sm);
            padding: 13px 16px;
            transition: all var(--transition);
        }

        .info-card:hover {
            border-color: var(--primary);
            box-shadow: 0 4px 12px rgba(67, 97, 238, 0.1);
            transform: translateY(-1px);
        }

        .info-card .label {
            color: var(--primary);
            font-size: 11px;
            font-weight: 600;
            margin-bottom: 5px;
            display: flex;
            align-items: center;
            gap: 6px;
            text-transform: uppercase;
            letter-spacing: 0.4px;
        }

        .info-card .label i {
            color: var(--primary);
            font-size: 11px;
        }

        .info-card .value {
            color: var(--text);
            font-size: 14px;
            font-weight: 700;
        }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .form-group label {
            font-size: 13px;
            font-weight: 700;
            color: #4b5563;
        }

        .edit-form input,
        .edit-form select {
            padding: 12px;
            border-radius: 12px;
            border: 1px solid #ccd7ea;
            outline: none;
            width: 100%;
        }

        /* RIGHT ALIGNED BUTTONS */
        .row-actions {
            display: flex;
            justify-content: flex-end;
            gap: 12px;
            margin-top: 20px;
            padding-top: 18px;
            border-top: 1px solid var(--border);
        }

        .btn {
            border: none;
            border-radius: 12px;
            padding: 11px 22px;
            cursor: pointer;
            font-size: 14px;
            font-weight: 700;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: 0.3s;
        }

        .btn.edit {
            background: linear-gradient(90deg, var(--primary), #6ea2ff);
            color: white;
        }

        .btn.secondary {
            background: #ffffff;
            color: #1f2937;
            border: 1px solid #d5dfef;
        }

        .btn:hover {
            opacity: 0.9;
            transform: translateY(-1px);
        }

        /* CROPPER MODAL */
        #cropModal {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            background: rgba(0, 0, 0, 0.84);
            backdrop-filter: blur(6px);
            display: none;
            justify-content: center;
            align-items: center;
            z-index: 99999;
        }

        .crop-container {
            width: 90%;
            max-width: 380px;
            height: 90%;
            background: #111;
            border-radius: 20px;
            overflow: hidden;
        }

        .crop-footer {
            padding: 16px;
            display: flex;
            gap: 12px;
            background: #111;
        }

        .crop-btn {
            flex: 1;
            padding: 12px;
            border-radius: 12px;
            border: none;
            cursor: pointer;
            font-weight: 700;
        }

        .save-btn {
            background: var(--primary);
            color: white;
        }

        @media (max-width: 1100px) {
            .profile-card {
                grid-template-columns: 1fr;
            }

            .profile-section {
                border-right: none;
                border-bottom: 1px solid #edf2f7;
            }
        }

        @media (max-width: 768px) {

            .admin_dash {
                padding: 12px;
            }

            .details {
                padding: 22px 18px;
            }

            .info-grid,
            .form-grid {
                grid-template-columns: 1fr;
            }

            .info-card[style*="grid-column"],
            .form-group[style*="grid-column"] {
                grid-column: span 1 !important;
            }

            .row-actions {
                flex-direction: column;
            }

            .btn {
                width: 100%;
                justify-content: center;
            }

            .upload-actions {
                flex-direction: column;
                width: 100%;
            }

            .upload-actions button {
                width: 100%;
                justify-content: center;
            }
        }

        @media (max-width:520px) {

            .profile-section {
                padding: 22px 16px;
            }

            .details {
                padding: 18px 14px;
            }

            .readonly,
            .edit-form {
                padding: 16px;
            }
        }
    </style>
</head>

<body>
    <div class="admin_dash">
        <%- include("partials/AdminPageSidebar") %>

            <div class="profile-card">
                <form id="imageForm" method="post" action="/staff/upload-image/<%= staff._id %>"
                    class="profile-section">
                    <input type="hidden" id="croppedImageInput" name="croppedImage">

                    <div class="image">
                        <img id="previewImg" class="preview"
                            src="<%= staff?.photo ? (staff.photo.startsWith('http') ? staff.photo : '/uploads/staffs/' + staff.photo) : '/images/default-profile.png' %>"
                            alt="Staff Profile">
                        <input id="fileInput" type="file" accept="image/*" style="display:none;">
                    </div>

                    <div class="staff-basic">
                        <h2>
                            <%= staff.name %>
                        </h2>
                        <p>
                            <%= staff.category || "Role Not Added" %>
                        </p>
                        <span class="staff-badge">Staff ID: <%= staff.empId || "N/A" %></span>
                    </div>

                    <div class="upload-actions">
                        <button id="chooseBtn" type="button"><i class="fa-regular fa-image"></i> Gallery</button>
                        <button id="cameraBtn" type="button"><i class="fa-solid fa-camera"></i> Camera</button>
                    </div>

                    <div class="left-meta">
                        <div class="meta-item"><span>Phone</span><span>
                                <%= staff.phone || "N/A" %>
                            </span></div>
                        <div class="meta-item"><span>Salary</span><span>₹<%= staff.salary ?
                                    Number(staff.salary).toLocaleString('en-IN') : "0" %></span></div>
                        <div class="meta-item"><span>Category</span><span>
                                <%= staff.category %>
                            </span></div>
                    </div>

                    <div id="cropModal">
                        <div class="crop-container">
                            <div style="color:white; padding:15px; text-align:center;">Adjust Photo</div>
                            <div style="height:300px; background:#000;"><img id="cropImage" style="max-width:100%;">
                            </div>
                            <div class="crop-footer">
                                <button id="cropCancel" type="button" class="crop-btn"
                                    style="background:#333; color:#fff;">Cancel</button>
                                <button id="cropSave" type="button" class="crop-btn save-btn">Save</button>
                            </div>
                        </div>
                    </div>
                </form>

                <div class="details">
                    <div class="details-header">
                        <h1>Staff Profile</h1>
                        <div class="subtitle">View and manage staff details</div>
                    </div>

                    <div class="readonly" id="detailForm">
                        <div class="section-title">Personal Information</div>
                        <div class="section-subtitle">Official staff record details</div>
                        <div class="info-grid">
                            <div class="info-card">
                                <div class="label"><i class="fa-solid fa-user"></i> Full Name</div>
                                <div class="value">
                                    <%= staff.name %>
                                </div>
                            </div>

                            <div class="info-card">
                                <div class="label"><i class="fa-solid fa-user"></i>Gender</div>
                                <div class="value">
                                    <%= staff.gender || 'N/A' %>
                                </div>
                            </div>

                            <div class="info-card">
                                <div class="label"><i class="fa-solid fa-phone"></i> Mobile</div>
                                <div class="value">
                                    <%= staff.phone %>
                                </div>
                            </div>

                            <div class="info-card" style="grid-column: 1 / -1;">
                                <div class="label"><i class="fa-solid fa-location-dot"></i> Address</div>
                                <div class="value">
                                    <%= staff.address %>
                                </div>
                            </div>
                        </div>

                        <div class="section-divider"></div>
                        <div class="section-title">Employment Information</div>
                        <div class="info-grid">
                            <div class="info-card">
                                <div class="label"><i class="fa-solid fa-id-badge"></i> Employee ID</div>
                                <div class="value">
                                    <%= staff.empId%>
                                </div>
                            </div>
                            <div class="info-card">
                                <div class="label"><i class="fa-solid fa-briefcase"></i> Role/Category</div>
                                <div class="value">
                                    <%= staff.category %>
                                </div>
                            </div>

                            <div class="info-card">
                                <div class="label"><i class="fa-solid fa-money-bill"></i> Salary</div>
                                <div class="value">₹<%= staff.salary %>
                                </div>
                            </div>
                            <div class="info-card">
                                <div class="label"><i class="fa-solid fa-calendar"></i> Joining Date</div>
                                <div class="value">
                                    <%= staff.joiningDate ? new Date(staff.joiningDate).toLocaleDateString('en-GB')
                                        : "N/A" %>
                                </div>
                            </div>
                            <div class="info-card">
                                <div class="label"><i class="fa-solid fa-graduation-cap"></i> Education</div>
                                <div class="value">
                                    <%= staff.education || "N/A" %>
                                </div>
                            </div>

                            <div class="info-card">
                                <div class="label"><i class="fa-solid fa-graduation-cap"></i> Experience</div>
                                <div class="value">
                                    <%= staff.experience || "N/A" %>
                                </div>
                            </div>
                        </div>
                        <% if (staff.category && staff.category.trim().toLowerCase()==="driver" ) { %>

                            <div class="section-divider"></div>

                            <div class="section-title">Driver Information</div>

                            <div class="info-grid">

                                <div class="info-card">
                                    <div class="label">
                                        <i class="fa-solid fa-bus"></i>
                                        Vehicle Type
                                    </div>
                                    <div class="value">
                                        <%= staff.vehicle || "N/A" %>
                                    </div>
                                </div>

                                <div class="info-card">
                                    <div class="label">
                                        <i class="fa-solid fa-hashtag"></i>
                                        Vehicle No
                                    </div>
                                    <div class="value">
                                        <%= staff.vehicleNo || "N/A" %>
                                    </div>
                                </div>

                            </div>

                            <% } %>
                    </div>

                    <form id="profileForm" action="/edit-staff/<%= staff._id %>" method="post" class="edit-form"
                        style="display:none;">
                        <div class="section-title">Edit Staff Details</div>
                        <div class="section-subtitle">Update information and save changes</div>
                        <div class="form-grid">
                            <div class="form-group"><label>Full Name</label><input type="text" name="name"
                                    value="<%= staff.name %>" required></div>
                            <div class="form-group"><label>Gender</label>
                                <select name="gender">
                                    <option value="">Select Gender</option>
                                    <option value="Male" <%=staff.gender==='Male' ? 'selected' : '' %>>Male</option>
                                    <option value="Female" <%=staff.gender==='Female' ? 'selected' : '' %>>Female</option>
                                    <option value="Other" <%=staff.gender==='Other' ? 'selected' : '' %>>Other</option>
                                </select>
                            </div>
                            <div class="form-group"><label>Mobile Number</label><input type="text" name="phone"
                                    value="<%= staff.phone %>" required></div>
                            <div class="form-group"><label>Salary</label><input type="number" name="salary"
                                    value="<%= staff.salary %>" required></div>
                            <div class="form-group"><label>Education</label><input type="text" name="education"
                                    value="<%= staff.education || '' %>"></div>
                            <div class="form-group"><label>Experience</label><input type="text" name="experience"
                                    value="<%= staff.experience || '' %>"></div>
                            <div class="form-group"><label>Joining Date</label><input type="date" name="joiningDate"
                                    value="<%= staff.joiningDate ? new Date(staff.joiningDate).toISOString().split('T')[0] : '' %>">
                            </div>
                            <div class="form-group">
                                <label>Category</label>
                                <select name="category" id="categorySelect" required>
                                    <option value="Accountant" <%=staff.category==="Accountant" ? "selected" :"" %>
                                        >Accountant</option>
                                    <option value="Receptionist" <%=staff.category==="Receptionist" ? "selected" :"" %>
                                        >Receptionist</option>
                                    <option value="Driver" <%=staff.category==="Driver" ? "selected" :"" %>>Driver
                                    </option>
                                    <option value="Cleaner" <%=staff.category==="Cleaner" ? "selected" :"" %>>Cleaner
                                    </option>
                                    <option value="Watchman" <%=staff.category==="Watchman" ? "selected" :"" %>>Watchman
                                    </option>
                                    <option value="Peon" <%=staff.category==="Peon" ? "selected" :"" %>>Peon</option>
                                    <option value="Other" <%=staff.category==="Other" ? "selected" :"" %>>Others
                                    </option>
                                </select>
                            </div>
                            <div id="vehicleFields" class="form-grid" style="display:none; grid-column: 1 / -1;">

                                <div class="form-group">
                                    <label>Vehicle Type</label>
                                    <input type="text" name="vehicle" value="<%= staff.vehicle || '' %>">
                                </div>

                                <div class="form-group">
                                    <label>Vehicle No</label>
                                    <input type="text" name="vehicleNo" value="<%= staff.vehicleNo || '' %>">
                                </div>
                            </div>

                            <div class="form-group"><label>Address</label><input type="text" name="address"
                                    value="<%= staff.address %>" required></div>
                        </div>
                    </form>

                    <div class="row-actions">
                        <button class="btn secondary" id="cancelBtn" type="button" style="display:none;"><i
                                class="fa-solid fa-xmark"></i> Cancel</button>
                        <button class="btn edit" id="editBtn" type="button"><i class="fa-solid fa-pen-to-square"></i>
                            Edit</button>
                        <button class="btn edit" id="saveBtn" type="button" style="display:none;"><i
                                class="fa-solid fa-floppy-disk"></i> Save Changes</button>
                    </div>
                </div>
            </div>
    </div>

    <script>
        const fileInput = document.getElementById('fileInput');
        const preview = document.getElementById('previewImg');
        const chooseBtn = document.getElementById('chooseBtn');
        const cameraBtn = document.getElementById('cameraBtn');
        const cropModal = document.getElementById('cropModal');
        const cropImage = document.getElementById('cropImage');
        const croppedHidden = document.getElementById("croppedImageInput");

        const editForm = document.getElementById('profileForm');
        const detailForm = document.getElementById('detailForm');
        const editBtn = document.getElementById('editBtn');
        const saveBtn = document.getElementById('saveBtn');
        const cancelBtn = document.getElementById('cancelBtn');
        let cropper;

        // Image Upload Logic
        chooseBtn.onclick = () => { fileInput.removeAttribute('capture'); fileInput.click(); };
        cameraBtn.onclick = () => { fileInput.setAttribute('capture', 'environment'); fileInput.click(); };

        fileInput.onchange = (e) => {
            const file = e.target.files[0];
            if (!file) return;
            cropImage.src = URL.createObjectURL(file);
            cropModal.style.display = "flex";
            if (cropper) cropper.destroy();
            cropper = new Cropper(cropImage, { aspectRatio: 1, viewMode: 2 });
        };

        document.getElementById('cropCancel').onclick = () => { cropModal.style.display = "none"; if (cropper) cropper.destroy(); };

        document.getElementById('cropSave').onclick = () => {
            const base64 = cropper.getCroppedCanvas({ width: 600, height: 600 }).toDataURL("image/jpeg");
            preview.src = base64;
            croppedHidden.value = base64;
            cropModal.style.display = "none";
            cropper.destroy();
            // Auto-submit image form if only image is changed
            document.getElementById('imageForm').submit();
        };

        // Toggle Edit Mode
        editBtn.onclick = () => {
            editForm.style.display = 'block';
            detailForm.style.display = 'none';
            editBtn.style.display = 'none';
            saveBtn.style.display = 'inline-flex';
            cancelBtn.style.display = 'inline-flex';
        };

        cancelBtn.onclick = () => {
            editForm.style.display = 'none';
            detailForm.style.display = 'block';
            editBtn.style.display = 'inline-flex';
            saveBtn.style.display = 'none';
            cancelBtn.style.display = 'none';
        };

        saveBtn.onclick = () => {
            editForm.submit();
        };

        const categorySelect = document.getElementById("categorySelect");
        const vehicleFields = document.getElementById("vehicleFields");

        function toggleVehicleFields() {

            if (
                categorySelect.value.toLowerCase() === "driver"
            ) {
                vehicleFields.style.display = "grid";
                vehicleFields.style.gridTemplateColumns = "repeat(2,1fr)";
            } else {
                vehicleFields.style.display = "none";
            }
        }

        toggleVehicleFields();
        categorySelect.addEventListener("change", toggleVehicleFields);
    </script>
    <script src="/backButton.js"></script>

</body>

</html>