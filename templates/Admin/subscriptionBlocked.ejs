<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Access Restricted | School Portal</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        body {
            background-color: #0f172a;
            /* Dark theme jo tumhare dashboard se match karega */
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100vh;
            margin: 0;
            font-family: 'Inter', sans-serif;
            color: white;
        }

        .card {
            text-align: center;
            background: #1e293b;
            padding: 40px;
            border-radius: 20px;
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);
            max-width: 450px;
            border: 1px solid #334155;
        }

        .icon-box {
            font-size: 60px;
            margin-bottom: 20px;
        }

        .status-icon-expired {
            color: #f59e0b;
        }

        /* Orange for expiry */
        .status-icon-inactive {
            color: #ef4444;
        }

        /* Red for suspension */

        h1 {
            margin-bottom: 15px;
            font-size: 26px;
            letter-spacing: -0.5px;
        }

        p {
            color: #94a3b8;
            font-size: 16px;
            line-height: 1.6;
            margin-bottom: 25px;
        }

        .info-box {
            padding: 15px;
            border-radius: 12px;
            font-size: 14px;
            text-align: left;
            display: flex;
            align-items: flex-start;
            gap: 12px;
            margin-bottom: 20px;
        }

        .info-expired {
            background: rgba(245, 158, 11, 0.1);
            color: #fbbf24;
            border: 1px solid rgba(245, 158, 11, 0.2);
        }

        .info-inactive {
            background: rgba(239, 68, 68, 0.1);
            color: #f87171;
            border: 1px solid rgba(239, 68, 68, 0.2);
        }

        .btn-home {
            display: inline-block;
            background: #3b82f6;
            color: white;
            text-decoration: none;
            padding: 12px 25px;
            border-radius: 10px;
            font-weight: 600;
            transition: all 0.3s ease;
        }

        .btn-home:hover {
            background: #2563eb;
            transform: translateY(-2px);
        }

        .contact-text {
            margin-top: 20px;
            font-size: 13px;
            color: #64748b;
        }
    </style>
</head>

<body>

    <div class="card">
        <div class="icon-box">
            <% if (status==='Inactive' ) { %>
                <i class="fa-solid fa-circle-xmark status-icon-inactive"></i>
                <% } else { %>
                    <i class="fa-solid fa-clock-rotate-left status-icon-expired"></i>
                    <% } %>
        </div>

        <h1>
            <% if (status==='Inactive' ) { %>
                Service Suspended
                <% } else { %>
                    Subscription Expired
                    <% } %>
        </h1>

        <p>
            Hello <strong>
                <%= role %>
            </strong>,
            <% if (status==='Inactive' ) { %>
                your portal access has been temporarily suspended by the Super Admin due to administrative reasons.
                <% } else { %>
                    your portal's subscription plan has ended. Access to all tools and records is currently locked.
                    <% } %>
        </p>

        <div class="info-box <%= status === 'Inactive' ? 'info-inactive' : 'info-expired' %>">
            <i class="fa-solid fa-circle-info" style="margin-top: 3px;"></i>
            <span>
                <% if (role==='Admin' ) { %>
                    <% if (status==='Inactive' ) { %>
                        Please contact the Super Admin to resolve the suspension and re-enable your portal.
                        <% } else { %>
                            Please renew your subscription plan by contactiong Super Admin to restore full access.
                            <% } %>
                                <% } else { %>
                                    Kindly contact your <strong>School Administration Office</strong> to restore your
                                    access.
                                    <% } %>
            </span>
        </div>

        <a href="/login" class="btn-home">
            <i class="fa-solid fa-arrow-left"></i> Back to Login
        </a>

        <div class="contact-text">
            For technical support: support@schoolflow.com
        </div>
    </div>
  <%- include("../partials/app-back-handler") %>

</body>

</html>