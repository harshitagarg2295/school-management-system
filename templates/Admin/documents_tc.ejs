<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Generate Transfer Certificate</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

            body {
                background: #f0f4f8;
                min-height: 100vh;
            }

            .admin_dash {
                display: flex;
            }

            .main-section {
                font-family: 'Inter', sans-serif;
                flex: 1;
                /* margin-left: 280px; */
                padding: 30px 35px;
                min-height: 100vh;
            }

            @media (max-width: 900px) {
                .main-section {
                    margin-left: 0;
                    padding: 30px 16px ;
                }
            }

            .page-content {
                max-width: 800px;
                margin: 0 auto;
            }

            .page-header {
                background: linear-gradient(135deg, #e53e3e 0%, #c53030 100%);
                border-radius: 20px;
                padding: 28px 35px;
                color: white;
                margin-bottom: 28px;
                display: flex;
                align-items: center;
                gap: 18px;
            }

            .back-btn {
                background: rgba(255, 255, 255, 0.2);
                border: none;
                color: white;
                width: 40px;
                height: 40px;
                border-radius: 10px;
                cursor: pointer;
                font-size: 16px;
                display: flex;
                align-items: center;
                justify-content: center;
                text-decoration: none;
                transition: background 0.2s;
            }

            .back-btn:hover {
                background: rgba(255, 255, 255, 0.35);
            }

            .page-header h1 {
                font-size: 22px;
                font-weight: 700;
            }

            .page-header p {
                font-size: 13px;
                opacity: 0.85;
                margin-top: 3px;
            }

            .form-card {
                background: white;
                border-radius: 20px;
                padding: 32px 35px;
                box-shadow: 0 2px 15px rgba(0, 0, 0, 0.06);
                margin-bottom: 24px;
            }

            .form-card h2 {
                font-size: 16px;
                font-weight: 700;
                color: #2d3748;
                margin-bottom: 22px;
                padding-bottom: 12px;
                border-bottom: 2px solid #f0f4f8;
                display: flex;
                align-items: center;
                gap: 10px;
            }

            .step-badge {
                width: 26px;
                height: 26px;
                border-radius: 50%;
                background: #e53e3e;
                color: white;
                font-size: 12px;
                font-weight: 700;
                display: inline-flex;
                align-items: center;
                justify-content: center;
            }

            .form-row {
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: 20px;
            }

            @media (max-width: 600px) {
                .form-row {
                    grid-template-columns: 1fr;
                }
            }

            .form-group {
                margin-bottom: 18px;
            }

            .form-group label {
                display: block;
                font-size: 13px;
                font-weight: 600;
                color: #4a5568;
                margin-bottom: 7px;
            }

            .form-group select,
            .form-group input,
            .form-group textarea {
                width: 100%;
                padding: 11px 14px;
                border: 2px solid #e8ecf0;
                border-radius: 10px;
                font-size: 14px;
                font-family: 'Inter', sans-serif;
                color: #2d3748;
                transition: border-color 0.2s;
                background: #fafbfc;
            }

            .form-group textarea {
                resize: vertical;
                min-height: 80px;
            }

            .form-group select:focus,
            .form-group input:focus,
            .form-group textarea:focus {
                outline: none;
                border-color: #e53e3e;
                background: white;
            }

            .btn-generate {
                background: linear-gradient(135deg, #e53e3e, #c53030);
                color: white;
                border: none;
                padding: 13px 30px;
                border-radius: 12px;
                font-size: 15px;
                font-weight: 600;
                cursor: pointer;
                font-family: 'Inter', sans-serif;
                display: inline-flex;
                align-items: center;
                gap: 10px;
                transition: opacity 0.2s;
            }

            .btn-generate:hover {
                opacity: 0.88;
            }

            .filter-btn {
                background: #f0f4f8;
                color: #4a5568;
                border: 2px solid #e8ecf0;
                padding: 11px 20px;
                border-radius: 10px;
                font-size: 14px;
                font-weight: 600;
                cursor: pointer;
                font-family: 'Inter', sans-serif;
            }

            .student-preview {
                background: #fff5f5;
                border: 1.5px solid #fed7d7;
                border-radius: 12px;
                padding: 16px 20px;
                margin-top: 16px;
                display: none;
            }

            .student-preview.show {
                display: block;
            }

            .preview-grid {
                display: grid;
                grid-template-columns: repeat(3, 1fr);
                gap: 12px;
                margin-top: 10px;
            }

            .preview-item label {
                font-size: 11px;
                color: #718096;
                font-weight: 600;
                text-transform: uppercase;
            }

            .preview-item span {
                display: block;
                font-size: 14px;
                color: #2d3748;
                font-weight: 500;
                margin-top: 2px;
            }
    </style>
</head>

<body>
    <div class="admin_dash">
        <%- include("partials/AdminPageSidebar") %>
            <section class="main-section">
                <!-- <%- include("partials/adminNotification", { admin: admin }) %> -->
                    <div class="page-content">

                        <div class="page-header">
                            <a href="/admin/documents" class="back-btn"><i class="fa-solid fa-chevron-left"></i></a>
                            <div>
                                <h1>📋 Transfer Certificate</h1>
                                <p>Generate a formal school leaving certificate for a student</p>
                            </div>
                        </div>

                        <!-- STEP 1: Filter -->
                        <div class="form-card">
                            <h2><span class="step-badge">1</span> Select Class</h2>
                            <form method="GET" action="/admin/documents/tc">
                                <div class="form-group">
                                    <label>Class</label>
                                    <select name="class" required>
                                        <option value="">— Select Class —</option>
                                        <% allClasses.forEach(cls=> { %>
                                            <option value="<%= cls %>" <%=selectedClass===cls ? 'selected' : '' %>><%=
                                                    cls %>
                                            </option>
                                            <% }) %>
                                    </select>
                                </div>
                                <button type="submit" class="filter-btn"><i class="fa-solid fa-filter"></i> Filter
                                    Students</button>
                            </form>
                        </div>

                        <% if (students.length> 0) { %>
                            <!-- STEP 2 -->
                            <div class="form-card">
                                <h2><span class="step-badge">2</span> TC Details</h2>
                                <form method="POST" action="/admin/documents/tc/generate" target="_blank">
                                    <div class="form-row">
                                        <div class="form-group">
                                            <label>Student</label>
                                            <select name="studentId" id="studentSelect" required
                                                onchange="showStudentPreview(this)">
                                                <option value="">— Select Student —</option>
                                                <% students.forEach(s=> { %>
                                                    <option value="<%= s._id %>" data-name="<%= s.studentName %>"
                                                        data-class="<%= s.class %>" data-section="<%= s.section %>"
                                                        data-father="<%= s.fatherName || '' %>"
                                                        data-dob="<%= s.DOB ? new Date(s.DOB).toLocaleDateString('en-IN') : '' %>"
                                                        data-admission="<%= s.admissionNo || '' %>">
                                                        <%= s.studentName %> — <%= s.class %>
                                                                <%= s.section %>
                                                    </option>
                                                    <% }) %>
                                            </select>
                                        </div>
                                        <div class="form-group">
                                            <label>TC Number</label>
                                            <input type="text" name="tcNumber" placeholder="e.g. TC-2024-001">
                                        </div>
                                    </div>

                                    <div id="studentPreviewBox" class="student-preview">
                                        <strong style="font-size:13px; color:#c53030;">Student Information (auto-filled
                                            in
                                            TC)</strong>
                                        <div class="preview-grid">
                                            <div class="preview-item"><label>Name</label><span id="prev-name">—</span>
                                            </div>
                                            <div class="preview-item"><label>Class</label><span id="prev-class">—</span>
                                            </div>
                                            <div class="preview-item"><label>Father's Name</label><span
                                                    id="prev-father">—</span></div>
                                            <div class="preview-item"><label>Date of Birth</label><span
                                                    id="prev-dob">—</span></div>
                                            <div class="preview-item"><label>Admission No</label><span
                                                    id="prev-adm">—</span></div>
                                        </div>
                                    </div>

                                    <div class="form-row" style="margin-top:18px;">
                                        <div class="form-group">
                                            <label>Date of Leaving</label>
                                            <input type="date" name="dateOfLeaving" required>
                                        </div>
                                        <div class="form-group">
                                            <label>Last Exam Passed</label>
                                            <input type="text" name="lastExamPassed"
                                                placeholder="e.g. Class 9 Annual Exam 2024">
                                        </div>
                                    </div>
                                    <div class="form-row">
                                        <div class="form-group">
                                            <label>Conduct</label>
                                            <select name="conduct">
                                                <option value="Excellent">Excellent</option>
                                                <option value="Good" selected>Good</option>
                                                <option value="Satisfactory">Satisfactory</option>
                                                <option value="Fair">Fair</option>
                                            </select>
                                        </div>
                                        <div class="form-group">
                                            <label>Reason for Leaving</label>
                                            <input type="text" name="reasonForLeaving"
                                                placeholder="e.g. Parents transferred to another city">
                                        </div>
                                    </div>

                                    <button type="submit" class="btn-generate">
                                        <i class="fa-solid fa-file-pdf"></i> Generate TC PDF
                                    </button>
                                </form>
                            </div>
                            <% } %>
            </section>
    </div>
    <script>
        function showStudentPreview(sel) {
            const opt = sel.selectedOptions[0];
            const box = document.getElementById('studentPreviewBox');
            if (!opt.value) { box.classList.remove('show'); return; }
            document.getElementById('prev-name').textContent = opt.dataset.name || '—';
            document.getElementById('prev-class').textContent = (opt.dataset.class + ' ' + opt.dataset.section) || '—';
            document.getElementById('prev-father').textContent = opt.dataset.father || '—';
            document.getElementById('prev-dob').textContent = opt.dataset.dob || '—';
            document.getElementById('prev-adm').textContent = opt.dataset.admission || '—';
            box.classList.add('show');
        }
    </script>
</body>

</html>