<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin: Teacher Attendance</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">

    <style>
        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            background-color: #f1f1f1;
            overflow-x: hidden;
        }

        /* --- LAYOUT --- */
        .admin_dash {
            display: flex;
            width: 100%;
        }

        .attendance_card {
            font-family: sans-serif;
            flex: 1;
            margin: 20px;
            border-radius: 8px;
            background-color: white;
            padding: 30px 35px;
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.05);
            width: auto;
            overflow: hidden;
        }

        /* --- HEADERS --- */
        .headers {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 15px;
            margin-top: 10px;
        }

        .headers h1 {
            margin: 0;
            font-size: 26px;
        }

        .search-teach {
            display: flex;
            align-items: center;
            position: relative;
        }

        .search-teach i {
            position: absolute;
            left: 10px;
            color: gray;
        }

        .search-teach input {
            padding: 10px 10px 10px 35px;
            border-radius: 20px;
            border: 1px solid grey;
            font-size: 15px;
            outline: none;
            width: 100%;
        }

        /* --- DATE & HOLIDAY --- */
        .date_month_year {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 30px;
            flex-wrap: wrap;
            gap: 20px;
        }

        .btn,
        .select-box {
            padding: 6px 10px;
            border-radius: 6px;
            border: 1px solid #cfd6dd;
            font-size: 14px;
        }

        .save_month_year {
            padding: 7px 18px;
            background: #4fa3f7;
            color: white;
            border: none;
            border-radius: 6px;
            font-size: 15px;
            cursor: pointer;
        }

        .save_month_year:hover {
            background: #2f8ae2;
        }

        .attendance_table {
            overflow-x: auto;
            margin-top: 30px;
            padding-bottom: 20px;
            width: 100%;
            scrollbar-width: thin;
            scrollbar-color: #b4b4b4 #f1f1f1;
        }

        .attend_list_header,
        .attend_list {
            min-width: 100%;
            width: max-content;
            display: flex;
            align-items: center;
        }

        .list ul {
            list-style: none;
            display: flex;
            padding: 0;
            margin: 0;
            align-items: center;
        }

        /* HEADER ROW */
        .attend_list_header {
            background-color: #b1e6f4;
            border-radius: 7px 7px 0 0;
            border: 1px solid rgb(186, 185, 185);
            border-bottom: none;
            height: 60px;
        }

        /* DATA ROW */
        .attend_list {
            border: 1px solid rgb(186, 185, 185);
            border-top: none;
            background: white;
            height: 70px;
        }

        .attend_list:last-child {
            border-radius: 0 0 7px 7px;
        }

        /* --- STICKY NAME COLUMN --- */
        .teachers_name {
            position: sticky;
            left: 0;
            width: 200px;
            min-width: 200px;
            z-index: 10;
            border-right: 1px solid #ddd;
            padding: 0 10px;
            font-weight: 600;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            height: 100%;
        }

        .attend_list_header .teachers_name {
            background-color: #b1e6f4;
            z-index: 20;
            border-radius: 7px 0 0 0;
            padding: 10px;
        }

        .attend_list .teachers_name {
            background-color: white;
            padding: 10px;
        }


        .list ul li:not(.teachers_name) {
            width: 65px;
            min-width: 65px;
            text-align: center;
            flex-shrink: 0;
        }

        .dropdown-wrapper {
            position: relative;
            width: 28px;
            height: 28px;
            display: inline-block;
        }

        .dropdown-wrapper:hover {
            border-color: #429af2;
        }

        .attendance_dropdown {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            appearance: none;
            text-align: center;
            -webkit-appearance: none;
            -moz-appearance: none;
            border: 1px solid #ccc;
            cursor: pointer;
        }

        .custom-arrow {
            font-size: 12px;
            color: rgb(34, 33, 33);
            position: absolute;
            right: 8px;
            top: 50%;
            transform: translateY(-50%);
            pointer-events: none;
        }

        /* --- ICONS & BADGES --- */
        img.status-icon {
            width: 30px;
            height: 30px;
            cursor: pointer;
            border-radius: 50%;
        }

        .holiday-cell {
            background-color: #b1e6f4;
            border-radius: 5px;
            width: 35px !important;
            height: 25px !important;
            display: flex;
            justify-content: center;
            align-items: center;
            margin: 0 auto;
        }

        .today-cell {
            background-color: rgb(89, 165, 240);
            border-radius: 5px;
            color: white;
            padding: 5px 0;
        }

        /* Extra Columns */
        .extra-col {
            width: 110px !important;
            min-width: 110px !important;
            font-size: 14px;
            text-align: center;
            border-left: 1px solid #eee;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            height: 100%;
        }

        .header-extra {
            font-weight: 600;
            line-height: 1.2;
        }

        /* Payment Status */
        .status {
            padding: 5px 10px;
            border-radius: 15px;
            font-size: 13px;
            font-weight: 500;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 5px;
        }

        .status.paid {
            background: #e0f8f1;
            color: #1aaa55;
        }

        .status.pending {
            background: #fff1e5;
            color: #e67817;
        }

        .status .dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: currentColor;
        }

        .payment_dropdown {
            padding: 2px;
            margin-top: 5px;
        }

        .holiday-popup {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.5);
            justify-content: center;
            align-items: center;
            z-index: 9999;
        }

        .holiday-card {
            background: #fff;
            padding: 20px 30px;
            border-radius: 12px;
            text-align: center;
            box-shadow: 0 6px 18px rgba(0, 0, 0, 0.2);
            max-width: 350px;
            width: 90%;
        }

        .holiday-card h3 {
            margin-bottom: 10px;
            color: #429af2;
        }

        .holiday-card p {
            margin-bottom: 15px;
            font-size: 18px;
            color: #333;
        }

        .holiday-card button {
            background: #429af2;
            border: none;
            color: white;
            padding: 8px 15px;
            border-radius: 6px;
            cursor: pointer;
        }

        .holiday-card button:hover {
            background: #2f7bdc;
        }

        /* BACKDROP */
        .bio-modal {
            display: none;
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100%;
            background: rgba(10, 15, 40, 0.7);
            backdrop-filter: blur(6px);
            justify-content: center;
            align-items: center;
            z-index: 9999;
        }
        .bio-modal.active { display: flex; }

        .bio-modal-content {
            width: 460px;
            max-width: 96vw;
            background: #fff;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 20px 60px rgba(0,0,0,0.25);
            animation: popupShow 0.25s ease;
        }
        .bio-modal-header {
            background: linear-gradient(135deg, #1e3a8a, #2563eb);
            padding: 20px 24px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }
        .bio-modal-header h2 {
            margin: 0;
            color: #fff;
            font-size: 18px;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .bio-close-x {
            background: rgba(255,255,255,0.15);
            border: none;
            color: #fff;
            width: 32px; height: 32px;
            border-radius: 50%;
            cursor: pointer;
            font-size: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: background 0.2s;
        }
        .bio-close-x:hover { background: rgba(255,255,255,0.3); }
        .bio-modal-body { padding: 24px; }
        .bio-sample-bar {
            background: #eff6ff;
            border: 1px solid #bfdbfe;
            border-radius: 10px;
            padding: 10px 14px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 16px;
            font-size: 13px;
            color: #1e40af;
        }
        .bio-sample-bar a {
            background: #2563eb;
            color: #fff;
            padding: 6px 14px;
            border-radius: 8px;
            text-decoration: none;
            font-size: 12px;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            transition: opacity 0.2s;
        }
        .bio-sample-bar a:hover { opacity: 0.85; }
        .bio-format-info {
            background: #f8fafc;
            border: 1px dashed #cbd5e1;
            border-radius: 10px;
            padding: 10px 14px;
            font-size: 12px;
            color: #64748b;
            margin-bottom: 16px;
            line-height: 1.8;
        }
        .bio-format-info strong { color: #334155; }
        .bio-drop-zone {
            border: 2px dashed #93c5fd;
            border-radius: 12px;
            padding: 24px;
            text-align: center;
            background: #f0f9ff;
            cursor: pointer;
            transition: all 0.2s;
            margin-bottom: 16px;
            position: relative;
        }
        .bio-drop-zone.dragover { border-color: #2563eb; background: #dbeafe; }
        .bio-drop-zone input[type=file] { position: absolute; inset: 0; opacity: 0; cursor: pointer; }
        .bio-drop-icon { font-size: 28px; margin-bottom: 8px; color: #60a5fa; }
        .bio-drop-text { font-size: 13px; color: #475569; }
        .bio-drop-text strong { color: #1d4ed8; }
        .bio-file-name { margin-top: 8px; font-size: 12px; color: #2563eb; font-weight: 600; min-height: 18px; }
        .bio-buttons { display: flex; gap: 10px; }
        .bio-upload-btn {
            flex: 1;
            background: linear-gradient(135deg, #1d4ed8, #2563eb);
            padding: 11px 18px;
            color: white;
            border: none;
            border-radius: 10px;
            font-weight: 700;
            font-size: 14px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            transition: opacity 0.2s;
        }
        .bio-upload-btn:hover { opacity: 0.9; }
        .bio-upload-btn:disabled { opacity: 0.55; cursor: not-allowed; }
        .bio-cancel-btn {
            background: #f1f5f9;
            padding: 11px 18px;
            border: 1px solid #e2e8f0;
            border-radius: 10px;
            cursor: pointer;
            font-weight: 600;
            font-size: 14px;
            transition: background 0.2s;
        }
        .bio-cancel-btn:hover { background: #e2e8f0; }
        .bio-processing { text-align: center; padding: 30px 24px; }
        .bio-spinner {
            width: 48px; height: 48px;
            border: 4px solid #dbeafe;
            border-top-color: #2563eb;
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
            margin: 0 auto 16px;
        }
        @keyframes spin { to { transform: rotate(360deg); } }
        .bio-processing p { color: #475569; font-size: 14px; font-weight: 600; margin: 0; }
        .bio-result { padding: 24px; text-align: center; }
        .bio-result-icon {
            width: 60px; height: 60px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 28px;
            margin: 0 auto 16px;
        }
        .bio-result-icon.success { background: #dcfce7; color: #16a34a; }
        .bio-result-icon.error { background: #fee2e2; color: #dc2626; }
        .bio-result h3 { font-size: 18px; font-weight: 700; margin: 0 0 8px; }
        .bio-result-date {
            display: inline-block;
            background: #eff6ff;
            color: #1d4ed8;
            border-radius: 20px;
            padding: 3px 14px;
            font-size: 13px;
            font-weight: 600;
            margin-bottom: 16px;
        }
        .bio-stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin-bottom: 18px; }
        .bio-stat { background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 10px; padding: 10px 6px; }
        .bio-stat .num { font-size: 22px; font-weight: 800; }
        .bio-stat .lbl { font-size: 11px; color: #64748b; font-weight: 500; }
        .bio-stat.p .num { color: #16a34a; }
        .bio-stat.l .num { color: #d97706; }
        .bio-stat.a .num { color: #dc2626; }
        .bio-result-actions { display: flex; gap: 10px; justify-content: center; }
        .bio-btn-primary { background: linear-gradient(135deg, #1d4ed8, #2563eb); color: #fff; border: none; border-radius: 10px; padding: 10px 22px; font-weight: 700; cursor: pointer; font-size: 14px; }
        .bio-btn-secondary { background: #f1f5f9; border: 1px solid #e2e8f0; border-radius: 10px; padding: 10px 22px; font-weight: 600; cursor: pointer; font-size: 14px; }
        .bio-error-msg { background: #fef2f2; border: 1px solid #fecaca; color: #b91c1c; border-radius: 10px; padding: 12px 16px; font-size: 13px; margin-bottom: 16px; text-align: left; }
        @keyframes popupShow { from { transform: scale(0.88); opacity: 0; } to { transform: scale(1); opacity: 1; } }

        /* --- RESPONSIVE --- */
        @media (max-width: 992px) {
            .attendance_card {
                margin: 10px;
                padding: 15px;
            }

            .teachers_name {
                width: 150px;
                min-width: 150px;
                font-size: 14px;
            }

            .headers {
                padding: 25px 30px;
            }

        }

        @media (max-width: 768px) {
            .admin_dash {
                flex-direction: column;
            }

            .attendance_card {
                width: 100%;
                margin: 0;
                border-radius: 0;
            }

            .date_month_year {
                flex-direction: column;
                align-items: stretch;
            }

            .extra-col {
                width: 90px !important;
                min-width: 90px !important;
                font-size: 12px;
            }
        }

        .print-btn {
            padding: 10px 30px;
            border-radius: 6px;
            border: none;
            font-size: 18px;
            background-color: rgb(66, 154, 242);
            color: white;
            cursor: pointer;
        }

        .print-btn:hover {
            background-color: #2f8ae2;
        }

        .print-header {
            display: none;
        }


        @media print {

            @page {
                size: landscape;
                margin: 8mm;
            }

            body {
                background: white !important;
                -webkit-print-color-adjust: exact !important;
                font-size: 10px !important;
                font-family: sans-serif;
                overflow: visible !important;
            }

            /* 1. HIDE EVERYTHING UNNECESSARY */
            .menu-section,
            .hamburger,
            .headers,
            .date_month_year,
            .bio-modal,
            .holiday-popup,
            .button-container,
            .search-teach,
            .payment_dropdown {
                display: none !important;
            }

            .print-header {
                display: block !important;
                width: 100% !important;
                margin-bottom: 25px !important;
            }

            .print-main-title {
                font-size: 26px !important;
                font-weight: bold !important;
                margin: 0 !important;
                color: black !important;
            }

            .print-month-title {
                font-size: 16px !important;
                font-weight: normal !important;
                margin-top: 5px !important;
                color: #555 !important;
            }

            .attendance_card,
            .attendance_table {
                display: block !important;
                width: 100% !important;
                margin: 0 !important;
                padding: 0 !important;
                box-shadow: none !important;
                overflow: visible !important;
                width: max-content !important;
                border: none !important;
            }

            .attend_list_header,
            .attend_list {
                display: flex !important;
                width: 100% !important;
                min-width: 100% !important;
                justify-content: flex-start;
                border: none !important;
                page-break-inside: avoid !important;
            }

            .attend_list_header {
                height: 60px !important;
                background-color: #ddd !important;
                border-bottom: 2px solid #000 !important;
            }

            .attend_list {
                height: 25px !important;
                border-bottom: 1px solid #ccc !important;
            }

            .attend_list ul,
            .attend_list_header ul {
                display: flex !important;
                width: 100% !important;
                padding: 0 !important;
                margin: 0 !important;
            }

            .list ul li {
                display: flex !important;
                align-items: center;
                justify-content: center;
                border-right: 1px solid #999 !important;
                border-left: 1px solid #999 !important;
                height: 100% !important;
                padding: 0 2px !important;
                box-sizing: border-box !important;
                flex-shrink: 0 !important;
            }

            .teachers_name {
                position: static !important;
                width: 180px !important;
                min-width: 180px !important;
                justify-content: flex-start !important;
                padding-left: 8px !important;
                font-weight: bold !important;
                text-align: left !important;
                background: white !important;
                color: black !important;
                border-right: 2px solid #000 !important;
            }

            .attend_list_header .teachers_name {
                background-color: #ddd !important;
            }

            .list ul li:not(.teachers_name):not(.extra-col) {
                width: 20px !important;
                min-width: 20px !important;
                flex-grow: 1;
                font-size: 9px !important;
            }

            .attend_list_header ul li:not(.teachers_name):not(.extra-col) {
                writing-mode: horizontal-tb !important;
                height: 100% !important;
                white-space: nowrap;
                border: none !important;
            }

            img.status-icon {
                width: 14px !important;
                height: 14px !important;
                display: block !important;
                margin: auto !important;
                object-fit: contain !important;
            }

            .holiday-cell {
                background-color: #eee !important;
                width: 100% !important;
                height: 100% !important;
            }

            /* Dropdowns chupana */
            .dropdown-wrapper,
            .custom-arrow {
                display: none !important;
            }

            /* 8. EXTRA COLUMNS (Salary etc) */
            .extra-col {
                width: 65px !important;
                min-width: 65px !important;
                font-size: 9px !important;
                flex-direction: column;
                line-height: 1.1;
            }

            /* Page Break Prevention */
            .teacher-row {
                break-inside: avoid;
                page-break-inside: avoid;
            }

            .status {
                padding: 5px 5px;
                border-radius: 7px;
                font-size: 10px;
                font-weight: 400;
            }

            .status .dot {
                width: 5px;
                height: 5px;
            }
        }
    </style>
</head>

<body>

    <div class="admin_dash">

        <%- include("partials/AdminPageSidebar") %>

            <div class="attendance_card">

                <div class="headers">
                    <h1>Teacher Attendance</h1>
                    <div class="search-teach">
                        <i class="fa fa-search"></i>
                        <input type="text" id="searchInput" placeholder="Search by Name">
                    </div>
                </div>

                <div class="date_month_year">
                    <form method="POST" action="/mark-teacher-holiday"
                        style="display: flex; align-items: center; gap: 10px; flex-wrap: wrap;">
                        <label style="font-size: 14px;">Declare Holiday:</label>
                        <input type="text" onfocus="(this.type='date')" name="date" placeholder="Select Date" required
                            class="btn">
                        <input type="text" name="reason" placeholder="Reason" class="btn">
                        <button type="submit" class="save_month_year" style="padding: 6px 15px;">Mark</button>
                    </form>

                    <form method="GET" action="/view-attendance-teachers"
                        style="display: flex; gap: 10px; flex-wrap: wrap;">
                        <select name="month" class="select-box">
                            <% for(let m=1; m <=12; m++) { %>
                                <option value="<%= m %>" <%=parseInt(month)===m ? "selected" : "" %>>
                                    <%= moment().month(m - 1).format("MMMM") %>
                                </option>
                                <% } %>
                        </select>
                        <select name="year" class="select-box">
                            <% for(let y=2022; y <=2030; y++) { %>
                                <option value="<%= y %>" <%=parseInt(year)===y ? "selected" : "" %>>
                                    <%= y %>
                                </option>
                                <% } %>
                        </select>
                        <button class="save_month_year" type="submit">Go</button>
                    </form>

                    <!-- ⭐ Add Upload Button HERE -->
                    <button id="uploadBioBtn" data-origin="teacher" class="save_month_year"
                        style="padding: 7px 20px; height: 38px; background:#2563eb;">
                        Upload Biometric File
                    </button>
                </div>

                <div class="print-header" style="position: relative; margin-bottom: 30px;">

                    <div id="print-live-datetime"
                        style="position: absolute; left: 0; top: 0; text-align: left; font-size: 12px; font-family: sans-serif; color: #333;">
                    </div>

                    <div style="text-align: center; width: 100%;">
                        <h1 class="print-main-title" style="margin: 0; font-size: 26px; font-weight: bold;">Teacher
                            Attendance</h1>
                        <h3 class="print-month-title"
                            style="margin: 5px 0 0 0; font-size: 16px; font-weight: normal; color: #555 !important;">
                            <%= moment().month(month - 1).format("MMMM") %>
                                <%= year %> Attendance Report
                        </h3>
                    </div>
                </div>

                <div class="attendance_table">

                    <!-- HEADER -->
                    <div class="attend_list_header list">
                        <ul>
                            <li class="teachers_name">Name</li>
                            <% for(let i=1; i <=daysInMonth; i++) { %>
                                <li class="<%= i === today ? 'today-cell' : '' %>">
                                    <%= i < 10 ? '0' + i : i %>
                                </li>
                                <% } %>
                                    <li class="extra-col header-extra">Absent<br>Days</li>
                                    <li class="extra-col header-extra">Per day<br>Salary</li>
                                    <li class="extra-col header-extra">Total<br>Payable</li>
                                    <li class="extra-col header-extra">Status</li>
                        </ul>
                    </div>

                    <!-- BODY -->
                    <form id="attendance-form" action="/submit-attendance-teachers" method="POST">
                        <input type="hidden" name="month" value="<%= month %>">
                        <input type="hidden" name="year" value="<%= year %>">

                        <% teachers.forEach(teacher=> { %>
                            <div class="attend_list list teacher-row" data-name="<%= teacher.name.toLowerCase() %>">
                                <ul>
                                    <li class="teachers_name">
                                        <%= teacher.name %>
                                    </li>

                                    <% for (let i=1; i <=daysInMonth; i++) { %>
                                        <% let status=(attendanceMap[teacher._id?.toString()] || {})['day_' + i]; %>

                                            <li class="<%= (sundays.includes(i) || holidays.includes(i)) ? 'holiday-cell' : '' %>"
                                                data-full-date="<%= `${year}-${String(month).padStart(2,'0')}-${String(i).padStart(2,'0')}` %>"
                                                data-day="<%= i %>" data-month="<%= month %>" data-year="<%= year %>"
                                                data-reason="<%= holidayReasons[i] || (sundays.includes(i) ? 'Sunday' : '') %>">

                                                <% if (sundays.includes(i) || holidays.includes(i)) { %>
                                                    -
                                                    <% } else { %>
                                                        <!-- UPDATED DROPDOWN STRUCTURE -->
                                                        <div class="dropdown-wrapper"
                                                            style="<%= status ? 'display: none;' : '' %>">
                                                            <select class="attendance_dropdown"
                                                                name="attendance[<%= teacher._id %>][<%= 'day_' + i %>]">
                                                                <option value=""></option>
                                                                <option value="P" <%=status==="P" ? "selected" : "" %>>P
                                                                </option>
                                                                <option value="A" <%=status==="A" ? "selected" : "" %>>A
                                                                </option>
                                                                <option value="L" <%=status==="L" ? "selected" : "" %>>L
                                                                </option>
                                                            </select>
                                                            <i class="fa-solid fa-angle-down custom-arrow"></i>
                                                        </div>

                                                        <img src="<%= status === 'P' ? '/images/present.jpg' : status === 'A' ? '/images/absent.jpg' : status === 'L' ? '/images/late-image.png' : '' %>"
                                                            class="status-icon"
                                                            style="display: <%= status ? 'inline-block' : 'none' %>;" />
                                                        <% } %>
                                            </li>
                                            <% } %>

                                                <li class="extra-col" style="color:#e67817; font-weight:bold;">
                                                    <%= salaryData[teacher._id.toString()].totalAbsent %>
                                                </li>
                                                <li class="extra-col">
                                                    ₹ <%=
                                                        salaryData[teacher._id.toString()].dailySalary.toLocaleString('en-IN')
                                                        %>
                                                </li>
                                                <li class="extra-col" style="color:#1aaa55; font-weight:bold;">
                                                    ₹ <%=
                                                        salaryData[teacher._id.toString()].payableSalary.toLocaleString('en-IN')
                                                        %>
                                                </li>

                                                <li class="extra-col payment-status">
                                                    <!-- ✔ Yeh data backend bhegda -->
                                                    <input type="hidden" name="paymentStatus[<%= teacher._id %>]"
                                                        value="<%= salaryData[teacher._id].status %>"
                                                        class="payment-status-input" />

                                                    <% if (salaryData[teacher._id].status==="paid" ) { %>
                                                        <span class="status paid"><span class="dot"></span> Paid</span>
                                                        <% } else { %>
                                                            <span class="status pending"><span class="dot"></span>
                                                                Pending</span>
                                                            <% } %>

                                                                <!-- ✔ Yahan se name="" attribute hata diya hai kyunki hidden input kaam kar raha hai -->
                                                                <select class="payment_dropdown" style="display:none;">
                                                                    <option value="pending"
                                                                        <%=salaryData[teacher._id.toString()].status==='pending'
                                                                        ? 'selected' : '' %>>Pending</option>
                                                                    <option value="paid"
                                                                        <%=salaryData[teacher._id.toString()].status==='paid'
                                                                        ? 'selected' : '' %>>Paid</option>
                                                                </select>
                                                </li>
                                </ul>
                            </div>
                            <% }) %>
                    </form>
                </div>

                <div class="button-container"
                    style="margin-top: 40px; text-align: center; display: flex; justify-content: center; gap: 20px; flex-wrap: wrap;">

                    <button type="submit" form="attendance-form" class="save_month_year"
                        style="font-size: 18px; padding: 10px 30px;">Save Attendance</button>

                    <button onclick="window.print()" class="print-btn no-print">
                        Download PDF
                    </button>

                </div>

            </div>
    </div>

    <!-- Pop up for holiday reason -->
    <div id="holidayPopup" class="holiday-popup">
        <div class="holiday-card">
            <h3>Holiday</h3>
            <p id="holidayReason"></p>
            <button id="closePopup">Close</button>
        </div>
    </div>

    <!-- Biometric Upload Modal -->
    <div id="uploadModal" class="bio-modal">
        <div class="bio-modal-content">
            <div class="bio-modal-header">
                <h2><i class="fa-solid fa-fingerprint"></i> Upload Biometric Attendance</h2>
                <button class="bio-close-x" id="closeModal" type="button">✕</button>
            </div>
            <div id="bioUploadView">
                <div class="bio-modal-body">
                    <div class="bio-sample-bar">
                        <span><i class="fa-solid fa-circle-info"></i> Don't have the format?</span>
                        <a href="/download-biometric-sample" download>
                            <i class="fa-solid fa-download"></i> Download Sample
                        </a>
                    </div>
                    <div class="bio-format-info">
                        <strong>📋 Required File Format (3 columns):</strong><br>
                        <code>Employee ID &nbsp;|&nbsp; Date (DD-MM-YYYY) &nbsp;|&nbsp; Time (HH:MM)</code><br>
                        Accepted: <strong>.xlsx, .xls, .csv, .txt</strong><br>
                        ⏰ Late cutoff: <strong>09:10 AM</strong> (after → Marked Late)
                    </div>
                    <div class="bio-drop-zone" id="bioDropZone">
                        <input type="file" id="bioFileInput" accept=".csv,.xlsx,.xls,.txt">
                        <div class="bio-drop-icon"><i class="fa-solid fa-cloud-arrow-up"></i></div>
                        <div class="bio-drop-text"><strong>Click to browse</strong> or drag & drop file here</div>
                        <div class="bio-file-name" id="bioFileName"></div>
                    </div>
                    <div class="bio-buttons">
                        <button type="button" id="bioUploadBtn" class="bio-upload-btn">
                            <i class="fa-solid fa-upload"></i> Upload Attendance
                        </button>
                        <button type="button" class="bio-cancel-btn" id="bioCancelBtn">Cancel</button>
                    </div>
                </div>
            </div>
            <div id="bioProcessingView" style="display:none;">
                <div class="bio-processing">
                    <div class="bio-spinner"></div>
                    <p>Processing biometric file...<br><small style="color:#94a3b8;">Please wait, updating attendance records</small></p>
                </div>
            </div>
            <div id="bioResultView" style="display:none;">
                <div class="bio-result">
                    <div class="bio-result-icon" id="bioResultIcon"></div>
                    <h3 id="bioResultTitle"></h3>
                    <div id="bioResultDate" class="bio-result-date" style="display:none;"></div>
                    <div id="bioErrorMsg" class="bio-error-msg" style="display:none;"></div>
                    <div class="bio-stats" id="bioStatsGrid" style="display:none;">
                        <div class="bio-stat p"><div class="num" id="bioPresentCount">0</div><div class="lbl">Present</div></div>
                        <div class="bio-stat l"><div class="num" id="bioLateCount">0</div><div class="lbl">Late</div></div>
                        <div class="bio-stat a"><div class="num" id="bioAbsentCount">0</div><div class="lbl">Absent</div></div>
                    </div>
                    <div class="bio-result-actions">
                        <button type="button" class="bio-btn-primary" id="bioGoBtn" style="display:none;">View Attendance</button>
                        <button type="button" class="bio-btn-secondary" id="bioRetryBtn">Upload Another</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        window.addEventListener("DOMContentLoaded", () => {
            const todayElement = document.querySelector(".today-cell");
            if (todayElement) todayElement.scrollIntoView({
                behavior: "smooth",
                inline: "center",
                block: "nearest"
            });
        });

        document.getElementById("searchInput").addEventListener("input", function () {
            const val = this.value.toLowerCase();
            document.querySelectorAll(".teacher-row").forEach(row => {
                row.style.display = row.dataset.name.includes(val) ? "flex" : "none";
            });
        });

        // Dropdown -> Icon (only for past and today dates not open for future dates)

        document.querySelectorAll(".attendance_dropdown").forEach(dd => {

            dd.addEventListener("change", function () {

                const li = this.closest("li");
                const cellDate = li.dataset.fullDate;

                const today = new Date();
                const yyyy = today.getFullYear();
                const mm = String(today.getMonth() + 1).padStart(2, "0");
                const ddStr = String(today.getDate()).padStart(2, "0");

                const todayFull = `${yyyy}-${mm}-${ddStr}`;
                const todayDate = new Date(todayFull);
                const clickedDate = new Date(cellDate);

                // ❌ BLOCK FUTURE DATES
                if (clickedDate > todayDate) {
                    alert("You cannot mark attendance for a FUTURE date.");
                    this.value = "";   // reset dropdown
                    return;
                }

                // ✔ existing logic (icon show etc.)
                const wrapper = this.parentElement;
                const img = wrapper.nextElementSibling;
                const val = this.value;

                if (val === 'P') { img.src = '/images/present.jpg'; img.style.display = 'inline-block'; wrapper.style.display = 'none'; }
                else if (val === 'A') { img.src = '/images/absent.jpg'; img.style.display = 'inline-block'; wrapper.style.display = 'none'; }
                else if (val === 'L') { img.src = '/images/late-image.png'; img.style.display = 'inline-block'; wrapper.style.display = 'none'; }
            });
        });

        // Icon -> Dropdown

        document.querySelectorAll(".status-icon").forEach(img => {

            img.addEventListener("click", function () {

                const li = this.closest("li");
                if (!li) return;

                const cellDate = li.dataset.fullDate;  // This is ISO format: YYYY-MM-DD

                // Today full date (also ISO format)
                const today = new Date();
                const yyyy = today.getFullYear();
                const mm = String(today.getMonth() + 1).padStart(2, "0");
                const dd = String(today.getDate()).padStart(2, "0");
                const todayFull = `${yyyy}-${mm}-${dd}`;

                // If not today → stop
                if (cellDate !== todayFull) {
                    alert("You can only edit attendance for TODAY.");
                    return;
                }


                this.style.display = 'none';
                const wrapper = this.previousElementSibling; // .dropdown-wrapper
                wrapper.style.display = 'inline-block';
                wrapper.querySelector("select").value = "";
            });

        });

        // Payment Status Logic
        document.querySelectorAll(".payment-status").forEach(cell => {
            const badge = cell.querySelector(".status");
            const select = cell.querySelector(".payment_dropdown");
            const input = cell.querySelector(".payment-status-input");

            badge.addEventListener("click", () => { badge.style.display = 'none'; select.style.display = 'block'; });
            select.addEventListener("change", function () {
                input.value = this.value;
                select.style.display = 'none';
                badge.className = `status ${this.value}`;
                badge.innerHTML = `<span class="dot"></span> ${this.value.charAt(0).toUpperCase() + this.value.slice(1)}`;
                badge.style.display = 'inline-flex';
            });
        });

        // Holiday Popup
        document.querySelectorAll(".holiday-cell").forEach(c => {
            c.addEventListener("click", () => {
                const r = c.dataset.reason;
                if (r) { document.getElementById("holidayReason").innerText = r; document.getElementById("holidayPopup").style.display = 'flex'; }
            });
        });
        document.getElementById("closePopup").addEventListener("click", () => document.getElementById("holidayPopup").style.display = 'none');


        // Biometric modal logic
        (function() {
            const modal       = document.getElementById("uploadModal");
            const uploadView  = document.getElementById("bioUploadView");
            const processingView = document.getElementById("bioProcessingView");
            const resultView  = document.getElementById("bioResultView");
            const fileInput   = document.getElementById("bioFileInput");
            const fileName    = document.getElementById("bioFileName");
            const dropZone    = document.getElementById("bioDropZone");
            const uploadBtn   = document.getElementById("bioUploadBtn");
            const cancelBtn   = document.getElementById("bioCancelBtn");
            const closeBtn    = document.getElementById("closeModal");
            const retryBtn    = document.getElementById("bioRetryBtn");
            const goBtn       = document.getElementById("bioGoBtn");
            let bioOrigin     = "teacher";
            let redirectUrl   = "/view-attendance-teachers";

            function openModal(origin) {
                bioOrigin = origin || "teacher";
                modal.classList.add("active");
                showUploadView();
            }
            function closeModal() { modal.classList.remove("active"); }
            function showUploadView() {
                uploadView.style.display = "";
                processingView.style.display = "none";
                resultView.style.display = "none";
                fileInput.value = "";
                fileName.textContent = "";
            }
            function showResult(data) {
                uploadView.style.display = "none";
                processingView.style.display = "none";
                resultView.style.display = "";
                const icon   = document.getElementById("bioResultIcon");
                const title  = document.getElementById("bioResultTitle");
                const dateEl = document.getElementById("bioResultDate");
                const errEl  = document.getElementById("bioErrorMsg");
                const stats  = document.getElementById("bioStatsGrid");

                if (data.success) {
                    icon.className = "bio-result-icon success";
                    icon.innerHTML = "✓";
                    title.textContent = "Attendance Uploaded!";
                    title.style.color = "#15803d";
                    dateEl.style.display = "inline-block";
                    dateEl.textContent = "📅 " + data.date;
                    errEl.style.display = "none";
                    stats.style.display = "grid";
                    document.getElementById("bioPresentCount").textContent = data.presentCount || 0;
                    document.getElementById("bioLateCount").textContent    = data.lateCount || 0;
                    document.getElementById("bioAbsentCount").textContent  = data.absentCount || 0;
                    redirectUrl = data.redirectUrl || "/view-attendance-teachers";
                    goBtn.style.display = "inline-block";
                } else {
                    icon.className = "bio-result-icon error";
                    icon.innerHTML = "✕";
                    title.textContent = "Upload Failed";
                    title.style.color = "#b91c1c";
                    dateEl.style.display = "none";
                    errEl.style.display = "block";
                    errEl.textContent = data.message || "Something went wrong.";
                    stats.style.display = "none";
                    goBtn.style.display = "none";
                }
            }

            document.getElementById("uploadBioBtn").addEventListener("click", (e) => {
                openModal(e.currentTarget.dataset.origin);
            });
            closeBtn.addEventListener("click", closeModal);
            cancelBtn.addEventListener("click", closeModal);
            modal.addEventListener("click", (e) => { if (e.target === modal) closeModal(); });
            retryBtn.addEventListener("click", showUploadView);
            goBtn.addEventListener("click", () => { window.location.href = redirectUrl; });

            fileInput.addEventListener("change", () => {
                fileName.textContent = fileInput.files[0]?.name || "";
            });
            dropZone.addEventListener("dragover", (e) => { e.preventDefault(); dropZone.classList.add("dragover"); });
            dropZone.addEventListener("dragleave", () => dropZone.classList.remove("dragover"));
            dropZone.addEventListener("drop", (e) => {
                e.preventDefault(); dropZone.classList.remove("dragover");
                const file = e.dataTransfer.files[0];
                if (file) {
                    const dt = new DataTransfer();
                    dt.items.add(file);
                    fileInput.files = dt.files;
                    fileName.textContent = file.name;
                }
            });

            uploadBtn.addEventListener("click", () => {
                const file = fileInput.files[0];
                if (!file) { alert("Please select a file first."); return; }

                const formData = new FormData();
                formData.append("bioFile", file);
                formData.append("origin", bioOrigin);

                uploadView.style.display = "none";
                processingView.style.display = "";

                fetch("/upload-biometric", { method: "POST", body: formData })
                    .then(r => r.json())
                    .then(data => { showResult(data); })
                    .catch(() => {
                        showResult({ success: false, message: "Network error. Please try again." });
                    });
            });
        })();

        // For printing live date time on pdf report
        window.onbeforeprint = function () {
            const now = new Date();
            const options = { year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit', second: '2-digit' };
            document.getElementById('print-live-datetime').innerHTML = "<b>Generated on:</b><br>" + now.toLocaleDateString('en-IN', options);
        };
    </script>
  <script src="/backButton.js"></script>
</body>

</html>